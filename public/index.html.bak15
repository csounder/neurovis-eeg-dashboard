                      "\u2022 ",
                      h("b", null, "Also compatible:"),
                      " Max/MSP, Pure Data, TouchDesigner, Processing, SuperCollider, Ableton (Max for Live), Unity, Unreal",
                      h("br"),
                      "\u2022 ",
                      h("b", null, "Tip:"),
                      " Uncomment one OSClisten line at a time in your .csd to switch bands. Use samphold + metro for rhythmic sampling.",
                    ),
                  ),
                ),
              ),

            displayMode === "single" &&
              view === "processing" &&
              h(
                Card,
                { t: th, title: "DSP Processing" },
                h(
                  "div",
                  { style: { padding: 12, color: th.t2, fontSize: 12 } },
                  "DSP controls (filters, smoothing) are in the sensor connection panel. Tab 15: Sensor Connect.",
                ),
              ),

            displayMode === "single" &&
              view === "calibration" &&
              h(
                Card,
                {
                  t: th,
                  title: "📊 Baseline Calibration (NeurOSC Research-Grade)",
                },
                h(
                  "div",
                  { style: { padding: 16 } },
                  h(
                    "div",
                    {
                      style: {
                        fontSize: 12,
                        color: th.t2,
                        marginBottom: 16,
                      },
                    },
                    "Mateo Goddard's Stanford neuroscience baseline system. Passively collects a rolling 30-second window for z-score normalization.",
                  ),
                  h(
                    "div",
                    { style: { fontSize: 11, color: th.t3 } },
                    "Full calibration controls are in Tab 15: Sensor Connect → Baseline/Calibration section.",
                  ),
                ),
              ),

            displayMode === "single" &&
              view === "presets" &&
              h(
                "div",
                {
                  style: {
                    display: "flex",
                    flexDirection: "column",
                    gap: 12,
                  },
                },

                // ══════════════════════════════════════════════════════════════
                // PERFORMANCE PRESETS (Complete Settings Snapshots)
                // ══════════════════════════════════════════════════════════════
                h(
                  Card,
                  { t: th, title: "🎭 Performance Presets" },
                  h(
                    "div",
                    null,
                    h(
                      "div",
                      {
                        style: {
                          fontSize: 9,
                          color: th.t3,
                          marginBottom: 10,
                        },
                      },
                      "Complete settings snapshots for live performance. Each preset saves: DSP filters, OSC config, display view, band toggles, scales, and calibration. Use keyboard shortcuts 1-9 to load instantly during performance.",
                    ),

                    // Preset list
                    h(
                      "div",
                      { style: { marginBottom: 12 } },
                      perfPresets.length === 0
                        ? h(
                            "div",
                            {
                              style: {
                                padding: 16,
                                textAlign: "center",
                                color: th.t3,
                                fontSize: 9,
                              },
                            },
                            "No presets yet — click Save Current or Import",
                          )
                        : perfPresets.map(function (preset, idx) {
                            var isActive = activePreset === preset.id;
                            return h(
                              "div",
                              {
                                key: preset.id,
                                style: {
                                  padding: 10,
                                  borderRadius: 8,
                                  background: isActive ? th.ac + "15" : th.sg,
                                  border:
                                    "2px solid " + (isActive ? th.ac : th.bd),
                                  marginBottom: 6,
                                },
                              },
                              h(
                                "div",
                                {
                                  style: {
                                    display: "flex",
                                    justifyContent: "space-between",
                                    alignItems: "center",
                                  },
                                },
                                h(
                                  "div",
                                  { style: { flex: 1 } },
                                  h(
                                    "div",
                                    {
                                      style: {
                                        display: "flex",
                                        alignItems: "center",
                                        gap: 6,
                                      },
                                    },
                                    h(
                                      "span",
                                      {
                                        style: {
                                          fontSize: 9,
                                          fontWeight: 700,
                                          color: th.t3,
                                          minWidth: 20,
                                        },
                                      },
                                      idx + 1,
                                    ),
                                    h(
                                      "span",
                                      {
                                        style: {
                                          fontSize: 11,
                                          fontWeight: 700,
                                          color: isActive ? th.ac : th.t2,
                                        },
                                      },
                                      preset.name,
                                    ),
                                  ),
                                  h(
                                    "div",
                                    {
                                      style: {
                                        fontSize: 8,
                                        color: th.t3,
                                        marginTop: 4,
                                      },
                                    },
                                    "DSP: " +
                                      (preset.dsp.car ? "CAR " : "") +
                                      (preset.dsp.notch ? "Notch " : "") +
                                      (preset.dsp.bandpass ? "BP " : "") +
                                      "• OSC: " +
                                      preset.osc.bands.join(", ") +
                                      " @ " +
                                      preset.osc.rate +
                                      "Hz • View: " +
                                      preset.display.view,
                                  ),
                                ),
                                h(
                                  "div",
                                  { style: { display: "flex", gap: 4 } },
                                  h(
                                    "button",
                                    {
                                      onClick: function () {
                                        loadPreset(preset);
                                      },
                                      style: {
                                        padding: "4px 10px",
                                        borderRadius: 5,
                                        border: "1px solid " + th.ac,
                                        background: th.ac + "20",
                                        color: th.ac,
                                        fontSize: 9,
                                        fontWeight: 700,
                                        cursor: "pointer",
                                      },
                                    },
                                    "Load",
                                  ),
                                  h(
                                    "button",
                                    {
                                      onClick: function () {
                                        var newName = prompt(
                                          "Rename preset:",
                                          preset.name,
                                        );
                                        if (newName)
                                          renamePreset(preset.id, newName);
                                      },
                                      title: "Rename",
                                      style: {
                                        padding: "4px 8px",
                                        borderRadius: 5,
                                        border: "1px solid " + th.bd,
                                        background: "transparent",
                                        color: th.t3,
                                        fontSize: 9,
                                        cursor: "pointer",
                                      },
                                    },
                                    "✏️",
                                  ),
                                  h(
                                    "button",
                                    {
                                      onClick: function () {
                                        exportPreset(preset);
                                      },
                                      title: "Export to file",
                                      style: {
                                        padding: "4px 8px",
                                        borderRadius: 5,
                                        border: "1px solid " + th.bd,
                                        background: "transparent",
                                        color: th.t3,
                                        fontSize: 9,
                                        cursor: "pointer",
                                      },
                                    },
                                    "💾",
                                  ),
                                  h(
                                    "button",
                                    {
                                      onClick: function () {
                                        if (
                                          confirm(
                                            'Delete "' + preset.name + '"?',
                                          )
                                        )
                                          deletePreset(preset.id);
                                      },
                                      title: "Delete",
                                      style: {
                                        padding: "4px 8px",
                                        borderRadius: 5,
                                        border: "1px solid #ef4444",
                                        background: "transparent",
                                        color: "#ef4444",
                                        fontSize: 9,
                                        cursor: "pointer",
                                      },
                                    },
                                    "🗑",
                                  ),
                                ),
                              ),
                            );
                          }),
                    ),

                    // Action buttons
                    h(
                      "div",
                      {
                        style: {
                          display: "flex",
                          gap: 6,
                          flexWrap: "wrap",
                        },
                      },
                      h(
                        "button",
                        {
                          onClick: function () {
                            var name = prompt(
                              "Preset name:",
                              "My Performance Setup",
                            );
                            if (name) saveCurrentAsPreset(name);
                          },
                          style: {
                            padding: "6px 14px",
                            borderRadius: 7,
                            border: "2px solid #10b981",
                            background: "#10b98120",
                            color: "#10b981",
                            fontSize: 10,
                            fontWeight: 700,
                            cursor: "pointer",
                          },
                        },
                        "💾 Save Current as Preset",
                      ),
                      h(
                        "label",
                        {
                          style: {
                            padding: "6px 14px",
                            borderRadius: 7,
                            border: "2px solid #3b82f6",
                            background: "#3b82f620",
                            color: "#3b82f6",
                            fontSize: 10,
                            fontWeight: 700,
                            cursor: "pointer",
                          },
                        },
                        "📁 Import Preset File",
                        h("input", {
                          type: "file",
                          accept: ".json",
                          onChange: function (e) {
                            var file = e.target.files[0];
                            if (file) {
                              var reader = new FileReader();
                              reader.onload = function (event) {
                                importPreset(event.target.result);
                              };
                              reader.readAsText(file);
                            }
                          },
                          style: { display: "none" },
                        }),
                      ),
                      h(
                        "button",
                        {
                          onClick: function () {
                            var json = JSON.stringify(perfPresets, null, 2);
                            var blob = new Blob([json], {
                              type: "application/json",
                            });
                            var url = URL.createObjectURL(blob);
                            var a = document.createElement("a");
                            a.href = url;
                            a.download = "neurovis_all_presets.json";
                            a.click();
                            URL.revokeObjectURL(url);
                          },
                          style: {
                            padding: "6px 14px",
                            borderRadius: 7,
                            border: "1px solid " + th.bd,
                            background: th.sg,
                            color: th.t2,
                            fontSize: 10,
                            fontWeight: 600,
                            cursor: "pointer",
                          },
                        },
                        "📦 Export All Presets",
                      ),
                    ),
                  ),
                ),

                // ══════════════════════════════════════════════════════════════
                // MIDI CONTROL (Foot Pedals, Controllers)
                // ══════════════════════════════════════════════════════════════
                h(
                  Card,
                  { t: th, title: "🎹 MIDI Control" },
                  h(
                    "div",
                    null,
                    h(
                      "div",
                      {
                        style: {
                          fontSize: 9,
                          color: th.t3,
                          marginBottom: 10,
                        },
                      },
                      "Map MIDI notes or CC messages from foot pedals or controllers to trigger presets during live performance. Click 'Learn' next to a preset, then press the MIDI button/pedal you want to use.",
                    ),

                    // MIDI Device Selector
                    h(
                      "div",
                      { style: { marginBottom: 12 } },
                      h(
                        "div",
                        {
                          style: {
                            fontSize: 9,
                            fontWeight: 700,
                            color: th.t2,
                            marginBottom: 4,
                          },
                        },
                        "MIDI Input Device:",
                      ),
                      midiDevices.length === 0
                        ? h(
                            "div",
                            {
                              style: {
                                padding: 8,
                                background: "#f59e0b20",
                                border: "1px solid #f59e0b",
                                borderRadius: 6,
                                fontSize: 8,
                                color: "#f59e0b",
                              },
                            },
                            "⚠️ No MIDI devices found. Connect a MIDI controller or foot pedal.",
                          )
                        : h(
                            "div",
                            {
                              style: {
                                display: "flex",
                                gap: 6,
                                alignItems: "center",
                              },
                            },
                            h(
                              "select",
                              {
                                value: midiDevice || "",
                                onChange: function (e) {
                                  setMidiDevice(e.target.value);
                                },
                                style: {
                                  flex: 1,
                                  fontSize: 9,
                                  padding: "6px 10px",
                                  borderRadius: 6,
                                  border: "1px solid " + th.bd,
                                  background: th.c2,
                                  color: th.t2,
                                },
                              },
                              midiDevices.map(function (dev) {
                                return h(
                                  "option",
                                  { key: dev.id, value: dev.id },
                                  dev.name + " (" + dev.manufacturer + ")",
                                );
                              }),
                            ),
                            midiActivity &&
                              h(
                                "span",
                                {
                                  style: {
                                    fontSize: 8,
                                    padding: "4px 8px",
                                    background: "#10b981",
                                    color: "white",
                                    borderRadius: 4,
                                    fontWeight: 700,
                                    animation: "pulse 0.2s",
                                  },
                                },
                                "🎹 " +
                                  (midiActivity.noteOrCC || 0) +
                                  " (" +
                                  (midiActivity.velocity || 0) +
                                  ")",
                              ),
                          ),
                    ),

                    // MIDI Mappings for Presets
                    h(
                      "div",
                      { style: { marginBottom: 12 } },
                      h(
                        "div",
                        {
                          style: {
                            fontSize: 9,
                            fontWeight: 700,
                            color: th.t2,
                            marginBottom: 6,
                          },
                        },
                        "Preset Mappings:",
                      ),
                      perfPresets.length === 0
                        ? h(
                            "div",
                            {
                              style: {
                                padding: 8,
                                fontSize: 8,
                                color: th.t3,
                                textAlign: "center",
                              },
                            },
                            "Create presets first, then map MIDI controls to them.",
                          )
                        : h(
                            "div",
                            {
                              style: {
                                display: "flex",
                                flexDirection: "column",
                                gap: 4,
                              },
                            },
                            perfPresets.map(function (preset, idx) {
                              // Find MIDI mapping for this preset
                              var mappedKey = null;
                              Object.keys(midiMappings).forEach(function (key) {
                                if (midiMappings[key] === preset.id) {
                                  mappedKey = key;
                                }
                              });

                              var isLearning = midiLearn === preset.id;

                              return h(
                                "div",
                                {
                                  key: preset.id,
                                  style: {
                                    display: "flex",
                                    alignItems: "center",
                                    gap: 6,
                                    padding: "6px 8px",
                                    background: isLearning
                                      ? "#10b98120"
                                      : th.sg,
                                    border:
                                      "1px solid " +
                                      (isLearning ? "#10b981" : th.bd),
                                    borderRadius: 6,
                                  },
                                },
                                h(
                                  "span",
                                  {
                                    style: {
                                      fontSize: 8,
                                      fontWeight: 700,
                                      color: th.t3,
                                      minWidth: 16,
                                    },
                                  },
                                  idx + 1,
                                ),
                                h(
                                  "span",
                                  {
                                    style: {
                                      flex: 1,
                                      fontSize: 9,
                                      color: th.t2,
                                    },
                                  },
                                  preset.name,
                                ),
                                mappedKey
                                  ? h(
                                      "div",
                                      {
                                        style: {
                                          display: "flex",
                                          gap: 4,
                                          alignItems: "center",
                                        },
                                      },
                                      h(
                                        "span",
                                        {
                                          style: {
                                            fontSize: 8,
                                            padding: "2px 6px",
                                            background: "#3b82f620",
                                            color: "#3b82f6",
                                            borderRadius: 4,
                                            fontWeight: 700,
                                          },
                                        },
                                        mappedKey
                                          .replace("note", "Note ")
                                          .replace("cc", "CC "),
                                      ),
                                      h(
                                        "button",
                                        {
                                          onClick: function () {
                                            clearMidiMapping(mappedKey);
                                          },
                                          style: {
                                            fontSize: 8,
                                            padding: "2px 6px",
                                            background: "transparent",
                                            border: "1px solid #ef4444",
                                            color: "#ef4444",
                                            borderRadius: 4,
                                            cursor: "pointer",
                                          },
                                        },
                                        "✕",
                                      ),
                                    )
                                  : h(
                                      "button",
                                      {
                                        onClick: function () {
                                          setMidiLearn(
                                            isLearning ? null : preset.id,
                                          );
                                        },
                                        style: {
                                          fontSize: 8,
                                          padding: "4px 10px",
                                          background: isLearning
                                            ? "#10b981"
                                            : "transparent",
                                          border:
                                            "1px solid " +
                                            (isLearning ? "#10b981" : th.bd),
                                          color: isLearning ? "white" : th.t2,
                                          borderRadius: 4,
                                          cursor: "pointer",
                                          fontWeight: 700,
                                        },
                                      },
                                      isLearning ? "⏺ Press MIDI..." : "Learn",
                                    ),
                              );
                            }),
                          ),
                    ),

                    // MIDI Info
                    h(
                      "div",
                      {
                        style: {
                          fontSize: 8,
                          color: th.t3,
                          padding: "8px 10px",
                          background: th.sg,
                          borderRadius: 6,
                          marginTop: 8,
                        },
                      },
                      "💡 Tip: MIDI mappings are saved automatically and work even when this tab is not visible. Perfect for foot controllers during live performance!",
                    ),
                  ),
                ),

                // ── Processing Presets (OLD - keeping for compatibility) ──
                h(
                  Card,
                  { t: th, title: "Processing Presets (Legacy)" },
                  h(
                    "div",
                    null,
                    h(
                      "div",
                      {
                        style: {
                          fontSize: 8,
                          color: th.t3,
                          marginBottom: 8,
                        },
                      },
                      "Save and recall filter/smoother/gate settings. Applies to all displays and recordings.",
                    ),
                    h(
                      "div",
                      {
                        style: {
                          display: "flex",
                          flexWrap: "wrap",
                          gap: 4,
                          marginBottom: 8,
                        },
                      },
                      presets.map(function (pr, i) {
                        return h(
                          "button",
                          {
                            key: i,
                            onClick: function () {
                              setPid(pr.p);
                              setFp(function (f) {
                                return Object.assign({}, f, pr.f);
                              });
                            },
                            style: {
                              padding: "6px 10px",
                              borderRadius: 7,
                              border:
                                "1px solid " + (pid === pr.p ? th.ac : th.bd),
                              background:
                                pid === pr.p ? th.ac + "15" : "transparent",
                            },
                          },
                          h(
                            "div",
                            {
                              style: {
                                fontSize: 10,
                                fontWeight: 700,
                                color: pid === pr.p ? th.ac : th.tx,
                              },
                            },
                            pr.n,
                          ),
                          h(
                            "div",
                            { style: { fontSize: 8, color: th.t3 } },
                            (
                              PROCS.find(function (p) {
                                return p.id === pr.p;
                              }) || {}
                            ).n,
                          ),
                        );
                      }),
                    ),
                    h(
                      "div",
                      { style: { display: "flex", gap: 6 } },
                      h(
                        "button",
                        {
                          onClick: function () {
                            var n = prompt("Preset name:");
                            if (n)
                              setPresets(function (p) {
                                return p.concat([
                                  {
                                    n: n,
                                    p: pid,
                                    f: Object.assign({}, fp),
                                  },
                                ]);
                              });
                          },
                          style: {
                            padding: "4px 12px",
                            borderRadius: 6,
                            border: "1px solid " + th.ac,
                            background: th.ac + "15",
                            color: th.ac,
                            fontSize: 10,
                            fontWeight: 700,
                          },
                        },
                        "+Save Current Processing",
                      ),
                      presets.length > 3 &&
                        h(
                          "button",
                          {
                            onClick: function () {
                              if (confirm("Delete last custom preset?"))
                                setPresets(function (p) {
                                  return p.slice(0, p.length - 1);
                                });
                            },
                            style: {
                              padding: "4px 12px",
                              borderRadius: 6,
                              border: "1px solid " + th.rd,
                              background: th.rd + "10",
                              color: th.rd,
                              fontSize: 10,
                              fontWeight: 600,
                            },
                          },
                          "\u2715 Delete Last",
                        ),
                    ),
                  ),
                ),

                // ── OSC Presets ──
                h(
                  Card,
                  {
                    t: th,
                    title: "OSC Presets \u2014 Per-App Stream Configurations",
                  },
                  h(
                    "div",
                    null,
                    h(
                      "div",
                      { style: { marginBottom: 10 } },
                      h(
                        "div",
                        {
                          style: {
                            fontSize: 9,
                            color: th.t3,
                            marginBottom: 6,
                          },
                        },
                        "Complete settings snapshots for live performance. Each preset saves: DSP filters, OSC config, display view, band toggles, scales, and calibration.",
                      ),
                      h(
                        "div",
                        {
                          style: {
                            fontSize: 8,
                            color: "#10b981",
                            fontWeight: 700,
                            padding: "4px 8px",
                            background: "#10b98110",
                            borderRadius: 5,
                            display: "inline-block",
                          },
                        },
                        "⌨️ Keyboard: Press 1-9 to load presets instantly",
                      ),
                    ),
                    h(
                      "div",
                      {
                        style: {
                          display: "flex",
                          flexDirection: "column",
                          gap: 6,
                          marginBottom: 10,
                        },
                      },
                      oscPresets.map(function (op, i) {
                        var isActive =
                          oscBands.join() === op.bands.join() &&
                          oscRate === op.rate;
                        return h(
                          "div",
                          {
                            key: i,
                            onClick: function () {
                              setOscBands(op.bands.slice());
                              setOscExtras(op.extras.slice());
                              setOscRate(op.rate);
                              setOscSmooth(op.smooth);
                              setOscFilt(op.filt);
                            },
                            style: {
                              padding: "10px 12px",
                              borderRadius: 8,
                              border: "1px solid " + (isActive ? th.ac : th.bd),
                              background: isActive
                                ? th.ac + "10"
                                : "transparent",
                              cursor: "pointer",
                            },
                          },
                          h(
                            "div",
                            {
                              style: {
                                display: "flex",
                                justifyContent: "space-between",
                                alignItems: "center",
                                marginBottom: 4,
                              },
                            },
                            h(
                              "div",
                              {
                                style: {
                                  display: "flex",
                                  alignItems: "center",
                                  gap: 6,
                                },
                              },
                              h(
                                "span",
                                {
                                  style: {
                                    fontSize: 11,
                                    fontWeight: 700,
                                    color: isActive ? th.ac : th.tx,
                                  },
                                },
                                op.n,
                              ),
                              h(
                                "span",
                                {
                                  style: {
                                    fontSize: 7,
                                    padding: "1px 6px",
                                    borderRadius: 4,
                                    background: th.wr + "20",
                                    color: th.wr,
                                    fontWeight: 700,
                                  },
                                },
                                op.target,
                              ),
                            ),
                            h(
                              "div",
                              { style: { display: "flex", gap: 4 } },
                              h(
                                "span",
                                {
                                  style: {
                                    fontSize: 8,
                                    padding: "1px 5px",
                                    borderRadius: 4,
                                    background: th.sg,
                                    border: "1px solid " + th.bd,
                                    fontFamily: M,
                                    color: th.t2,
                                  },
                                },
                                op.rate + " Hz",
                              ),
                              h(
                                "span",
                                {
                                  style: {
                                    fontSize: 8,
                                    padding: "1px 5px",
                                    borderRadius: 4,
                                    background: th.sg,
                                    border: "1px solid " + th.bd,
                                    fontFamily: M,
                                    color: th.t2,
                                  },
                                },
                                "\u03B1 " + op.smooth,
                              ),
                              h(
                                "span",
                                {
                                  style: {
                                    fontSize: 8,
                                    padding: "1px 5px",
                                    borderRadius: 4,
                                    background: op.filt
                                      ? th.gd + "20"
                                      : th.bd + "40",
                                    color: op.filt ? th.gd : th.t3,
                                  },
                                },
                                op.filt ? "Filtered" : "Raw",
                              ),
                            ),
                          ),
                          h(
                            "div",
                            {
                              style: {
                                display: "flex",
                                gap: 3,
                                marginBottom: 3,
                              },
                            },
                            op.bands.map(function (bn) {
                              var b = BANDS.find(function (x) {
                                return x.n === bn;
                              });
                              var c = b ? (th === TH.dark ? b.d : b.c) : th.t3;
                              return h(
                                "span",
                                {
                                  key: bn,
                                  style: {
                                    fontSize: 7,
                                    padding: "1px 5px",
                                    borderRadius: 10,
                                    background: c + "20",
                                    color: c,
                                    fontWeight: 700,
                                  },
                                },
                                bn,
                              );
                            }),
                            op.extras.map(function (ex) {
                              return h(
                                "span",
                                {
                                  key: ex,
                                  style: {
                                    fontSize: 7,
                                    padding: "1px 5px",
                                    borderRadius: 10,
                                    background: th.wr + "15",
                                    color: th.wr,
                                  },
                                },
                                ex.toUpperCase(),
                              );
                            }),
                          ),
                          h(
                            "div",
                            { style: { fontSize: 8, color: th.t3 } },
                            op.desc,
                          ),
                        );
                      }),
                    ),
                    // Save new OSC preset
                    h(
                      "button",
                      {
                        onClick: function () {
                          var n = prompt("OSC Preset name:");
                          if (!n) return;
                          var tgt =
                            prompt(
                              "Target app (Csound, Max/MSP, TouchDesigner, Unity, Ableton, Logic, Other):",
                            ) || "Other";
                          setOscPresets(function (p) {
                            return p.concat([
                              {
                                n: n,
                                target: tgt,
                                bands: oscBands.slice(),
                                extras: oscExtras.slice(),
                                rate: oscRate,
                                smooth: oscSmooth,
                                filt: oscFilt,
                                desc:
                                  "Custom \u2014 " +
                                  oscBands.length +
                                  " bands" +
                                  (oscExtras.length > 0
                                    ? " + " + oscExtras.join(",")
                                    : "") +
                                  " at " +
                                  oscRate +
                                  "Hz",
                              },
                            ]);
                          });
                        },
                        style: {
                          padding: "5px 14px",
                          borderRadius: 6,
                          border: "1px solid " + th.ac,
                          background: th.ac + "15",
                          color: th.ac,
                          fontSize: 10,
                          fontWeight: 700,
                          marginBottom: 8,
                        },
                      },
                      "+Save Current OSC Config as Preset",
                    ),
                    oscPresets.length > 6 &&
                      h(
                        "button",
                        {
                          onClick: function () {
                            if (confirm("Delete last custom OSC preset?"))
                              setOscPresets(function (p) {
                                return p.slice(0, p.length - 1);
                              });
                          },
                          style: {
                            padding: "4px 12px",
                            borderRadius: 6,
                            border: "1px solid " + th.rd,
                            background: th.rd + "10",
                            color: th.rd,
                            fontSize: 10,
                            fontWeight: 600,
                            marginLeft: 8,
                          },
                        },
                        "\u2715 Delete Last",
                      ),

                    // Current OSC state summary
                    h(
                      "div",
                      {
                        style: {
                          marginTop: 10,
                          padding: "8px 10px",
                          borderRadius: 8,
                          background: th.sg,
                          border: "1px solid " + th.bd,
                        },
                      },
                      h(
                        "div",
                        {
                          style: {
                            fontSize: 9,
                            fontWeight: 700,
                            color: th.t2,
                            marginBottom: 4,
                          },
                        },
                        "Current OSC State",
                      ),
                      h(
                        "div",
                        {
                          style: {
                            fontSize: 8,
                            color: th.t3,
                            lineHeight: 1.7,
                            fontFamily: M,
                          },
                        },
                        "Bands: " + oscBands.join(", "),
                        h("br"),
                        "Extras: " +
                          (oscExtras.length > 0
                            ? oscExtras.join(", ")
                            : "none"),
                        h("br"),
                        "Rate: " +
                          oscRate +
                          " Hz | Smooth: " +
                          oscSmooth.toFixed(2),
                        h("br"),
                        "Filter: " +
                          (oscFilt
                            ? (
                                PROCS.find(function (p) {
                                  return p.id === pid;
                                }) || {}
                              ).n
                            : "OFF (raw)"),
                        h("br"),
                        "Port: " +
                          oscPort +
                          " | Messages/tick: ~" +
                          (oscBands.length + oscExtras.length),
                      ),
                    ),
                  ),
                ),

                // ── Aux Toggles ──
                h(
                  Card,
                  { t: th, title: "Aux Sensor Toggles" },
                  h(
                    "div",
                    null,
                    Object.keys(d.aux).length === 0
                      ? h(
                          "div",
                          {
                            style: {
                              fontSize: 10,
                              color: th.t3,
                              padding: 8,
                            },
                          },
                          "No aux sensors on " + d.name,
                        )
                      : Object.keys(d.aux).map(function (k) {
                          return h(
                            "div",
                            {
                              key: k,
                              style: {
                                display: "flex",
                                alignItems: "center",
                                justifyContent: "space-between",
                                padding: "6px 10px",
                                borderRadius: 6,
                                background: th.sg,
                                border: "1px solid " + th.bd,
                                marginBottom: 3,
                              },
                            },
                            h(
                              "div",
                              null,
                              h(
                                "span",
                                {
                                  style: {
                                    fontSize: 10,
                                    fontWeight: 700,
                                    textTransform: "uppercase",
                                    color: auxOn[k] !== false ? th.tx : th.t3,
                                  },
                                },
                                k,
                              ),
                              h(
                                "span",
                                {
                                  style: {
                                    fontSize: 8,
                                    color: th.t3,
                                    marginLeft: 6,
                                  },
                                },
                                d.aux[k].d,
                              ),
                            ),
                            h(
                              "button",
                              {
                                onClick: function () {
                                  setAuxOn(function (p) {
                                    var n = {};
                                    for (var x in p) n[x] = p[x];
                                    n[k] = p[k] === false;
                                    return n;
                                  });
                                },
                                style: {
                                  width: 30,
                                  height: 16,
                                  borderRadius: 8,
                                  border: "none",
                                  background:
                                    auxOn[k] !== false ? th.gd : th.bd,
                                  position: "relative",
                                },
                              },
                              h("div", {
                                style: {
                                  width: 12,
                                  height: 12,
                                  borderRadius: 6,
                                  background: "#fff",
                                  position: "absolute",
                                  top: 2,
                                  left: auxOn[k] !== false ? 16 : 2,
                                  transition: "left .2s",
                                },
                              }),
                            ),
                          );
                        }),
                  ),
                ),
              ),

            displayMode === "single" &&
              view === "recs" &&
              h(
                Card,
                { t: th, title: "Recordings (" + recs.length + ")" },
                recs.length === 0
                  ? h(
                      "div",
                      {
                        style: {
                          textAlign: "center",
                          padding: 24,
                          color: th.t3,
                          fontSize: 11,
                        },
                      },
                      "No recordings yet \u2014 press Rec",
                    )
                  : recs.map(function (r) {
                      return h(
                        "div",
                        {
                          key: r.id,
                          style: {
                            padding: "8px 10px",
                            borderRadius: 7,
                            background: th.sg,
                            border: "1px solid " + th.bd,
                            marginBottom: 4,
                          },
                        },
                        h(
                          "div",
                          {
                            style: {
                              display: "flex",
                              justifyContent: "space-between",
                              alignItems: "center",
                            },
                          },
                          h(
                            "div",
                            {
                              style: {
                                display: "flex",
                                alignItems: "center",
                                gap: 5,
                              },
                            },
                            h(
                              "span",
                              { style: { fontSize: 11, fontWeight: 700 } },
                              r.ts,
                            ),
                            h(
                              "span",
                              {
                                style: {
                                  fontSize: 7,
                                  fontWeight: 700,
                                  padding: "1px 5px",
                                  borderRadius: 4,
                                  background: th.ac + "20",
                                  color: th.ac,
                                  textTransform: "uppercase",
                                },
                              },
                              r.type,
                            ),
                            h(
                              "span",
                              {
                                style: {
                                  fontSize: 7,
                                  padding: "1px 5px",
                                  borderRadius: 4,
                                  background: r.filt
                                    ? th.gd + "20"
                                    : th.bd + "40",
                                  color: r.filt ? th.gd : th.t3,
                                },
                              },
                              r.filt ? r.pn : "RAW",
                            ),
                          ),
                          h(
                            "div",
                            { style: { display: "flex", gap: 3 } },
                            h(
                              "button",
                              {
                                onClick: function () {
                                  var csv =
                                    "# Type:" +
                                    r.type +
                                    " Filter:" +
                                    (r.filt ? r.pn : "Raw") +
                                    "\nTime," +
                                    r.chs.join(",") +
                                    "\n";
                                  r.data.forEach(function (row) {
                                    var l = row.t.toFixed(3);
                                    r.chs.forEach(function (c) {
                                      l += "," + (row.v[c] || 0).toFixed(4);
                                    });
                                    csv += l + "\n";
                                  });
                                  var a = document.createElement("a");
                                  a.href = URL.createObjectURL(
                                    new Blob([csv], { type: "text/csv" }),
                                  );
                                  a.download =
                                    "neurovis_" + r.type + "_" + r.id + ".csv";
                                  a.click();
                                },
                                style: {
                                  padding: "2px 6px",
                                  borderRadius: 4,
                                  border: "1px solid " + th.bd,
                                  background: "transparent",
                                  color: th.ac,
                                  fontSize: 8,
                                  fontWeight: 700,
                                },
                              },
                              "CSV",
                            ),
                            h(
                              "button",
                              {
                                onClick: function () {
                                  setRecs(function (p) {
                                    return p.filter(function (x) {
                                      return x.id !== r.id;
                                    });
                                  });
                                },
                                style: {
                                  padding: "2px 6px",
                                  borderRadius: 4,
                                  border: "1px solid rgba(239,68,68,.3)",
                                  background: "transparent",
                                  color: "#ef4444",
                                  fontSize: 8,
                                },
                              },
                              "\u2715",
                            ),
                          ),
                        ),
                        h(
                          "div",
                          {
                            style: {
                              fontSize: 8,
                              color: th.t3,
                              marginTop: 3,
                            },
                          },
                          r.dur +
                            "s \u00B7 " +
                            r.smp +
                            " samples \u00B7 " +
                            r.chs.length +
                            " channels",
                        ),
                      );
                    }),
              ),
            // Close content area div (scrollable displays)
          ),
          // Close right display area div (bands/channels + content)
          // Close main layout div (sidebar + display)
          // Close top-level container div
        );
      }

      ReactDOM.render(h(App), document.getElementById("root"));
    </script>
    <script src="app.js?v=7"></script>
  </body>
</html>
