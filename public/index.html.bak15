                "python launcher.py",
              ),
              h("br"),
              "Supports Muse 2, Muse 3/Athena, OpenBCI Ganglion. Pair in System Bluetooth first.",
            ),
          );

        return h("div", { style: { position: "relative" } }, btn, dropdown);
      }

      // ── Scale Controls Component ──
      function ScaleControls(p) {
        var th = p.t;
        var viewId = p.viewId;
        var autoScale = p.autoScale || false;
        var yAxisRange = p.yAxisRange || 100;
        var setAutoScales = p.setAutoScales;
        var setYAxisRanges = p.setYAxisRanges;

        return h(
          "div",
          {
            style: {
              display: "flex",
              alignItems: "center",
              justifyContent: "flex-end",
              gap: 14,
              padding: "8px 12px",
              borderTop: "1px solid " + th.bd,
              background: th.c1,
              fontSize: 8,
            },
          },
          h(
            "div",
            { style: { display: "flex", alignItems: "center", gap: 6 } },
            h(
              "label",
              {
                style: {
                  fontFamily: M,
                  color: th.t2,
                  letterSpacing: "0.04em",
                  cursor: "pointer",
                  display: "flex",
                  alignItems: "center",
                  gap: 4,
                },
              },
              "AUTO",
              h("input", {
                type: "checkbox",
                checked: autoScale,
                style: { marginLeft: 4 },
                onChange: function (e) {
                  setAutoScales(function (prev) {
                    var next = Object.assign({}, prev);
                    next[viewId] = e.target.checked;
                    return next;
                  });
                  console.log(
                    "[Scale:" +
                      viewId +
                      "] AUTO: " +
                      (e.target.checked ? "ON" : "OFF"),
                  );
                },
              }),
            ),
          ),
          h(
            "div",
            { style: { display: "flex", alignItems: "center", gap: 6 } },
            h("input", {
              type: "range",
              min: 10,
              max: 200,
              value: yAxisRange,
              disabled: autoScale,
              style: {
                width: 100,
                opacity: autoScale ? 0.3 : 1,
                cursor: autoScale ? "not-allowed" : "pointer",
              },
              onChange: function (e) {
                var val = parseInt(e.target.value);
                setYAxisRanges(function (prev) {
                  var next = Object.assign({}, prev);
                  next[viewId] = val;
                  return next;
                });
                console.log("[Scale:" + viewId + "] Range: ±" + val);
              },
            }),
            h(
              "span",
              {
                style: {
                  fontFamily: M,
                  fontSize: 8,
                  color: th.t2,
                  minWidth: 50,
                },
              },
              "±" + yAxisRange,
            ),
          ),
        );
      }

      // ── Canvas Displays ──
      function PowerTL(p) {
        var ref = useRef(null),
          hist = useRef({}),
          autoMin = useRef(0),
          autoMax = useRef(100);
        var th = p.t,
          d = DEVS[p.dev] || DEVS["muse_s"],
          isDk = th === TH.dark;
        if (!d || !d.eeg) return null;
        var els = d.eeg.filter(function (e) {
          return p.chs.indexOf(e.id) >= 0;
        });
        useEffect(
          function () {
            var c = ref.current;
            if (!c) return;
            var ctx = c.getContext("2d"),
              W = c.width,
              H = c.height;
            ctx.clearRect(0, 0, W, H);
            var mW = 120,
              tlX = mW + 14,
              tlW = W - tlX - 14,
              rH = H / Math.max(els.length, 1);

            // Calculate AUTO scale bounds if enabled
            var yMin = 0,
              yMax = 100;
            if (p.autoScale) {
              var allVals = [];
              els.forEach(function (el) {
                p.bands.forEach(function (bn) {
                  var bIdx = BANDS.findIndex(function (b) {
                    return b.n === bn;
                  });
                  if (bIdx < 0) return;
                  if (hist.current[el.id] && hist.current[el.id][bn]) {
                    allVals = allVals.concat(hist.current[el.id][bn]);
                  }
                });
              });
              if (allVals.length > 0) {
                var dataMin = Math.min.apply(null, allVals);
                var dataMax = Math.max.apply(null, allVals);
                // Smooth transition for AUTO scale
                autoMin.current = autoMin.current * 0.85 + dataMin * 0.15;
                autoMax.current = autoMax.current * 0.85 + dataMax * 0.15;
                var pad = (autoMax.current - autoMin.current) * 0.1;
                yMin = autoMin.current - pad;
                yMax = autoMax.current + pad;
              }
            } else {
              yMin = -p.yAxisRange;
              yMax = p.yAxisRange;
            }

            els.forEach(function (el, ei) {
              var yT = ei * rH,
                yM = yT + rH / 2;
              if (ei > 0) {
                ctx.strokeStyle = th.bd;
                ctx.lineWidth = 0.5;
                ctx.beginPath();
                ctx.moveTo(0, yT);
                ctx.lineTo(W, yT);
                ctx.stroke();
              }
              ctx.fillStyle = th.t2;
              ctx.font = "bold 9px " + M;
              ctx.fillText(el.id, 4, yM + 3);
              p.bands.forEach(function (bn, bi2) {
                var bIdx = BANDS.findIndex(function (b) {
                  return b.n === bn;
                });
                if (bIdx < 0) return;
                var b = BANDS[bIdx],
                  col = isDk ? b.d : b.c,
                  pw = bpow(p.time, el.id, bIdx, p.pid, p.fp);
                var bH = Math.max(2, (rH - 4) / p.bands.length - 1),
                  by = yT + 2 + bi2 * (bH + 1);
                ctx.fillStyle = th.bd + "60";
                ctx.fillRect(30, by, mW - 36, bH);
                ctx.fillStyle = col;
                ctx.globalAlpha = 0.8;
                ctx.fillRect(30, by, pw * (mW - 36), bH);
                ctx.globalAlpha = 1;
                if (!hist.current[el.id]) hist.current[el.id] = {};
                if (!hist.current[el.id][bn]) hist.current[el.id][bn] = [];
                hist.current[el.id][bn].push(
                  eeg(p.time, el.id, bIdx, p.pid, p.fp),
                );
                if (hist.current[el.id][bn].length > 200)
                  hist.current[el.id][bn].shift();
                var data = hist.current[el.id][bn];
                ctx.strokeStyle = col;
                ctx.lineWidth = 1;
                ctx.globalAlpha = 0.7;
                ctx.beginPath();
                data.forEach(function (v, i) {
                  var x = tlX + (i / 199) * tlW;
                  // Map value from [yMin, yMax] to canvas Y position
                  var normalized = (v - yMin) / (yMax - yMin);
                  var y = yM + rH * 0.35 - normalized * rH * 0.7;
                  i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
                });
                ctx.stroke();
                ctx.globalAlpha = 1;
              });
              var q = qual(el.id, p.time);
              ctx.fillStyle = qc(q, th);
              ctx.beginPath();
              ctx.arc(W - 6, yM, 3, 0, Math.PI * 2);
              ctx.fill();
            });
          },
          [Math.floor(p.time * 6)],
        );
        var ch = Math.max(250, els.length * 50);
        return h("canvas", {
          ref: ref,
          width: 1000,
          height: ch,
          style: {
            width: "100%",
            height: Math.max(200, els.length * 40),
            borderRadius: 8,
            background: th.sg,
          },
        });
      }

      function TopoSVG(p) {
        var th = p.t,
          d = DEVS[p.dev],
          b = BANDS[p.bi],
          isDk = th === TH.dark,
          col = isDk ? b.d : b.c,
          skin = p.skin;
        var els = d.eeg;
        var defs = els.map(function (el) {
          var pw = bpow(p.time, el.id, p.bi, p.pid, p.fp);
          return h(
            "radialGradient",
            { key: el.id, id: "t" + el.id },
            h("stop", { offset: "0%", stopColor: col, stopOpacity: pw * 0.85 }),
            h("stop", {
              offset: "40%",
              stopColor: col,
              stopOpacity: pw * 0.35,
            }),
            h("stop", { offset: "100%", stopColor: col, stopOpacity: 0 }),
          );
        });
        var glowR = d.ch <= 4 ? 60 : 38;
        var glows = els.map(function (el) {
          var cx = (el.x / 100) * 300 + 20,
            cy = (el.y / 100) * 340 + 20;
          return h("circle", {
            key: "g" + el.id,
            cx: cx,
            cy: cy,
            r: glowR,
            fill: "url(#t" + el.id + ")",
          });
        });
        var dots = els.map(function (el) {
          var pw = bpow(p.time, el.id, p.bi, p.pid, p.fp),
            q = qual(el.id, p.time),
            cx = (el.x / 100) * 300 + 20,
            cy = (el.y / 100) * 340 + 20;
          return h(
            "g",
            { key: el.id },
            h("circle", {
              cx: cx,
              cy: cy,
              r: 6 + pw * 5,
              fill: col,
              opacity: 0.85,
            }),
            h("circle", {
              cx: cx,
              cy: cy,
              r: 12,
              fill: "none",
              stroke: qc(q, th),
              strokeWidth: 1.5,
              opacity: 0.6,
              strokeDasharray: q * 75 + " 75",
              transform: "rotate(-90 " + cx + " " + cy + ")",
            }),
            h(
              "text",
              {
                x: cx,
                y: cy - 16,
                textAnchor: "middle",
                fontSize: 9,
                fill: th.tx,
                fontWeight: 700,
                fontFamily: M,
              },
              el.id,
            ),
          );
        });
        return h(
          "svg",
          { viewBox: "0 0 340 400", style: { width: "100%", maxHeight: 340 } },
          h("defs", null, defs),
          // Head outline
          h("ellipse", {
            cx: 170,
            cy: 195,
            rx: 150,
            ry: 172,
            fill: skin.skull,
            stroke: th.bd,
            strokeWidth: 1.5,
          }),
          // Brain surface
          h("ellipse", {
            cx: 170,
            cy: 188,
            rx: 134,
            ry: 155,
            fill: skin.brain,
          }),
          // Central fissure
          h("path", {
            d: "M170 32Q168 110 172 188Q168 265 170 340",
            fill: "none",
            stroke: skin.sulci,
            strokeWidth: 2,
            opacity: 0.4,
          }),
          // Lateral fissure hints
          h("path", {
            d: "M60 180Q100 160 140 175",
            fill: "none",
            stroke: skin.sulci,
            strokeWidth: 1.2,
            opacity: 0.3,
          }),
          h("path", {
            d: "M280 180Q240 160 200 175",
            fill: "none",
            stroke: skin.sulci,
            strokeWidth: 1.2,
            opacity: 0.3,
          }),
          // Nose
          h("path", {
            d: "M163 20L170 4L177 20",
            fill: "none",
            stroke: th.t2,
            strokeWidth: 2,
          }),
          // Ears
          h("ellipse", {
            cx: 16,
            cy: 195,
            rx: 8,
            ry: 18,
            fill: skin.skull,
            stroke: th.bd,
            strokeWidth: 1,
          }),
          h("ellipse", {
            cx: 324,
            cy: 195,
            rx: 8,
            ry: 18,
            fill: skin.skull,
            stroke: th.bd,
            strokeWidth: 1,
          }),
          // Anatomical labels
          h(
            "text",
            { x: 170, y: 14, textAnchor: "middle", fontSize: 8, fill: th.t3 },
            "Nasion",
          ),
          h(
            "text",
            { x: 170, y: 395, textAnchor: "middle", fontSize: 8, fill: th.t3 },
            "Inion",
          ),
          h(
            "text",
            { x: 6, y: 198, textAnchor: "middle", fontSize: 8, fill: th.t3 },
            "L",
          ),
          h(
            "text",
            { x: 334, y: 198, textAnchor: "middle", fontSize: 8, fill: th.t3 },
            "R",
          ),
          // Activity glows + electrode dots
          glows,
          dots,
          // SCIENTIFIC COLORBAR (power scale)
          h(
            "g",
            { transform: "translate(260, 80)" },
            // Background
            h("rect", {
              x: 0,
              y: 0,
              width: 60,
              height: 200,
              fill: th.sg,
              stroke: th.bd,
              strokeWidth: 1,
              rx: 4,
            }),
            // Title
            h(
              "text",
              {
                x: 30,
                y: 15,
                textAnchor: "middle",
                fontSize: 9,
                fill: th.t2,
                fontWeight: "bold",
                fontFamily: M,
              },
              "Power",
            ),
            // Gradient bar
            h(
              "defs",
              null,
              h(
                "linearGradient",
                { id: "powerGrad", x1: "0%", y1: "0%", x2: "0%", y2: "100%" },
                h("stop", { offset: "0%", stopColor: col, stopOpacity: 0.85 }),
                h("stop", { offset: "50%", stopColor: col, stopOpacity: 0.5 }),
                h("stop", { offset: "100%", stopColor: col, stopOpacity: 0.1 }),
              ),
            ),
            h("rect", {
              x: 10,
              y: 25,
              width: 20,
              height: 150,
              fill: "url(#powerGrad)",
              stroke: th.bd,
              strokeWidth: 1,
            }),
            // Scale labels
            h(
              "text",
              { x: 35, y: 30, fontSize: 8, fill: th.t3, fontFamily: M },
              "High",
            ),
            h(
              "text",
              { x: 35, y: 105, fontSize: 8, fill: th.t3, fontFamily: M },
              "Med",
            ),
            h(
              "text",
              { x: 35, y: 175, fontSize: 8, fill: th.t3, fontFamily: M },
              "Low",
            ),
            // Band frequency range
            h(
              "text",
              {
                x: 30,
                y: 195,
                textAnchor: "middle",
                fontSize: 8,
                fill: th.t3,
                fontFamily: M,
              },
              b.r + " Hz",
            ),
          ),
          // 10-20 system reference note
          h(
            "text",
            {
              x: 170,
              y: 385,
              textAnchor: "middle",
              fontSize: 7,
              fill: th.t3,
              fontStyle: "italic",
            },
            "Modified 10-20 electrode placement system",
          ),
        );
      }

      function ConnectView(p) {
        var th = p.t,
          d = DEVS[p.dev];
        // Use actual device electrode positions
        var els = d.eeg;
        var svgEls = els.map(function (el) {
          var q = qual(el.id, p.time),
            cx = (el.x / 100) * 240 + 20,
            cy = (el.y / 100) * 260 + 20,
            c = qc(q, th);
          return h(
            "g",
            { key: el.id },
            h("circle", {
              cx: cx,
              cy: cy,
              r: 13,
              fill: "none",
              stroke: th.bd,
              strokeWidth: 1.5,
            }),
            h("circle", {
              cx: cx,
              cy: cy,
              r: 13,
              fill: "none",
              stroke: c,
              strokeWidth: 2.5,
              strokeDasharray: q * 82 + " 82",
              strokeLinecap: "round",
              transform: "rotate(-90 " + cx + " " + cy + ")",
            }),
            h("circle", {
              cx: cx,
              cy: cy,
              r: 5,
              fill: c,
              opacity: 0.6 + q * 0.4,
            }),
            h(
              "text",
              {
                x: cx,
                y: cy - 17,
                textAnchor: "middle",
                fontSize: 8,
                fill: th.t2,
                fontFamily: M,
                fontWeight: 600,
              },
              el.id,
            ),
          );
        });
        var grid = els.map(function (el) {
          var q = qual(el.id, p.time),
            c = qc(q, th);
          return h(
            "div",
            {
              key: el.id,
              style: {
                padding: 8,
                borderRadius: 6,
                background: th.sg,
                border: "1px solid " + th.bd,
                textAlign: "center",
              },
            },
            h(
              "div",
              {
                style: {
                  fontSize: 10,
                  fontWeight: 700,
                  fontFamily: M,
                  color: th.t2,
                },
              },
              el.id,
            ),
            h(
              "div",
              {
                style: {
                  width: "100%",
                  height: 4,
                  borderRadius: 2,
                  background: th.bd,
                  margin: "4px 0",
                  overflow: "hidden",
                },
              },
              h("div", {
                style: {
                  width: q * 100 + "%",
                  height: "100%",
                  background: c,
                  borderRadius: 2,
                },
              }),
            ),
            h(
              "div",
              { style: { fontSize: 9, color: c, fontWeight: 700 } },
              q > 0.8
                ? "Excellent"
                : q > 0.6
                  ? "Good"
                  : q > 0.35
                    ? "Fair"
                    : "Poor",
            ),
          );
        });
        return h(
          "div",
          { style: { maxWidth: "70%", margin: "0 auto" } },
          h(
            "div",
            { style: { fontSize: 9, color: th.t3, marginBottom: 8 } },
            d.name + " \u2014 " + d.ch + " EEG channels at " + d.hz + " Hz",
          ),
          h(
            "div",
            {
              style: {
                display: "grid",
                gridTemplateColumns: "280px 1fr",
                gap: 16,
                alignItems: "start",
              },
            },
            h(
              "svg",
              {
                viewBox: "0 0 280 300",
                style: { width: "100%", height: "auto" },
              },
              h("ellipse", {
                cx: 140,
                cy: 145,
                rx: 115,
                ry: 130,
                fill: "none",
                stroke: th.bd,
                strokeWidth: 1.5,
                strokeDasharray: "4 3",
              }),
              h("path", {
                d: "M133 13L140 0L147 13",
                fill: "none",
                stroke: th.t3,
                strokeWidth: 1.5,
              }),
              h(
                "text",
                {
                  x: 140,
                  y: 290,
                  textAnchor: "middle",
                  fontSize: 8,
                  fill: th.t3,
                },
                "Inion",
              ),
              h(
                "text",
                {
                  x: 140,
                  y: 8,
                  textAnchor: "middle",
                  fontSize: 8,
                  fill: th.t3,
                },
                "Nasion",
              ),
              h(
                "text",
                {
                  x: 8,
                  y: 148,
                  textAnchor: "middle",
                  fontSize: 8,
                  fill: th.t3,
                },
                "L",
              ),
              h(
                "text",
                {
                  x: 272,
                  y: 148,
                  textAnchor: "middle",
                  fontSize: 8,
                  fill: th.t3,
                },
                "R",
              ),
              svgEls,
            ),
            h(
              "div",
              null,
              h(
                "div",
                {
                  style: {
                    fontSize: 8,
                    color: th.t3,
                    fontWeight: 700,
                    textTransform: "uppercase",
                    letterSpacing: ".05em",
                    marginBottom: 6,
                  },
                },
                "Sensor Quality",
              ),
              h(
                "div",
                {
                  style: {
                    display: "grid",
                    gridTemplateColumns:
                      "repeat(" + Math.min(els.length, 2) + ",1fr)",
                    gap: 4,
                    marginBottom: 12,
                  },
                },
                grid,
              ),
              h(
                "div",
                {
                  style: {
                    fontSize: 8,
                    color: th.t3,
                    fontWeight: 700,
                    textTransform: "uppercase",
                    letterSpacing: ".05em",
                    marginBottom: 6,
                  },
                },
                "Band Signal Levels",
              ),
              h(
                "div",
                {
                  style: {
                    display: "grid",
                    gridTemplateColumns: "50px repeat(5,1fr)",
                    gap: 2,
                  },
                },
                [h("div")]
                  .concat(
                    BANDS.map(function (b) {
                      return h(
                        "div",
                        {
                          key: b.n,
                          style: {
                            fontSize: 7,
                            textAlign: "center",
                            color: th.t3,
                            fontWeight: 700,
                          },
                        },
                        b.n,
                      );
                    }),
                  )
                  .concat(
                    els.map(function (el) {
                      return h(
                        Fragment,
                        { key: el.id },
                        h(
                          "div",
                          {
                            style: {
                              fontSize: 9,
                              fontFamily: M,
                              color: th.t2,
                              display: "flex",
                              alignItems: "center",
                            },
                          },
                          el.id,
                        ),
                        BANDS.map(function (b, bi) {
                          var lv =
                            bpowSmooth(p.time, el.id, bi, "none", {}) *
                            qual(el.id, p.time);
                          var c2 = lv > 0.4 ? th.gd : lv > 0.2 ? th.wr : th.rd;
                          return h(
                            "div",
                            {
                              key: b.n,
                              style: {
                                height: 12,
                                borderRadius: 3,
                                background: th.bd + "60",
                                overflow: "hidden",
                              },
                            },
                            h("div", {
                              style: {
                                height: "100%",
                                width: lv * 100 + "%",
                                background: c2,
                                borderRadius: 3,
                              },
                            }),
                          );
                        }),
                      );
                    }),
                  ),
              ),
            ),
          ),
        );
      }

      function NeuroView(p) {
        var th = p.t,
          d = DEVS[p.dev],
          isDk = th === TH.dark;
        var ratios = [
          { n: "Focus", a: 3, b: 1, desc: "Beta/Theta" },
          { n: "Relax", a: 2, b: 3, desc: "Alpha/Beta" },
          { n: "Meditate", a: 1, b: 2, desc: "Theta/Alpha" },
          { n: "Drowsy", a: 0, b: 2, desc: "Delta/Alpha" },
        ];
        // Smoothed neuro values
        var smoothed = useRef({ Focus: 0, Relax: 0, Meditate: 0, Drowsy: 0 });
        return h(
          "div",
          {
            style: { display: "grid", gridTemplateColumns: "1fr 1fr", gap: 8 },
          },
          ratios.map(function (r) {
            var tot = 0;
            d.eeg.forEach(function (el) {
              tot +=
                bpow(p.time, el.id, r.a, p.pid, p.fp) /
                (bpow(p.time, el.id, r.b, p.pid, p.fp) + 0.01);
            });
            var raw = Math.min(tot / d.eeg.length / 2, 1);
            smoothed.current[r.n] = smoothed.current[r.n] * 0.96 + raw * 0.04;
            var norm = smoothed.current[r.n];
            var col = isDk ? BANDS[r.a].d : BANDS[r.a].c;
            return h(
              "div",
              {
                key: r.n,
                style: {
                  padding: 12,
                  borderRadius: 8,
                  background: th.sg,
                  border: "1px solid " + th.bd,
                  textAlign: "center",
                },
              },
              h(
                "div",
                {
                  style: {
                    fontSize: 9,
                    fontWeight: 700,
                    color: th.t2,
                    textTransform: "uppercase",
                    marginBottom: 2,
                  },
                },
                r.n,
              ),
              h(
                "div",
                { style: { fontSize: 7, color: th.t3, marginBottom: 4 } },
                r.desc,
              ),
              h(
                "div",
                {
                  style: {
                    position: "relative",
                    width: 70,
                    height: 70,
                    margin: "0 auto",
                  },
                },
                h(
                  "svg",
                  { viewBox: "0 0 70 70", style: { width: 70, height: 70 } },
                  h("circle", {
                    cx: 35,
                    cy: 35,
                    r: 28,
                    fill: "none",
                    stroke: th.bd,
                    strokeWidth: 5,
                  }),
                  h("circle", {
                    cx: 35,
                    cy: 35,
                    r: 28,
                    fill: "none",
                    stroke: col,
                    strokeWidth: 5,
                    strokeDasharray: norm * 176 + " 176",
                    strokeLinecap: "round",
                    transform: "rotate(-90 35 35)",
                  }),
                ),
                h(
                  "div",
                  {
                    style: {
                      position: "absolute",
                      inset: 0,
                      display: "flex",
                      alignItems: "center",
                      justifyContent: "center",
                      fontSize: 16,
                      fontWeight: 700,
                      color: col,
                      fontFamily: M,
                    },
                  },
                  Math.round(norm * 100),
                ),
              ),
            );
          }),
        );
      }

      // ── Traces View (NeurOSC-style raw EEG waveforms) ──
      // ══════════════════════════════════════════════════════════════════
      // SCIENTIFIC MULTI-CHANNEL EEG DISPLAY
      // Professional research-grade oscilloscope-style viewer
      // ══════════════════════════════════════════════════════════════════
      function TracesView(p) {
        var th = p.t,
          d = DEVS[p.dev],
          isDk = th === TH.dark;
        var ref = useRef(null);
        var dataRef = useRef({ channels: [], timestamps: [], samples: [] });
        var autoMin = useRef([]),
          autoMax = useRef([]);

        // Poll /api/timeseries endpoint
        useEffect(
          function () {
            var timer = setInterval(function () {
              var window = p.timeWindow || 4;
              fetch("/api/timeseries?window=" + window + "&maxPoints=1024")
                .then(function (r) {
                  return r.json();
                })
                .then(function (data) {
                  if (data.samples && data.samples.length > 0) {
                    dataRef.current = data;
                  }
                })
                .catch(function () {});
            }, 100); // Poll at 10 Hz
            return function () {
              clearInterval(timer);
            };
          },
          [p.timeWindow],
        );

        // SCIENTIFIC RENDERING ENGINE
        useEffect(
          function () {
            var c = ref.current;
            if (!c) return;
            var ctx = c.getContext("2d"),
              W = c.width,
              H = c.height;

            // Clear with proper background
            ctx.fillStyle = isDk ? "#0a0e1a" : "#ffffff";
            ctx.fillRect(0, 0, W, H);

            var data = dataRef.current;
            if (
              !data.timestamps ||
              data.timestamps.length === 0 ||
              !data.samples ||
              data.samples.length === 0
            )
              return;

            // LAYOUT CONFIGURATION (scientific standard)
            var viewMode = p.viewMode || "quad"; // single, dual, quad
            var activeChs = p.activeChannels || [0, 1, 2, 3];
            var numChannels =
              viewMode === "single" ? 1 : viewMode === "dual" ? 2 : 4;
            var displayChannels = activeChs.slice(0, numChannels);

            var topMargin = 80;
            var bottomMargin = 60;
            var leftMargin = 100;
            var rightMargin = 40;
            var channelSpacing = 20;

            var plotH = H - topMargin - bottomMargin;
            var plotW = W - leftMargin - rightMargin;
            var channelH =
              (plotH - (numChannels - 1) * channelSpacing) / numChannels;

            // TITLE BAR
            ctx.fillStyle = th.t1;
            ctx.font = "bold 20px " + M;
            ctx.fillText(
              "EEG Traces (" + viewMode.toUpperCase() + " View)",
              leftMargin,
              35,
            );
            ctx.fillStyle = th.t3;
            ctx.font = "12px " + M;
            ctx.fillText(
              data.sampleRate + " Hz | " + displayChannels.length + " channels",
              leftMargin,
              55,
            );
            // DEVICE & SCALING INFO (top right)
            ctx.fillStyle = th.ac;
            ctx.font = "bold 11px " + M;
            ctx.textAlign = "right";
            ctx.fillText(
              (p.deviceModel || "Muse 2") +
                " | " +
                (p.inputFormat || "AUTO").toUpperCase(),
              W - rightMargin,
              35,
            );
            ctx.fillStyle = th.t3;
            ctx.font = "10px " + M;
            ctx.fillText(
              "Voltage scaling: " +
                (useAutoScale ? "AUTO" : "±" + ampRange + "μV"),
              W - rightMargin,
              50,
            );
            ctx.textAlign = "left";

            // AMPLITUDE SCALING (per-channel or global)
            var ampRange = p.ampRange || 100; // µV
            var useAutoScale = p.ampAuto !== false;

            // Calculate auto-scale per channel if enabled
            if (useAutoScale) {
              if (autoMin.current.length === 0) {
                autoMin.current = new Array(4).fill(-100);
                autoMax.current = new Array(4).fill(100);
              }
            }

            // DRAW EACH CHANNEL (scientific oscilloscope style)
            for (var chIdx = 0; chIdx < displayChannels.length; chIdx++) {
              var ch = displayChannels[chIdx];
              var chY = topMargin + chIdx * (channelH + channelSpacing);
              var samples = data.samples[ch] || [];
              if (samples.length === 0) continue;

              // Calculate amplitude range for this channel
              var yMin = -ampRange;
              var yMax = ampRange;
              if (useAutoScale && samples.length > 0) {
                var min = Math.min.apply(null, samples);
                var max = Math.max.apply(null, samples);
                autoMin.current[ch] = autoMin.current[ch] * 0.9 + min * 0.1;
                autoMax.current[ch] = autoMax.current[ch] * 0.9 + max * 0.1;
                var absMax = Math.max(
                  Math.abs(autoMin.current[ch]),
                  Math.abs(autoMax.current[ch]),
                );
                yMin = -absMax * 1.1;
                yMax = absMax * 1.1;
              }

              // CHANNEL BACKGROUND PANEL
              ctx.fillStyle = isDk ? "#0f1419" : "#f8f9fa";
              ctx.fillRect(leftMargin, chY, plotW, channelH);

              // GRID (scientific style - always enabled for research)
              ctx.strokeStyle = isDk ? "#1a1f2e80" : "#e5e7eb80";
              ctx.lineWidth = 1;
              // Horizontal grid (amplitude) - major gridlines
              var gridSteps = 8;
              for (var g = 0; g <= gridSteps; g++) {
                var yGrid = chY + (g / gridSteps) * channelH;
                ctx.globalAlpha = g % 2 === 0 ? 1.0 : 0.4; // Major/minor lines
                ctx.beginPath();
                ctx.moveTo(leftMargin, yGrid);
                ctx.lineTo(leftMargin + plotW, yGrid);
                ctx.stroke();
              }
              ctx.globalAlpha = 1.0;
              // Vertical grid (time) - major gridlines every 0.5s
              var timeSteps = (p.timeWindow || 4) * 2; // every 0.5s
              for (var t = 0; t <= timeSteps; t++) {
                var xGrid = leftMargin + (t / timeSteps) * plotW;
                ctx.globalAlpha = t % 2 === 0 ? 1.0 : 0.3; // Major/minor lines
                ctx.beginPath();
                ctx.moveTo(xGrid, chY);
                ctx.lineTo(xGrid, chY + channelH);
                ctx.stroke();
              }
              ctx.globalAlpha = 1.0;

              // ZERO BASELINE (prominent)
              var zeroY = chY + channelH / 2;
              ctx.strokeStyle = isDk ? "#374151" : "#9ca3af";
              ctx.lineWidth = 2;
              ctx.beginPath();
              ctx.moveTo(leftMargin, zeroY);
              ctx.lineTo(leftMargin + plotW, zeroY);
              ctx.stroke();

              // CHANNEL LABEL (left margin)
              var chName = data.channels[ch] || "CH" + (ch + 1);
              ctx.save();
              ctx.translate(30, chY + channelH / 2);
              ctx.fillStyle = BANDS[ch % 5].c;
              ctx.font = "bold 18px " + M;
              ctx.textAlign = "center";
              ctx.fillText(chName, 0, 6);
              ctx.restore();

              // AMPLITUDE SCALE (left axis) - scientific style with intermediate values
              ctx.fillStyle = th.t3;
              ctx.font = "10px " + M;
              ctx.textAlign = "right";
              // Top (max)
              ctx.fillText("+" + yMax.toFixed(1), leftMargin - 8, chY + 12);
              // 3/4 mark
              ctx.fillText(
                "+" + (yMax * 0.5).toFixed(1),
                leftMargin - 8,
                chY + channelH * 0.25 + 4,
              );
              // Zero
              ctx.font = "bold 11px " + M;
              ctx.fillText("0", leftMargin - 8, zeroY + 4);
              ctx.font = "10px " + M;
              // 1/4 mark
              ctx.fillText(
                (yMin * 0.5).toFixed(1),
                leftMargin - 8,
                chY + channelH * 0.75 + 4,
              );
              // Bottom (min)
              ctx.fillText(yMin.toFixed(1), leftMargin - 8, chY + channelH - 4);
              // Unit label (rotated on left side)
              ctx.save();
              ctx.translate(leftMargin - 30, chY + channelH / 2);
              ctx.rotate(-Math.PI / 2);
              ctx.font = "bold 10px " + M;
              ctx.textAlign = "center";
              ctx.fillText("µV", 0, 0);
              ctx.restore();

              // DRAW WAVEFORM
              var color = BANDS[ch % 5].c;
              ctx.strokeStyle = color;
              ctx.lineWidth = 2;
              ctx.beginPath();

              for (var i = 0; i < samples.length; i++) {
                var x = leftMargin + (i / (samples.length - 1)) * plotW;
                var val = samples[i];
                // Map from µV to canvas Y
                var normalizedVal = (val - yMin) / (yMax - yMin);
                var y = chY + channelH - normalizedVal * channelH;
                if (i === 0) {
                  ctx.moveTo(x, y);
                } else {
                  ctx.lineTo(x, y);
                }
              }
              ctx.stroke();

              // BORDER
              ctx.strokeStyle = th.bd;
              ctx.lineWidth = 1;
              ctx.strokeRect(leftMargin, chY, plotW, channelH);
            }

            // TIME AXIS (bottom, shared)
            ctx.fillStyle = th.t2;
            ctx.font = "bold 12px " + M;
            ctx.textAlign = "center";
            var duration = p.timeWindow || 4;
            for (var t = 0; t <= duration; t++) {
              var x = leftMargin + (t / duration) * plotW;
              ctx.fillText(t + "s", x, H - 25);
            }
            ctx.fillText("Time (seconds)", leftMargin + plotW / 2, H - 8);
          },
          [p.time, p.autoScale, p.yAxisRange],
        );

        return h("canvas", {
          ref: ref,
          width: 1600,
          height: 800,
          style: {
            width: "800px",
            height: "400px",
            maxWidth: "50%",
            background: isDk ? th.bg : "#fff",
            borderRadius: 4,
            display: "block",
            margin: "0 auto",
          },
        });
      }

      // ── Mental State View (NeurOSC-style engagement/meditation/focus) ──
      function MentalStateView(p) {
        var th = p.t,
          d = DEVS[p.dev],
          isDk = th === TH.dark;
        var ref = useRef(null);
        var stateRef = useRef({
          engagement: 0,
          meditation: 0,
          focus: 0,
          state: "Calm",
        });

        // Poll /api/bands and calculate mental state
        useEffect(function () {
          var timer = setInterval(function () {
            fetch("/api/bands")
              .then(function (r) {
                return r.json();
              })
              .then(function (data) {
                if (!data.values || data.values.length === 0) return;

                // Average across all channels
                var avgBands = {
                  delta: 0,
                  theta: 0,
                  alpha: 0,
                  beta: 0,
                  gamma: 0,
                };
                var numChannels = data.values.length;

                data.values.forEach(function (channelBands) {
                  if (channelBands.length >= 5) {
                    avgBands.delta += channelBands[0];
                    avgBands.theta += channelBands[1];
                    avgBands.alpha += channelBands[2];
                    avgBands.beta += channelBands[3];
                    avgBands.gamma += channelBands[4];
                  }
                });

                avgBands.delta /= numChannels;
                avgBands.theta /= numChannels;
                avgBands.alpha /= numChannels;
                avgBands.beta /= numChannels;
                avgBands.gamma /= numChannels;

                var totalPower =
                  avgBands.delta +
                  avgBands.theta +
                  avgBands.alpha +
                  avgBands.beta +
                  avgBands.gamma;

                // Calculate metrics (NeurOSC formulas)
                var engagement =
                  avgBands.beta / (avgBands.alpha + avgBands.theta + 0.001);
                engagement = Math.max(0, Math.min(5, engagement)); // Clamp 0-5

                var meditation =
                  totalPower > 0
                    ? (avgBands.alpha + avgBands.theta) / totalPower
                    : 0;
                var focus = totalPower > 0 ? avgBands.beta / totalPower : 0;

                // State classification
                var state = "Calm";
                if (avgBands.delta / totalPower > 0.4) state = "Drowsy";
                else if (
                  avgBands.alpha / totalPower > 0.35 &&
                  avgBands.beta / totalPower < 0.25
                )
                  state = "Meditative";
                else if (avgBands.beta / totalPower > 0.3) state = "Focused";

                stateRef.current = {
                  engagement: engagement,
                  meditation: meditation,
                  focus: focus,
                  state: state,
                };
              })
              .catch(function () {});
          }, 100); // Poll at 10 Hz
          return function () {
            clearInterval(timer);
          };
        }, []);

        // Render canvas
        useEffect(
          function () {
            var c = ref.current;
            if (!c) return;
            var ctx = c.getContext("2d"),
              W = c.width,
              H = c.height;
            ctx.clearRect(0, 0, W, H);

            var state = stateRef.current;

            // Title
            ctx.fillStyle = th.t1;
            ctx.font = "bold 16px " + M;
            ctx.fillText("Mental State Indicators", 20, 30);

            // State label with emoji
            var stateEmoji = {
              Calm: "😌",
              Meditative: "🧘",
              Focused: "🎯",
              Drowsy: "😴",
            };
            var stateColor = {
              Calm: "#00e5a0",
              Meditative: "#a855f7",
              Focused: "#3b82f6",
              Drowsy: "#f59e0b",
            };

            // Title
            ctx.fillStyle = th.t1;
            ctx.font = "bold 24px " + M;
            ctx.fillText("Mental State Indicators", 80, 40);

            // Current state badge
            ctx.fillStyle = stateColor[state.state] || th.t2;
            ctx.font = "bold 20px " + M;
            ctx.fillText(
              stateEmoji[state.state] + " " + state.state,
              W - 180,
              40,
            );

            // VERTICAL bars for 3 metrics
            var metrics = [
              {
                label: "Engagement",
                value: state.engagement / 5,
                color: "#3b82f6",
                desc: "Beta/(Alpha+Theta)",
              },
              {
                label: "Meditation",
                value: state.meditation,
                color: "#a855f7",
                desc: "(Alpha+Theta)/Total",
              },
              {
                label: "Focus",
                value: state.focus,
                color: "#00e5a0",
                desc: "Beta/Total",
              },
            ];

            var topMargin = 100;
            var bottomMargin = 120;
            var leftMargin = 100;
            var rightMargin = 60;
            var plotH = H - topMargin - bottomMargin;
            var plotW = W - leftMargin - rightMargin;
            var barW = plotW / 3;

            metrics.forEach(function (metric, idx) {
              var barX = leftMargin + idx * barW;

              // Bar background
              ctx.fillStyle = th.bd + "20";
              ctx.fillRect(barX + 20, topMargin, barW - 40, plotH);

              // Bar fill (VERTICAL, grows upward)
              var barH = plotH * Math.min(1, metric.value);
              var barY = topMargin + plotH - barH;

              // Gradient fill (vertical)
              var gradient = ctx.createLinearGradient(
                barX,
                topMargin + plotH,
                barX,
                barY,
              );
              gradient.addColorStop(0, metric.color + "40");
              gradient.addColorStop(1, metric.color);
              ctx.fillStyle = gradient;
              ctx.fillRect(barX + 20, barY, barW - 40, barH);

              // Border
              ctx.strokeStyle = metric.color;
              ctx.lineWidth = 3;
              ctx.strokeRect(barX + 20, barY, barW - 40, barH);

              // Value text (on or above bar)
              ctx.fillStyle = isDk ? "#fff" : "#000";
              ctx.font = "bold 16px " + M;
              ctx.textAlign = "center";
              var valueText = (metric.value * 100).toFixed(0) + "%";
              if (metric.label === "Engagement") {
                valueText = state.engagement.toFixed(1);
              }
              if (barH > 40) {
                ctx.fillText(valueText, barX + barW / 2, barY + barH / 2);
              } else {
                ctx.fillText(valueText, barX + barW / 2, barY - 10);
              }

              // Label (bottom)
              ctx.fillStyle = metric.color;
              ctx.font = "bold 18px " + M;
              ctx.fillText(metric.label, barX + barW / 2, H - 70);

              // Description (smaller, below label)
              ctx.fillStyle = th.t3;
              ctx.font = "11px " + M;
              ctx.fillText(metric.desc, barX + barW / 2, H - 50);
            });

            // Y-axis scale
            ctx.fillStyle = th.t3;
            ctx.font = "12px " + M;
            ctx.textAlign = "right";
            ctx.fillText("100%", leftMargin - 10, topMargin + 4);
            ctx.fillText("50%", leftMargin - 10, topMargin + plotH / 2 + 4);
            ctx.fillText("0%", leftMargin - 10, topMargin + plotH + 4);

            // Info text (bottom)
            ctx.fillStyle = th.t3;
            ctx.font = "10px " + M;
            ctx.textAlign = "center";
            ctx.fillText(
              "Classified by band power ratios: Drowsy (high delta), Meditative (high alpha+theta), Focused (high beta), Calm (balanced)",
              W / 2,
              H - 55,
            );
            ctx.fillText(
              "• Drowsy: High delta (>40%)   • Meditative: High alpha+theta, low beta",
              30,
              H - 40,
            );
            ctx.fillText(
              "• Focused: High beta (>30%)   • Calm: Balanced state",
              30,
              H - 25,
            );
          },
          [p.time],
        );

        return h("canvas", {
          ref: ref,
          width: 1200,
          height: 600,
          style: {
            width: "600px",
            height: "300px",
            maxWidth: "50%",
            background: isDk ? th.bg : "#fff",
            borderRadius: 4,
            display: "block",
            margin: "0 auto",
          },
        });
      }

      // ══════════════════════════════════════════════════════════════════
      // ALL BANDS TIMELINE (Mind Monitor style)
      // Shows all 5 band powers scrolling together with unique colors
      // ══════════════════════════════════════════════════════════════════
      function AllBandsTimeline(p) {
        var th = p.t,
          d = DEVS[p.dev],
          isDk = th === TH.dark;
        var ref = useRef(null);
        var historyRef = useRef({});

        // Initialize history buffers for each band
        BANDS.forEach(function (band, bi) {
          if (!historyRef.current[bi]) {
            historyRef.current[bi] = [];
          }
        });

        useEffect(
          function () {
            try {
              var c = ref.current;
              if (!c) return;
              var ctx = c.getContext("2d");
              if (!ctx) return;

              var W = c.width,
                H = c.height;

              ctx.clearRect(0, 0, W, H);

              var leftMargin = 100;
              var rightMargin = 30;
              var topMargin = 40;
              var bottomMargin = 40;
              var plotW = W - leftMargin - rightMargin;
              var plotH = H - topMargin - bottomMargin;

              // Title
              ctx.fillStyle = th.t2 || "#333";
              ctx.font = "bold 24px " + M;
              ctx.fillText("All Bands Timeline", leftMargin, 28);

              // Background
              ctx.fillStyle = th.sg || "#f5f5f5";
              ctx.fillRect(leftMargin, topMargin, plotW, plotH);

              // Grid
              ctx.strokeStyle = (th.bd || "#ddd") + "40";
              ctx.lineWidth = 1;
              for (var g = 0; g <= 5; g++) {
                var yy = topMargin + (g / 5) * plotH;
                ctx.beginPath();
                ctx.moveTo(leftMargin, yy);
                ctx.lineTo(leftMargin + plotW, yy);
                ctx.stroke();
              }
              for (var t = 0; t <= 10; t++) {
                var xx = leftMargin + (t / 10) * plotW;
                ctx.beginPath();
                ctx.moveTo(xx, topMargin);
                ctx.lineTo(xx, topMargin + plotH);
                ctx.stroke();
              }

              // Y-axis labels (normalized power)
              ctx.fillStyle = th.t3 || "#666";
              ctx.font = "14px " + M;
              ctx.textAlign = "right";
              ctx.fillText("1.0", leftMargin - 10, topMargin + 5);
              ctx.fillText("0.8", leftMargin - 10, topMargin + plotH * 0.2 + 5);
              ctx.fillText("0.6", leftMargin - 10, topMargin + plotH * 0.4 + 5);
              ctx.fillText("0.4", leftMargin - 10, topMargin + plotH * 0.6 + 5);
              ctx.fillText("0.2", leftMargin - 10, topMargin + plotH * 0.8 + 5);
              ctx.fillText("0.0", leftMargin - 10, topMargin + plotH);

              // Y-axis label
              ctx.save();
              ctx.translate(20, topMargin + plotH / 2);
              ctx.rotate(-Math.PI / 2);
              ctx.textAlign = "center";
              ctx.font = "bold 13px " + M;
              ctx.fillStyle = th.t2 || "#333";
              ctx.fillText("Normalized Power (0-1)", 0, 0);
              ctx.restore();

              // Draw each band's timeline
              var maxHistory = 200;
              var enabledBands = [];

              if (!d || !d.eeg) return; // Safety check

              BANDS.forEach(function (band, bi) {
                // Check if band is enabled (default to true if bandToggles not set)
                var bandKey = band.n.toLowerCase();
                var isEnabled =
                  !p.bandToggles || p.bandToggles[bandKey] !== false;

                if (isEnabled) {
                  enabledBands.push(bi);

                  // Calculate average power across all channels
                  var sum = 0;
                  var count = 0;
                  d.eeg.forEach(function (el) {
                    if (typeof bpow === "function") {
                      sum += bpow(
                        p.time || 0,
                        el.id,
                        bi,
                        p.pid || "none",
                        p.fp || {},
                      );
                      count++;
                    }
                  });
                  var avg = count > 0 ? sum / count : 0;

                  // Add to history
                  historyRef.current[bi].push(avg);
                  if (historyRef.current[bi].length > maxHistory) {
                    historyRef.current[bi].shift();
                  }

                  // Draw line
                  var color = isDk ? band.d : band.c;
                  ctx.strokeStyle = color;
                  ctx.lineWidth = 2.5;
                  ctx.globalAlpha = 0.85;
                  ctx.beginPath();

                  var history = historyRef.current[bi];
                  if (history && history.length > 0) {
                    history.forEach(function (val, i) {
                      var x =
                        leftMargin + (i / Math.max(maxHistory - 1, 1)) * plotW;
                      var y = topMargin + plotH - val * plotH;
                      i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
                    });
                    ctx.stroke();
                  }

                  ctx.globalAlpha = 1;
                }
              });

              // Legend (right side)
              ctx.font = "bold 16px " + M;
              enabledBands.forEach(function (bi, idx) {
                var band = BANDS[bi];
                var color = isDk ? band.d : band.c;
                var yy = topMargin + 20 + idx * 30;

                // Color box
                ctx.fillStyle = color;
                ctx.fillRect(leftMargin + plotW + 10, yy - 12, 20, 16);

                // Label
                ctx.fillStyle = th.t2 || "#333";
                ctx.textAlign = "left";
                ctx.fillText(band.n, leftMargin + plotW + 35, yy);

                // Frequency range
                ctx.fillStyle = th.t3 || "#666";
                ctx.font = "11px " + M;
                ctx.fillText(band.r + " Hz", leftMargin + plotW + 35, yy + 12);
                ctx.font = "bold 16px " + M;
              });

              // X-axis time labels (assuming 256Hz sample rate, 200 samples shown)
              ctx.fillStyle = th.t3 || "#666";
              ctx.font = "12px " + M;
              ctx.textAlign = "center";
              var maxHistory = 200;
              var sampleRate = 256; // typical EEG sample rate
              var timeWindow = maxHistory / sampleRate; // seconds
              for (var tx = 0; tx <= 4; tx++) {
                var xPos = leftMargin + (tx / 4) * plotW;
                var timeVal = ((tx / 4) * timeWindow).toFixed(1);
                ctx.fillText(timeVal + "s", xPos, topMargin + plotH + 25);
              }

              // X-axis label
              ctx.font = "bold 13px " + M;
              ctx.fillStyle = th.t2 || "#333";
              ctx.fillText("Time (seconds)", leftMargin + plotW / 2, H - 8);
            } catch (err) {
              console.error("[AllBandsTimeline] Render error:", err);
            }
          },
          [p.time, p.bandToggles],
        );

        return h("canvas", {
          ref: ref,
          width: 2400,
          height: 800,
          style: {
            width: "100%",
            maxWidth: "50%",
            height: "auto",
            borderRadius: 8,
            background: th.sg || "#f5f5f5",
            margin: "0 auto",
            display: "block",
          },
        });
      }

      // ══════════════════════════════════════════════════════════════════
      // SIMPLIFIED BAND POWER SPECTRUM
      // Shows 5 brain wave bands (Delta, Theta, Alpha, Beta, Gamma) clearly
      // ══════════════════════════════════════════════════════════════════
      // ══════════════════════════════════════════════════════════════════
      // FFT SPECTRUM ANALYZER (NeurOSC / Audacity style)
      // Continuous 2D frequency spectrum with color-coded bands
      // ══════════════════════════════════════════════════════════════════
      function SpectrumView(p) {
        var th = p.t,
          d = DEVS[p.dev],
          isDk = th === TH.dark;
        var ref = useRef(null);
        var fftDataRef = useRef({ channels: [], frequencies: [], power: [] });
        var bandsDataRef = useRef({ bands: [], values: [] });

        // Poll /api/fft for real frequency spectrum
        useEffect(function () {
          var timer = setInterval(function () {
            fetch("/api/fft?minFreq=0.5&maxFreq=50")
              .then(function (r) {
                return r.json();
              })
              .then(function (data) {
                if (data.frequencies && data.power) {
                  fftDataRef.current = data;
                }
              })
              .catch(function () {});
          }, 100);
          return function () {
            clearInterval(timer);
          };
        }, []);

        // Also poll /api/bands for the band power bars at bottom
        useEffect(function () {
          var timer = setInterval(function () {
            fetch("/api/bands")
              .then(function (r) {
                return r.json();
              })
              .then(function (data) {
                if (data.values && data.values.length > 0) {
                  bandsDataRef.current = {
                    bands: ["Delta", "Theta", "Alpha", "Beta", "Gamma"],
                    values: data.values,
                  };
                }
              })
              .catch(function () {});
          }, 100);
          return function () {
            clearInterval(timer);
          };
        }, []);

        // Render FFT spectrum + band powers
        useEffect(
          function () {
            try {
              var c = ref.current;
              if (!c) return;
              var ctx = c.getContext("2d");
              if (!ctx) return;

              var W = c.width,
                H = c.height;

              // Clear background
              ctx.fillStyle = isDk ? "#0a0e1a" : "#ffffff";
              ctx.fillRect(0, 0, W, H);

              var fftData = fftDataRef.current;
              if (!fftData.frequencies || fftData.frequencies.length === 0)
                return;

              var topMargin = 100;
              var bottomMargin = 200; // Extra space for band bars
              var leftMargin = 120;
              var rightMargin = 80;
              var plotW = W - leftMargin - rightMargin;
              var plotH = H - topMargin - bottomMargin;

              // ═══════════════════════════════════════════════════════════
              // TITLE & INFO
              // ═══════════════════════════════════════════════════════════
              ctx.fillStyle = th.t1 || "#333";
              ctx.font = "bold 28px " + M;
              ctx.fillText("FFT Spectrum Analyzer", leftMargin, 45);

              ctx.fillStyle = th.t3 || "#666";
              ctx.font = "14px " + M;
              ctx.fillText(
                "Continuous frequency spectrum — Color-coded brain wave bands",
                leftMargin,
                75,
              );

              // ═══════════════════════════════════════════════════════════
              // FFT SPECTRUM PLOT (Audacity style)
              // ═══════════════════════════════════════════════════════════

              // Background
              ctx.fillStyle = isDk ? "#0f1419" : "#f8f9fa";
              ctx.fillRect(leftMargin, topMargin, plotW, plotH);

              // Grid
              ctx.strokeStyle = (th.bd || "#ddd") + "40";
              ctx.lineWidth = 1;
              for (var g = 0; g <= 5; g++) {
                var yy = topMargin + (g / 5) * plotH;
                ctx.beginPath();
                ctx.moveTo(leftMargin, yy);
                ctx.lineTo(leftMargin + plotW, yy);
                ctx.stroke();
              }

              // Frequency grid lines at band boundaries
              var bandBoundaries = [4, 8, 13, 30]; // Delta|Theta|Alpha|Beta|Gamma
              var freqRange = [
                fftData.frequencies[0],
                fftData.frequencies[fftData.frequencies.length - 1],
              ];
              bandBoundaries.forEach(function (freq) {
                if (freq >= freqRange[0] && freq <= freqRange[1]) {
                  var xPos =
                    leftMargin +
                    ((freq - freqRange[0]) / (freqRange[1] - freqRange[0])) *
                      plotW;
                  ctx.strokeStyle = (th.t3 || "#999") + "60";
                  ctx.lineWidth = 2;
                  ctx.setLineDash([5, 5]);
                  ctx.beginPath();
                  ctx.moveTo(xPos, topMargin);
                  ctx.lineTo(xPos, topMargin + plotH);
                  ctx.stroke();
                  ctx.setLineDash([]);
                }
              });

              // Axes labels
              ctx.fillStyle = th.t3 || "#666";
              ctx.font = "bold 14px " + M;
              ctx.textAlign = "right";
              ctx.fillText("Power", leftMargin - 10, topMargin + 4);
              ctx.fillText("(dB)", leftMargin - 10, topMargin + 20);

              // X-axis: Frequency (Hz)
              ctx.textAlign = "center";
              for (var f = 0; f <= 50; f += 10) {
                if (f >= freqRange[0] && f <= freqRange[1]) {
                  var xx =
                    leftMargin +
                    ((f - freqRange[0]) / (freqRange[1] - freqRange[0])) *
                      plotW;
                  ctx.fillText(f + " Hz", xx, topMargin + plotH + 30);
                }
              }

              // ═══════════════════════════════════════════════════════════
              // DRAW FFT CURVES (color-coded by frequency band)
              // ═══════════════════════════════════════════════════════════

              // Helper: Get band color for frequency
              function getBandColor(freq) {
                if (freq < 4) return isDk ? BANDS[0].d : BANDS[0].c; // Delta
                if (freq < 8) return isDk ? BANDS[1].d : BANDS[1].c; // Theta
                if (freq < 13) return isDk ? BANDS[2].d : BANDS[2].c; // Alpha
                if (freq < 30) return isDk ? BANDS[3].d : BANDS[3].c; // Beta
                return isDk ? BANDS[4].d : BANDS[4].c; // Gamma
              }

              // Average power across all channels (or show per-channel if desired)
              var avgPower = [];
              for (var fi = 0; fi < fftData.frequencies.length; fi++) {
                var sum = 0;
                var count = 0;
                for (var ch = 0; ch < fftData.power.length; ch++) {
                  if (
                    fftData.power[ch] &&
                    fftData.power[ch][fi] !== undefined
                  ) {
                    sum += fftData.power[ch][fi];
                    count++;
                  }
                }
                avgPower.push(count > 0 ? sum / count : -60);
              }

              // Normalize to 0-1 range for display
              var minDB = -60;
              var maxDB = 20;
              var normalizedPower = avgPower.map(function (db) {
                return Math.max(0, Math.min(1, (db - minDB) / (maxDB - minDB)));
              });

              // Draw gradient-filled spectrum by band segments
              var bandRanges = [
                { start: 0.5, end: 4, idx: 0 },
                { start: 4, end: 8, idx: 1 },
                { start: 8, end: 13, idx: 2 },
                { start: 13, end: 30, idx: 3 },
                { start: 30, end: 50, idx: 4 },
              ];

              bandRanges.forEach(function (range) {
                var bandColor = isDk ? BANDS[range.idx].d : BANDS[range.idx].c;

                // Find frequency indices in this band
                var startIdx = fftData.frequencies.findIndex(function (f) {
                  return f >= range.start;
                });
                var endIdx = fftData.frequencies.findIndex(function (f) {
                  return f > range.end;
                });
                if (endIdx === -1) endIdx = fftData.frequencies.length;
                if (startIdx === -1) return;

                // Draw filled area
                ctx.beginPath();
                ctx.moveTo(
                  leftMargin +
                    ((fftData.frequencies[startIdx] - freqRange[0]) /
                      (freqRange[1] - freqRange[0])) *
                      plotW,
                  topMargin + plotH,
                );

                for (var i = startIdx; i < endIdx; i++) {
                  var freq = fftData.frequencies[i];
                  var power = normalizedPower[i];
                  var x =
                    leftMargin +
                    ((freq - freqRange[0]) / (freqRange[1] - freqRange[0])) *
                      plotW;
                  var y = topMargin + plotH - power * plotH;
                  ctx.lineTo(x, y);
                }

                ctx.lineTo(
                  leftMargin +
                    ((fftData.frequencies[endIdx - 1] - freqRange[0]) /
                      (freqRange[1] - freqRange[0])) *
                      plotW,
                  topMargin + plotH,
                );
                ctx.closePath();

                // Gradient fill
                var gradient = ctx.createLinearGradient(
                  0,
                  topMargin + plotH,
                  0,
                  topMargin,
                );
                gradient.addColorStop(0, bandColor + "20");
                gradient.addColorStop(1, bandColor + "80");
                ctx.fillStyle = gradient;
                ctx.fill();

                // Stroke outline
                ctx.beginPath();
                for (var i = startIdx; i < endIdx; i++) {
                  var freq = fftData.frequencies[i];
                  var power = normalizedPower[i];
                  var x =
                    leftMargin +
                    ((freq - freqRange[0]) / (freqRange[1] - freqRange[0])) *
                      plotW;
                  var y = topMargin + plotH - power * plotH;
                  i === startIdx ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
                }
                ctx.strokeStyle = bandColor;
                ctx.lineWidth = 2.5;
                ctx.globalAlpha = 0.9;
                ctx.stroke();
                ctx.globalAlpha = 1;
              });

              // ═══════════════════════════════════════════════════════════
              // BAND POWER BARS (bottom section)
              // ═══════════════════════════════════════════════════════════
              var bandsData = bandsDataRef.current;
              if (bandsData.values && bandsData.values.length > 0) {
                var barY = topMargin + plotH + 60;
                var barH = 80;
                var barGap = 20;
                var numBars = 5;
                var barW = (plotW - (numBars - 1) * barGap) / numBars;

                // Average across channels
                var avgBands = [0, 0, 0, 0, 0];
                bandsData.values.forEach(function (chVals) {
                  for (var i = 0; i < 5; i++) {
                    avgBands[i] += Math.abs(chVals[i] || 0);
                  }
                });
                avgBands = avgBands.map(function (v) {
                  return v / bandsData.values.length;
                });

                var maxPower = Math.max.apply(null, avgBands) || 1;

                for (var i = 0; i < 5; i++) {
                  var band = BANDS[i];
                  var bandColor = isDk ? band.d : band.c;
                  var power = avgBands[i];
                  var fillH = (power / maxPower) * barH;
                  var barX = leftMargin + i * (barW + barGap);

                  // Background
                  ctx.fillStyle = (th.bd || "#ddd") + "20";
                  ctx.fillRect(barX, barY, barW, barH);

                  // Fill
                  ctx.fillStyle = bandColor + "60";
                  ctx.fillRect(barX, barY + barH - fillH, barW, fillH);

                  // Border
                  ctx.strokeStyle = bandColor;
                  ctx.lineWidth = 2;
                  ctx.strokeRect(barX, barY, barW, barH);

                  // Label
                  ctx.fillStyle = th.t2 || "#333";
                  ctx.font = "bold 12px " + M;
                  ctx.textAlign = "center";
                  ctx.fillText(
                    band.n + " " + band.r + "Hz",
                    barX + barW / 2,
                    barY + barH + 18,
                  );

                  // Value
                  ctx.fillText(
                    power.toFixed(2),
                    barX + barW / 2,
                    barY + barH / 2,
                  );
                }
              }
            } catch (err) {
              console.error("[SpectrumView] Render error:", err);
            }
          },
          [p.time],
        );

        return h("canvas", {
          ref: ref,
          width: 2400,
          height: 1200,
          style: {
            width: "100%",
            maxWidth: "50%",
            height: "auto",
            background: isDk ? th.bg : "#fff",
            borderRadius: 8,
            display: "block",
            margin: "0 auto",
          },
        });
      }

      // ── Band Powers View (NeurOSC-style standalone bars) ──
      function BandPowersView(p) {
        var th = p.t,
          d = DEVS[p.dev],
          isDk = th === TH.dark;
        var ref = useRef(null);
        var dataRef = useRef({ channels: [], bands: [], values: [] });

        // Poll /api/bands endpoint
        useEffect(function () {
          var timer = setInterval(function () {
            fetch("/api/bands")
              .then(function (r) {
                return r.json();
              })
              .then(function (data) {
                if (data.values && data.values.length > 0) {
                  dataRef.current = data;
                }
              })
              .catch(function () {});
          }, 100);
          return function () {
            clearInterval(timer);
          };
        }, []);

        // Render
        useEffect(
          function () {
            var c = ref.current;
            if (!c) return;
            var ctx = c.getContext("2d"),
              W = c.width,
              H = c.height;
            ctx.clearRect(0, 0, W, H);

            var data = dataRef.current;
            if (!data.values || data.values.length === 0) return;

            // Title
            ctx.fillStyle = th.t1;
            ctx.font = "bold 28px " + M;
            ctx.fillText("Band Powers", 40, 50);

            // Subtitle with measurement info
            ctx.fillStyle = th.t3;
            ctx.font = "13px " + M;
            ctx.fillText("Relative power distribution (normalized)", 40, 72);

            var numChannels = Math.min(data.channels.length, 4);
            var bottomMargin = 80;
            var topMargin = 100;
            var leftMargin = 80;
            var rightMargin = 40;
            var channelSpacing = 40;

            var plotH = H - topMargin - bottomMargin;
            var totalW = W - leftMargin - rightMargin;
            var channelW =
              (totalW - (numChannels - 1) * channelSpacing) / numChannels;

            // Get enabled bands from toggles
            var toggles = p.bandToggles || {
              delta: true,
              theta: true,
              alpha: true,
              beta: true,
              gamma: true,
            };
            var bandKeys = ["delta", "theta", "alpha", "beta", "gamma"];
            var enabledBands = [];
            for (var i = 0; i < 5; i++) {
              if (toggles[bandKeys[i]]) {
                enabledBands.push(i);
              }
            }

            if (enabledBands.length === 0) {
              ctx.fillStyle = th.t3;
              ctx.font = "16px " + M;
              ctx.textAlign = "center";
              ctx.fillText("No bands selected", W / 2, H / 2);
              return;
            }

            // Draw background grid (scientific style)
            ctx.strokeStyle = isDk ? "#ffffff10" : "#00000008";
            ctx.lineWidth = 1;
            for (var gridY = 0; gridY <= 10; gridY++) {
              var yLine = topMargin + plotH - (gridY / 10) * plotH;
              ctx.globalAlpha = gridY % 2 === 0 ? 0.3 : 0.15;
              ctx.beginPath();
              ctx.moveTo(leftMargin, yLine);
              ctx.lineTo(leftMargin + totalW, yLine);
              ctx.stroke();
            }
            ctx.globalAlpha = 1.0;

            // Draw each channel's bands (VERTICAL bars)
            for (var ch = 0; ch < numChannels; ch++) {
              var chX = leftMargin + ch * (channelW + channelSpacing);
              var channelBands = data.values[ch] || [];
              if (channelBands.length === 0) continue;

              // Channel label (top)
              var chName = data.channels[ch] || "CH" + (ch + 1);
              ctx.fillStyle = th.t1;
              ctx.font = "bold 20px " + M;
              ctx.textAlign = "center";
              ctx.fillText(chName, chX + channelW / 2, 80);

              // Normalize to 0-1 (use absolute values, convert to percentages)
              var total = 0;
              channelBands.forEach(function (v) {
                total += Math.abs(v);
              });

              var barW = channelW / enabledBands.length;

              // Draw ONLY enabled bands as VERTICAL bars
              for (var ebi = 0; ebi < enabledBands.length; ebi++) {
                var bi = enabledBands[ebi];
                var barX = chX + ebi * barW;
                var bandValue = Math.abs(channelBands[bi]) / (total || 1);
                var barH = plotH * Math.min(1, bandValue);

                var band = BANDS[bi];
                var bandColor = isDk ? band.d : band.c;

                // Bar (vertical, grows upward from bottom)
                var barY = topMargin + plotH - barH;

                // Gradient (vertical)
                var gradient = ctx.createLinearGradient(
                  barX,
                  topMargin + plotH,
                  barX,
                  barY,
                );
                gradient.addColorStop(0, bandColor + "40");
                gradient.addColorStop(1, bandColor);
                ctx.fillStyle = gradient;
                ctx.fillRect(barX + 2, barY, barW - 4, barH);

                // Border
                ctx.strokeStyle = bandColor;
                ctx.lineWidth = 2;
                ctx.strokeRect(barX + 2, barY, barW - 4, barH);

                // Band label (bottom)
                ctx.save();
                ctx.translate(barX + barW / 2, H - 48);
                ctx.fillStyle = bandColor;
                ctx.font = "bold 14px " + M;
                ctx.textAlign = "center";
                ctx.fillText(band.n, 0, 0);

                // Frequency range (smaller, below band name)
                ctx.fillStyle = th.t3;
                ctx.font = "10px " + M;
                ctx.fillText(band.r + " Hz", 0, 14);
                ctx.restore();

                // Value text (on bar)
                if (barH > 30) {
                  ctx.fillStyle = isDk ? "#fff" : "#000";
                  ctx.font = "bold 11px " + M;
                  ctx.textAlign = "center";
                  ctx.fillText(
                    (bandValue * 100).toFixed(0) + "%",
                    barX + barW / 2,
                    barY + barH / 2 + 4,
                  );
                }
              }

              // Y-axis scale (left side, first channel only) - more detailed
              if (ch === 0) {
                ctx.fillStyle = th.t3;
                ctx.font = "11px " + M;
                ctx.textAlign = "right";
                // Draw scale markers
                for (var yscale = 0; yscale <= 10; yscale++) {
                  var yPos = topMargin + plotH - (yscale / 10) * plotH;
                  var label = yscale * 10 + "%";
                  if (yscale % 2 === 0) {
                    ctx.font = "bold 11px " + M;
                    ctx.fillText(label, leftMargin - 10, yPos + 4);
                  } else {
                    ctx.font = "10px " + M;
                    ctx.fillStyle = th.t3 + "80";
                    ctx.fillText(label, leftMargin - 10, yPos + 4);
                    ctx.fillStyle = th.t3;
                  }
                }

                // Y-axis label (rotated)
                ctx.save();
                ctx.translate(20, topMargin + plotH / 2);
                ctx.rotate(-Math.PI / 2);
                ctx.font = "bold 12px " + M;
                ctx.fillStyle = th.t2;
                ctx.textAlign = "center";
                ctx.fillText("Relative Power (%)", 0, 0);
                ctx.restore();
              }
            }
          },
          [p.time],
        );

        return h("canvas", {
          ref: ref,
          width: 1200,
          height: 800,
          style: {
            width: "600px",
            height: "400px",
            maxWidth: "50%",
            background: isDk ? th.bg : "#fff",
            borderRadius: 4,
            display: "block",
            margin: "0 auto",
          },
        });
      }

      // ── 3D FFT Waterfall ──
      function Waterfall(p) {
        var d = DEVS[p.dev],
          hist = useRef([]),
          isDk = p.t === TH.dark,
          th = p.t;
        var ref = useRef(null);
        useEffect(
          function () {
            // Build a row of FFT bins (60 bins covering 0-60 Hz) for the first electrode
            var elId = d.eeg[0].id;
            var nBins = 60;
            var row = [];
            for (var f = 0; f < nBins; f++) {
              var freq = (f / nBins) * 60;
              var bIdx =
                freq < 4 ? 0 : freq < 8 ? 1 : freq < 13 ? 2 : freq < 30 ? 3 : 4;
              row.push(
                Math.abs(eeg(p.time + f * 0.002, elId, bIdx, p.pid, p.fp)) / 50,
              );
            }
            hist.current.push(row);
            if (hist.current.length > 90) hist.current.shift();
            var c = ref.current;
            if (!c) return;
            var ctx = c.getContext("2d"),
              W = c.width,
              H = c.height;
            ctx.clearRect(0, 0, W, H);
            var oX = 60,
              oY = 35,
              nRows = hist.current.length;
            var binW = (W - 140) / nBins;
            // Draw back to front
            for (var r = 0; r < nRows; r++) {
              var rd = hist.current[r];
              var yBase = H - oY - r * 3.8;
              var xShift = r * 1.8;
              var alpha = 0.08 + (r / nRows) * 0.92;
              // Filled polygon
              ctx.beginPath();
              ctx.moveTo(oX + xShift, yBase);
              for (var b2 = 0; b2 < nBins; b2++) {
                var x = oX + xShift + b2 * binW;
                var amp = Math.min(rd[b2], 2) * 120;
                ctx.lineTo(x, yBase - amp);
              }
              ctx.lineTo(oX + xShift + (nBins - 1) * binW, yBase);
              ctx.closePath();
              // Color by predominant band at front
              var bIdx2 = Math.floor(nBins / 2);
              var freq2 = (bIdx2 / nBins) * 60;
              var bandI =
                freq2 < 4
                  ? 0
                  : freq2 < 8
                    ? 1
                    : freq2 < 13
                      ? 2
                      : freq2 < 30
                        ? 3
                        : 4;
              var bc = isDk ? BANDS[p.bi].d : BANDS[p.bi].c;
              ctx.fillStyle =
                bc +
                Math.floor(alpha * 18)
                  .toString(16)
                  .padStart(2, "0");
              ctx.fill();
              // Line with color segments
              for (var b3 = 1; b3 < nBins; b3++) {
                var freq3 = (b3 / nBins) * 60;
                var bi3 =
                  freq3 < 4
                    ? 0
                    : freq3 < 8
                      ? 1
                      : freq3 < 13
                        ? 2
                        : freq3 < 30
                          ? 3
                          : 4;
                var segCol = isDk ? BANDS[bi3].d : BANDS[bi3].c;
                ctx.strokeStyle = segCol;
                ctx.globalAlpha = alpha;
                ctx.lineWidth = 1.2;
                ctx.beginPath();
                ctx.moveTo(
                  oX + xShift + (b3 - 1) * binW,
                  yBase - Math.min(rd[b3 - 1], 2) * 120,
                );
                ctx.lineTo(
                  oX + xShift + b3 * binW,
                  yBase - Math.min(rd[b3], 2) * 120,
                );
                ctx.stroke();
              }
              ctx.globalAlpha = 1;
            }
            // Frequency axis labels
            ctx.fillStyle = th.t3;
            ctx.font = "9px " + M;
            [0, 4, 8, 13, 30, 60].forEach(function (f2) {
              var x = oX + (f2 / 60) * (W - 140);
              ctx.fillText(f2 + "Hz", x - 6, H - 4);
            });
            // Band labels at top
            ctx.font = "bold 8px " + M;
            [
              { n: "Delta", lo: 0, hi: 4, i: 0 },
              { n: "Theta", lo: 4, hi: 8, i: 1 },
              { n: "Alpha", lo: 8, hi: 13, i: 2 },
              { n: "Beta", lo: 13, hi: 30, i: 3 },
              { n: "Gamma", lo: 30, hi: 60, i: 4 },
            ].forEach(function (br) {
              var x1 = oX + (br.lo / 60) * (W - 140),
                x2 = oX + (br.hi / 60) * (W - 140);
              var bc2 = isDk ? BANDS[br.i].d : BANDS[br.i].c;
              ctx.fillStyle = bc2 + "30";
              ctx.fillRect(x1, 8, x2 - x1, 12);
              ctx.fillStyle = bc2;
              ctx.fillText(br.n, x1 + 2, 17);
            });
            ctx.fillStyle = th.t3;
            ctx.font = "10px " + M;
            ctx.fillText("\u2190 Time (rows)", W - 100, 20);
            ctx.fillText("Amplitude \u2191", 5, 20);
          },
          [Math.floor(p.time * 5)],
        );
        return h("canvas", {
          ref: ref,
          width: 1300,
          height: 580,
          style: {
            width: "100%",
            height: 440,
            borderRadius: 8,
            background: th.sg,
          },
        });
      }

      // ── Full Brain (4-view EPOC style) ──
      function FullBrain(p) {
        var d = DEVS[p.dev],
          b = BANDS[p.bi],
          isDk = p.t === TH.dark,
          col = isDk ? b.d : b.c,
          skin = p.skin,
          th = p.t;
        var glowR = d.ch <= 4 ? 55 : 38;
        function proj(el, v) {
          switch (v) {
            case "top":
              return { x: el.x * 2.8 + 30, y: el.y * 2.6 + 10 };
            case "left":
              return { x: (100 - el.y) * 2.6 + 15, y: 45 + (50 - el.x) * 1.8 };
            case "right":
              return { x: el.y * 2.6 + 15, y: 45 + (el.x - 50) * 1.8 };
            default:
              return { x: (100 - el.x) * 2.6 + 15, y: (100 - el.y) * 2.2 + 15 };
          }
        }
        return h(
          "div",
          null,
          h(
            "div",
            { style: { fontSize: 8, color: th.t3, marginBottom: 6 } },
            d.name +
              " \u2014 showing " +
              b.n +
              " band power across " +
              d.ch +
              " electrodes. Brighter = higher power.",
          ),
          h(
            "div",
            {
              style: {
                display: "grid",
                gridTemplateColumns: "1fr 1fr",
                gap: 8,
              },
            },
            ["top", "left", "right", "back"].map(function (v) {
              var fE = d.eeg.filter(function (e) {
                return v === "top"
                  ? true
                  : v === "left"
                    ? e.x <= 55
                    : v === "right"
                      ? e.x >= 45
                      : e.y >= 50;
              });
              // Build radial gradient defs for each electrode in this view
              var gradDefs = fE.map(function (el) {
                var pw = bpow(p.time, el.id, p.bi, p.pid, p.fp);
                return h(
                  "radialGradient",
                  { key: "fb_" + v + "_" + el.id, id: "fb_" + v + "_" + el.id },
                  h("stop", {
                    offset: "0%",
                    stopColor: col,
                    stopOpacity: Math.max(0.35, pw * 0.9),
                  }),
                  h("stop", {
                    offset: "45%",
                    stopColor: col,
                    stopOpacity: Math.max(0.15, pw * 0.5),
                  }),
                  h("stop", { offset: "100%", stopColor: col, stopOpacity: 0 }),
                );
              });
              return h(
                "div",
                {
                  key: v,
                  style: {
                    background: th.sg,
                    borderRadius: 8,
                    border: "1px solid " + th.bd,
                    padding: 4,
                  },
                },
                h(
                  "div",
                  {
                    style: {
                      fontSize: 9,
                      fontWeight: 700,
                      color: th.t2,
                      textTransform: "capitalize",
                      padding: "2px 6px",
                    },
                  },
                  v,
                ),
                h(
                  "svg",
                  {
                    viewBox: "0 0 320 260",
                    style: { width: "100%", height: 200 },
                  },
                  h("defs", null, gradDefs),
                  h("ellipse", {
                    cx: 160,
                    cy: 130,
                    rx: 125,
                    ry: 120,
                    fill: skin.brain,
                    stroke: skin.sulci,
                    strokeWidth: 1.5,
                  }),
                  v === "top" &&
                    h("line", {
                      x1: 160,
                      y1: 8,
                      x2: 160,
                      y2: 252,
                      stroke: skin.sulci,
                      strokeWidth: 1.5,
                      opacity: 0.4,
                    }),
                  v === "top" &&
                    h(
                      "text",
                      {
                        x: 160,
                        y: 8,
                        textAnchor: "middle",
                        fontSize: 7,
                        fill: th.t3,
                      },
                      "Front",
                    ),
                  v === "top" &&
                    h(
                      "text",
                      {
                        x: 160,
                        y: 258,
                        textAnchor: "middle",
                        fontSize: 7,
                        fill: th.t3,
                      },
                      "Back",
                    ),
                  // Glow layer (radial gradient halos — rendered first, behind dots)
                  fE.map(function (el) {
                    var pt = proj(el, v),
                      pw = bpow(p.time, el.id, p.bi, p.pid, p.fp);
                    return h("circle", {
                      key: "glow_" + el.id,
                      cx: pt.x,
                      cy: pt.y,
                      r: glowR + pw * 30,
                      fill: "url(#fb_" + v + "_" + el.id + ")",
                    });
                  }),
                  // Electrode dots + labels (on top of glows)
                  fE.map(function (el) {
                    var pt = proj(el, v),
                      pw = bpow(p.time, el.id, p.bi, p.pid, p.fp);
                    return h(
                      "g",
                      { key: el.id },
                      h("circle", {
                        cx: pt.x,
                        cy: pt.y,
                        r: 7 + pw * 5,
                        fill: col,
                        opacity: 0.75 + pw * 0.25,
                        stroke: th.c1,
                        strokeWidth: 1.2,
                      }),
                      h(
                        "text",
                        {
                          x: pt.x,
                          y: pt.y - 12,
                          textAnchor: "middle",
                          fontSize: 8,
                          fill: th.tx,
                          fontWeight: 600,
                          fontFamily: M,
                        },
                        el.id,
                      ),
                    );
                  }),
                ),
              );
            }),
          ),
        );
      }

      // ── Phase Display (2D polar, smoothed) ──
      function PhaseView(p) {
        var d = DEVS[p.dev],
          b = BANDS[p.bi],
          isDk = p.t === TH.dark,
          col = isDk ? b.d : b.c,
          th = p.t;
        var ref = useRef(null),
          trails = useRef({});
        useEffect(
          function () {
            var c = ref.current;
            if (!c) return;
            var ctx = c.getContext("2d"),
              W = c.width,
              H = c.height;
            ctx.clearRect(0, 0, W, H);
            var cx = W / 2,
              cy = H / 2,
              r = Math.min(cx, cy) - 30;
            // Grid circles
            ctx.strokeStyle = th.bd;
            ctx.lineWidth = 0.5;
            [1, 0.75, 0.5, 0.25].forEach(function (s) {
              ctx.beginPath();
              ctx.arc(cx, cy, r * s, 0, Math.PI * 2);
              ctx.stroke();
            });
            // Cross hairs
            ctx.beginPath();
            ctx.moveTo(cx - r, cy);
            ctx.lineTo(cx + r, cy);
            ctx.moveTo(cx, cy - r);
            ctx.lineTo(cx, cy + r);
            ctx.stroke();
            // Degree labels
            ctx.fillStyle = th.t3;
            ctx.font = "9px " + M;
            [0, 90, 180, 270].forEach(function (deg) {
              var rad = (deg * Math.PI) / 180;
              ctx.fillText(
                deg + "\u00B0",
                cx + Math.cos(rad) * (r + 14) - 8,
                cy + Math.sin(rad) * (r + 14) + 3,
              );
            });
            // Electrode phase vectors with trail
            d.eeg.forEach(function (el) {
              var phase =
                (eeg(p.time, el.id, p.bi, p.pid, p.fp) / 80) * Math.PI;
              var mg = Math.min(bpow(p.time, el.id, p.bi, p.pid, p.fp), 1);
              var ex = cx + Math.cos(phase) * r * mg,
                ey = cy + Math.sin(phase) * r * mg;
              // Trail
              if (!trails.current[el.id]) trails.current[el.id] = [];
              trails.current[el.id].push({ x: ex, y: ey });
              if (trails.current[el.id].length > 12)
                trails.current[el.id].shift();
              ctx.strokeStyle = col + "30";
              ctx.lineWidth = 1;
              ctx.beginPath();
              trails.current[el.id].forEach(function (pt, i) {
                i === 0 ? ctx.moveTo(pt.x, pt.y) : ctx.lineTo(pt.x, pt.y);
              });
              ctx.stroke();
              // Vector line
              ctx.strokeStyle = col;
              ctx.lineWidth = 2;
              ctx.globalAlpha = 0.5 + mg * 0.5;
              ctx.beginPath();
              ctx.moveTo(cx, cy);
              ctx.lineTo(ex, ey);
              ctx.stroke();
              ctx.globalAlpha = 1;
              // Dot
              ctx.fillStyle = col;
              ctx.beginPath();
              ctx.arc(ex, ey, 3 + mg * 3, 0, Math.PI * 2);
              ctx.fill();
              ctx.fillStyle = th.tx;
              ctx.font = "bold 8px " + M;
              ctx.fillText(el.id, ex + 6, ey - 4);
            });
          },
          [Math.floor(p.time * 4)],
        );
        return h("canvas", {
          ref: ref,
          width: 600,
          height: 600,
          style: {
            width: "300px",
            height: "300px",
            maxWidth: "50%",
            borderRadius: 8,
            background: th.sg,
            margin: "0 auto",
            display: "block",
          },
        });
      }

      // ── Coherence Matrix ──
      function CoherenceView(p) {
        var th = p.t,
          d = DEVS[p.dev],
          els = d.eeg,
          b = BANDS[p.bi],
          isDk = th === TH.dark,
          col = isDk ? b.d : b.c;
        return h(
          "div",
          {
            style: {
              display: "grid",
              gridTemplateColumns: "24px repeat(" + els.length + ",1fr)",
              gap: 2,
              maxWidth: "50%",
              margin: "0 auto",
            },
          },
          h("div"),
          els.map(function (el) {
            return h(
              "div",
              {
                key: el.id,
                style: {
                  fontSize: 7,
                  textAlign: "center",
                  color: th.t3,
                  fontWeight: 700,
                  fontFamily: M,
                },
              },
              el.id,
            );
          }),
          els.map(function (row, ri) {
            return h(
              Fragment,
              { key: row.id },
              h(
                "div",
                {
                  style: {
                    fontSize: 7,
                    color: th.t3,
                    display: "flex",
                    alignItems: "center",
                    fontFamily: M,
                    fontWeight: 700,
                  },
                },
                row.id,
              ),
              els.map(function (c, ci) {
                var coh =
                  ri === ci
                    ? 1
                    : Math.abs(
                        Math.sin(p.time * 0.3 + ri * 0.7 + ci * 1.1) * 0.5 +
                          0.3 +
                          Math.sin(p.time * 0.1 + ri + ci) * 0.2,
                      );
                return h(
                  "div",
                  {
                    key: c.id,
                    style: {
                      aspectRatio: "1",
                      borderRadius: 3,
                      background:
                        ri === ci
                          ? col + "30"
                          : col +
                            Math.floor(coh * 200)
                              .toString(16)
                              .padStart(2, "0"),
                      border: "1px solid " + th.bd,
                      display: "flex",
                      alignItems: "center",
                      justifyContent: "center",
                      fontSize: 6,
                      color: coh > 0.6 ? th.tx : th.t3,
                      fontFamily: M,
                    },
                  },
                  Math.round(coh * 100),
                );
              }),
            );
          }),
        );
      }

      // ── FFT Spectrum + Power Bands ──
      function FFTView(p) {
        var th = p.t,
          d = DEVS[p.dev],
          isDk = th === TH.dark;
        var ref = useRef(null),
          hist = useRef({}),
          autoMin = useRef(0),
          autoMax = useRef(80);
        useEffect(
          function () {
            var c = ref.current;
            if (!c) return;
            var ctx = c.getContext("2d"),
              W = c.width,
              H = c.height;
            ctx.clearRect(0, 0, W, H);
            var specW = W * 0.65,
              barX = specW + 30,
              barW = W - barX - 10;
            var elId = d.eeg[0].id;

            // Calculate AUTO scale bounds if enabled
            var yMin = 0,
              yMax = 80;
            if (p.autoScale) {
              var allAmps = [];
              d.eeg.slice(0, 4).forEach(function (el) {
                for (var f = 0; f < 120; f++) {
                  var freq = (f / 120) * 60,
                    bIdx =
                      freq < 4
                        ? 0
                        : freq < 8
                          ? 1
                          : freq < 13
                            ? 2
                            : freq < 30
                              ? 3
                              : 4;
                  allAmps.push(
                    Math.abs(eeg(p.time + f * 0.002, el.id, bIdx, p.pid, p.fp)),
                  );
                }
              });
              if (allAmps.length > 0) {
                var dataMax = Math.max.apply(null, allAmps);
                autoMax.current = autoMax.current * 0.85 + dataMax * 0.15;
                yMax = autoMax.current * 1.1; // 10% headroom
              }
            } else {
              yMax = p.yAxisRange || 80;
            }
            // ── Left: FFT spectrum curve ──
            // Grid
            ctx.strokeStyle = th.bd + "60";
            ctx.lineWidth = 0.5;
            for (var gy = 0; gy < 5; gy++) {
              var yy = 20 + gy * ((H - 40) / 4);
              ctx.beginPath();
              ctx.moveTo(40, yy);
              ctx.lineTo(specW, yy);
              ctx.stroke();
            }
            // Frequency axis
            ctx.fillStyle = th.t3;
            ctx.font = "8px " + M;
            [0, 10, 20, 30, 40, 50, 60].forEach(function (f) {
              var xx = 40 + (f / 60) * (specW - 50);
              ctx.fillText(f + "", xx - 6, H - 4);
            });
            ctx.fillText("Hz", specW - 10, H - 4);
            // Band region shading
            var bandRanges = [
              { lo: 0.5, hi: 4, bi: 0 },
              { lo: 4, hi: 8, bi: 1 },
              { lo: 8, hi: 13, bi: 2 },
              { lo: 13, hi: 30, bi: 3 },
              { lo: 30, hi: 60, bi: 4 },
            ];
            bandRanges.forEach(function (br) {
              var x1 = 40 + (br.lo / 60) * (specW - 50),
                x2 = 40 + (br.hi / 60) * (specW - 50);
              var bc = isDk ? BANDS[br.bi].d : BANDS[br.bi].c;
              ctx.fillStyle = bc + "12";
              ctx.fillRect(x1, 15, x2 - x1, H - 40);
              ctx.fillStyle = bc;
              ctx.font = "bold 7px " + M;
              ctx.fillText(BANDS[br.bi].n, x1 + 2, 12);
            });
            // Spectrum line per visible electrode
            d.eeg.slice(0, 4).forEach(function (el, ei) {
              var bc = isDk ? BANDS[ei % 5].d : BANDS[ei % 5].c;
              ctx.strokeStyle = bc;
              ctx.lineWidth = 1.5;
              ctx.globalAlpha = 0.7;
              ctx.beginPath();
              for (var f = 0; f < 120; f++) {
                var freq = (f / 120) * 60,
                  bIdx =
                    freq < 4
                      ? 0
                      : freq < 8
                        ? 1
                        : freq < 13
                          ? 2
                          : freq < 30
                            ? 3
                            : 4;
                var amp = Math.abs(
                  eeg(p.time + f * 0.002, el.id, bIdx, p.pid, p.fp),
                );
                var x = 40 + (freq / 60) * (specW - 50);
                var y = H - 30 - (amp / yMax) * (H - 50);
                f === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
              }
              ctx.stroke();
              ctx.globalAlpha = 1;
            });
            // Electrode legend
            ctx.font = "bold 8px " + M;
            d.eeg.slice(0, 4).forEach(function (el, ei) {
              var bc = isDk ? BANDS[ei % 5].d : BANDS[ei % 5].c;
              ctx.fillStyle = bc;
              ctx.fillText(el.id, specW - 50, 25 + ei * 12);
            });
            // ── Right: Power band bars (all bands, animated) ──
            ctx.fillStyle = th.t2;
            ctx.font = "bold 9px " + M;
            ctx.fillText("Band Power", barX, 14);
            var bandH = (H - 30) / 5 - 4;
            BANDS.forEach(function (band, bi) {
              var bc = isDk ? band.d : band.c;
              // Average power across electrodes
              var sum = 0;
              d.eeg.forEach(function (el) {
                sum += bpow(p.time, el.id, bi, p.pid, p.fp);
              });
              var avg = sum / d.eeg.length;
              // Track history for sparkline
              if (!hist.current[bi]) hist.current[bi] = [];
              hist.current[bi].push(avg);
              if (hist.current[bi].length > 40) hist.current[bi].shift();
              var by = 22 + bi * (bandH + 4);
              // Label
              ctx.fillStyle = bc;
              ctx.font = "bold 8px " + M;
              ctx.fillText(band.n, barX, by + 10);
              // Bar background
              ctx.fillStyle = th.bd + "60";
              ctx.fillRect(barX + 45, by + 2, barW - 50, bandH - 4);
              // Bar fill
              ctx.fillStyle = bc;
              ctx.globalAlpha = 0.8;
              ctx.fillRect(barX + 45, by + 2, avg * (barW - 50), bandH - 4);
              ctx.globalAlpha = 1;
              // Percentage
              ctx.fillStyle = th.tx;
              ctx.font = "bold 8px " + M;
              ctx.fillText(
                Math.round(avg * 100) + "%",
                barX + 45 + avg * (barW - 50) + 4,
                by + bandH - 6,
              );
              // Mini sparkline
              ctx.strokeStyle = bc + "80";
              ctx.lineWidth = 1;
              ctx.beginPath();
              var sparkH = bandH - 8;
              hist.current[bi].forEach(function (v, i) {
                var sx = barX + 45 + (i / 39) * (barW - 50);
                var sy = by + bandH - 2 - v * sparkH;
                i === 0 ? ctx.moveTo(sx, sy) : ctx.lineTo(sx, sy);
              });
              ctx.stroke();
            });
          },
          [Math.floor(p.time * 5)],
        );
        return h("canvas", {
          ref: ref,
          width: 1100,
          height: 350,
          style: {
            width: "100%",
            height: 300,
            borderRadius: 8,
            background: th.sg,
          },
        });
      }

      function AuxPanel(p) {
        var th = p.t,
          d = DEVS[p.dev];
        if (!d.aux[p.kind])
          return h(
            "div",
            {
              style: {
                padding: 16,
                fontSize: 9,
                color: th.t3,
                textAlign: "center",
              },
            },
            "No " + p.kind.toUpperCase() + " data available for this device",
          );
        var allChs = d.aux[p.kind].ch || [];
        // Filter channels based on toggles for fNIRS
        var chs =
          p.kind === "fnirs" && p.fnirsToggles
            ? allChs.filter(function (ch) {
                return p.fnirsToggles[ch];
              })
            : allChs;
        ((colors = [
          "#ef4444",
          "#22c55e",
          "#3b82f6",
          "#f59e0b",
          "#8b5cf6",
          "#ec4899",
        ]),
          (bufs = useRef({})),
          (autoMin = useRef(0)),
          (autoMax = useRef(100)));
        var hrSmooth = useRef(72);
        var ref = useRef(null);
        useEffect(
          function () {
            var c = ref.current;
            if (!c) return;
            var ctx = c.getContext("2d"),
              W = c.width,
              H = c.height;
            ctx.clearRect(0, 0, W, H);

            // Calculate AUTO scale bounds if enabled
            var yMin = -100,
              yMax = 100;
            if (p.autoScale) {
              var allVals = [];
              chs.forEach(function (ch) {
                if (bufs.current[ch]) {
                  allVals = allVals.concat(bufs.current[ch]);
                }
              });
              if (allVals.length > 0) {
                var dataMin = Math.min.apply(null, allVals);
                var dataMax = Math.max.apply(null, allVals);
                autoMin.current = autoMin.current * 0.85 + dataMin * 0.15;
                autoMax.current = autoMax.current * 0.85 + dataMax * 0.15;
                var pad = (autoMax.current - autoMin.current) * 0.1;
                yMin = autoMin.current - pad;
                yMax = autoMax.current + pad;
              }
            } else if (p.yAxisRange) {
              yMin = -p.yAxisRange;
              yMax = p.yAxisRange;
            }

            chs.forEach(function (ch, ci) {
              if (!bufs.current[ch]) bufs.current[ch] = [];
              bufs.current[ch].push(simAux(p.time, ch));
              if (bufs.current[ch].length > 250) bufs.current[ch].shift();
              ctx.strokeStyle = colors[ci % 6];
              ctx.lineWidth = 1.5;
              ctx.beginPath();
              bufs.current[ch].forEach(function (v, i) {
                var x = (i / 249) * W;
                var y;
                if (p.autoScale || p.yAxisRange) {
                  // Use dynamic scaling
                  var normalized = (v - yMin) / (yMax - yMin);
                  y = H - 20 - normalized * (H - 40);
                } else {
                  // Use original hardcoded scaling
                  if (ch.indexOf("PPG") === 0)
                    y = H - 20 - ((v - 60) / 30) * (H - 40);
                  else if (ch.indexOf("Acc") === 0)
                    y = H / 2 - (v / 12) * H * 0.35;
                  else if (ch.indexOf("Gyro") === 0)
                    y = H / 2 - (v / 6) * H * 0.3;
                  else y = H / 2 - (v - 0.3) * H * 1.2;
                }
                i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
              });
              ctx.stroke();
              ctx.fillStyle = colors[ci % 6];
              ctx.font = "bold 18px " + M;
              ctx.fillText(ch, W - 110, 28 + ci * 26);
            });
          },
          [Math.floor(p.time * 8)],
        );
        var isPPG = p.kind === "ppg";
        if (isPPG) {
          hrSmooth.current =
            hrSmooth.current * 0.95 + simAux(p.time, "PPG1") * 0.05;
        }
        return h(
          "div",
          { style: { maxWidth: "50%", margin: "0 auto" } },
          isPPG &&
            h(
              "div",
              {
                style: {
                  display: "flex",
                  alignItems: "center",
                  gap: 12,
                  marginBottom: 8,
                },
              },
              h(
                "span",
                {
                  style: {
                    fontSize: 40,
                    fontWeight: 300,
                    color: "#ef4444",
                    fontFamily: M,
                    lineHeight: 1,
                  },
                },
                Math.round(hrSmooth.current),
              ),
              h(
                "span",
                { style: { fontSize: 10, color: th.t3, fontWeight: 700 } },
                "BPM \u2665",
              ),
            ),
          h("canvas", {
            ref: ref,
            width: 1200,
            height: 400,
            style: {
              width: "100%",
              height: 200,
              borderRadius: 8,
              background: th.sg,
            },
          }),
        );
      }

      // ── Main App ──
      function App() {
        var _th = useState("dark"),
          theme = _th[0],
          setTheme = _th[1];
        var _si = useState(0),
          si = _si[0],
          setSi = _si[1];
        var _dev = useState("muse_s"),
          dev = _dev[0],
          setDev = _dev[1];
        var _pr = useState(null),
          paired = _pr[0],
          setPaired = _pr[1];
        var _v = useState("timeline"),
          view = _v[0],
          setView = _v[1];
        var _bi = useState(2),
          bi = _bi[0],
          setBi = _bi[1];
        var _se = useState(null),
          selEl = _se[0],
          setSelEl = _se[1];
        var _qm = useState(false),
          quadMode = _qm[0],
          setQuadMode = _qm[1];
        var _qp = useState(["timeline", "topo", "neuro", "fft"]),
          quadPanels = _qp[0],
          setQuadPanels = _qp[1];

        // Display mode: single, dual, quad
        var _displayMode = useState("single"),
          displayMode = _displayMode[0],
          setDisplayMode = _displayMode[1];

        // Dual view panels (left and right)
        var _dualPanels = useState(["timeline", "traces"]),
          dualPanels = _dualPanels[0],
          setDualPanels = _dualPanels[1];

        // Per-view AUTO scale state
        var _autoScales = useState({
            timeline: false,
            fft: false,
            traces: true,
            fnirs: false,
            ppg: false,
            imu: false,
          }),
          autoScales = _autoScales[0],
          setAutoScales = _autoScales[1];
        var _yAxisRanges = useState({
            timeline: 100,
            fft: 100,
            traces: 100,
            fnirs: 100,
            ppg: 100,
            imu: 100,
          }),
          yAxisRanges = _yAxisRanges[0],
          setYAxisRanges = _yAxisRanges[1];

        // DSP state (independent toggles)
        var _dspCAR = useState(true),
          dspCAR = _dspCAR[0],
          setDspCAR = _dspCAR[1];
        var _dspNotch = useState(true),
          dspNotch = _dspNotch[0],
          setDspNotch = _dspNotch[1];
        var _dspBandpass = useState(true),
          dspBandpass = _dspBandpass[0],
          setDspBandpass = _dspBandpass[1];

        // Device & Voltage Scaling
        var _deviceModel = useState("Muse 2"),
          deviceModel = _deviceModel[0],
          setDeviceModel = _deviceModel[1];
        var _inputFormat = useState("auto"),
          inputFormat = _inputFormat[0],
          setInputFormat = _inputFormat[1];

        // Baseline state
        var _baseLog = useState(false),
          baseLog = _baseLog[0],
          setBaseLog = _baseLog[1];
        var _baseNorm = useState(false),
          baseNorm = _baseNorm[0],
          setBaseNorm = _baseNorm[1];

        var _sim = useState(false),
          simMode = _sim[0],
          setSimMode = _sim[1];
        var _oscSending = useState(false),
          oscSending = _oscSending[0],
          setOscSending = _oscSending[1];
        var _baseLog = useState(false),
          baseLog = _baseLog[0],
          setBaseLog = _baseLog[1];
        var _baseNorm = useState(false),
          baseNorm = _baseNorm[0],
          setBaseNorm = _baseNorm[1];
        var _baselineStatus = useState(null),
          baselineStatus = _baselineStatus[0],
          setBaselineStatus = _baselineStatus[1];

        // Scientific display controls
        var _viewMode = useState("quad"),
          viewMode = _viewMode[0],
          setViewMode = _viewMode[1];
        var _activeChs = useState([0, 1, 2, 3]),
          activeChannels = _activeChs[0],
          setActiveChannels = _activeChs[1];
        var _timeWindow = useState(4),
          timeWindow = _timeWindow[0],
          setTimeWindow = _timeWindow[1];
        var _ampRange = useState(100),
          ampRange = _ampRange[0],
          setAmpRange = _ampRange[1];
        var _ampAuto = useState(true),
          ampAuto = _ampAuto[0],
          setAmpAuto = _ampAuto[1];
        var _showGrid = useState(true),
          showGrid = _showGrid[0],
          setShowGrid = _showGrid[1];

        // Band selection toggles (Delta, Theta, Alpha, Beta, Gamma)
        var _bandToggles = useState({
            delta: true,
            theta: true,
            alpha: true,
            beta: true,
            gamma: true,
          }),
          bandToggles = _bandToggles[0],
          setBandToggles = _bandToggles[1];

        // fNIRS channel toggles (HbO, HbR, HbT)
        var _fnirsToggles = useState({
            HbO: true, // Oxygenated hemoglobin
            HbR: true, // Deoxygenated hemoglobin
            HbT: true, // Total hemoglobin
          }),
          fnirsToggles = _fnirsToggles[0],
          setFnirsToggles = _fnirsToggles[1];

        var _t = useState(0),
          time = _t[0],
          setTime = _t[1];
        var _ir = useState(false),
          isRec = _ir[0],
          setIsRec = _ir[1];
        var _rt = useState("eeg"),
          recType = _rt[0],
          setRecType = _rt[1];
        var _rf = useState(true),
          recFilt = _rf[0],
          setRecFilt = _rf[1];
        var _recs = useState([]),
          recs = _recs[0],
          setRecs = _recs[1];
        var _rb = useState([]),
          recBuf = _rb[0],
          setRecBuf = _rb[1];
        var _r0 = useState(0),
          recT0 = _r0[0],
          setRecT0 = _r0[1];
        var _pid = useState("none"),
