                      },
                    },
                    h(
                      "div",
                      null,
                      h(
                        "div",
                        { style: { fontSize: 11, fontWeight: 700 } },
                        "Send " + (oscFilt ? "Filtered" : "Raw") + " Data",
                      ),
                      h(
                        "div",
                        { style: { fontSize: 9, color: th.t3 } },
                        oscFilt
                          ? "Using: " +
                              (
                                PROCS.find(function (p) {
                                  return p.id === pid;
                                }) || {}
                              ).n
                          : "Bypassing all processing",
                      ),
                    ),
                    h(
                      "button",
                      {
                        onClick: function () {
                          setOscFilt(!oscFilt);
                        },
                        style: {
                          width: 34,
                          height: 18,
                          borderRadius: 9,
                          border: "none",
                          background: oscFilt ? th.gd : th.bd,
                          position: "relative",
                        },
                      },
                      h("div", {
                        style: {
                          width: 14,
                          height: 14,
                          borderRadius: 7,
                          background: "#fff",
                          position: "absolute",
                          top: 2,
                          left: oscFilt ? 18 : 2,
                          transition: "left .2s",
                          boxShadow: "0 1px 3px rgba(0,0,0,.3)",
                        },
                      }),
                    ),
                  ),

                  // ── Target Routing ──
                  h(
                    "div",
                    { style: { marginBottom: 12 } },
                    h(
                      "div",
                      {
                        style: {
                          fontSize: 9,
                          fontWeight: 700,
                          color: th.t2,
                          textTransform: "uppercase",
                          letterSpacing: ".05em",
                          marginBottom: 6,
                        },
                      },
                      "OSC Targets \u2014 Route to Multiple Apps",
                    ),
                    h(
                      "div",
                      {
                        style: {
                          display: "flex",
                          flexDirection: "column",
                          gap: 4,
                        },
                      },
                      oscTargets.map(function (tgt, ti) {
                        return h(
                          "div",
                          {
                            key: ti,
                            style: {
                              display: "flex",
                              alignItems: "center",
                              gap: 8,
                              padding: "6px 10px",
                              borderRadius: 8,
                              background: tgt.enabled ? th.ac + "08" : th.sg,
                              border:
                                "1px solid " +
                                (tgt.enabled ? th.ac + "30" : th.bd),
                            },
                          },
                          // Enable toggle
                          h(
                            "button",
                            {
                              onClick: function () {
                                setOscTargets(function (p) {
                                  var n = p.slice();
                                  n[ti] = Object.assign({}, n[ti], {
                                    enabled: !n[ti].enabled,
                                  });
                                  return n;
                                });
                              },
                              style: {
                                width: 30,
                                height: 16,
                                borderRadius: 8,
                                border: "none",
                                background: tgt.enabled ? th.gd : th.bd,
                                position: "relative",
                                flexShrink: 0,
                              },
                            },
                            h("div", {
                              style: {
                                width: 12,
                                height: 12,
                                borderRadius: 6,
                                background: "#fff",
                                position: "absolute",
                                top: 2,
                                left: tgt.enabled ? 16 : 2,
                                transition: "left .2s",
                              },
                            }),
                          ),
                          // Name
                          h(
                            "span",
                            {
                              style: {
                                fontSize: 10,
                                fontWeight: 700,
                                color: tgt.enabled ? th.tx : th.t3,
                                minWidth: 100,
                              },
                            },
                            tgt.name,
                          ),
                          // Port input
                          h(
                            "span",
                            { style: { fontSize: 8, color: th.t3 } },
                            ":",
                          ),
                          h("input", {
                            value: tgt.port,
                            onChange: function (e) {
                              setOscTargets(function (p) {
                                var n = p.slice();
                                n[ti] = Object.assign({}, n[ti], {
                                  port: e.target.value,
                                });
                                return n;
                              });
                            },
                            style: {
                              width: 50,
                              padding: "2px 5px",
                              borderRadius: 4,
                              border: "1px solid " + th.bd,
                              background: th.sg,
                              color: th.tx,
                              fontSize: 9,
                              fontFamily: M,
                              textAlign: "center",
                            },
                          }),
                          // Mode selector
                          h(
                            "select",
                            {
                              value: tgt.mode,
                              onChange: function (e) {
                                setOscTargets(function (p) {
                                  var n = p.slice();
                                  n[ti] = Object.assign({}, n[ti], {
                                    mode: e.target.value,
                                  });
                                  return n;
                                });
                              },
                              style: {
                                padding: "2px 4px",
                                borderRadius: 4,
                                border: "1px solid " + th.bd,
                                background: th.sg,
                                color: th.tx,
                                fontSize: 8,
                                fontFamily: M,
                              },
                            },
                            h("option", { value: "A" }, "Mode A (Muse/Csound)"),
                            h("option", { value: "B" }, "Mode B (Scalar/Max)"),
                          ),
                          // Status
                          tgt.enabled &&
                            oscSending &&
                            h(
                              "span",
                              {
                                style: {
                                  fontSize: 7,
                                  color: th.gd,
                                  fontWeight: 700,
                                  fontFamily: M,
                                },
                              },
                              "\u25CF LIVE",
                            ),
                        );
                      }),
                    ),
                    h(
                      "div",
                      {
                        style: { fontSize: 8, color: th.t3, marginTop: 6 },
                      },
                      'Mode A = /muse/elements/{band}_absolute with "ffff" (4 floats per message, Csound-compatible)',
                      h("br"),
                      "Mode B = /eeg/{electrode}/{band} with single float (Max/MSP, TouchDesigner, Unity-friendly)",
                    ),
                  ),

                  // Connection settings
                  h(
                    "div",
                    {
                      style: {
                        display: "grid",
                        gridTemplateColumns: "1fr 100px",
                        gap: 8,
                        marginBottom: 12,
                        alignItems: "end",
                      },
                    },
                    h(
                      "div",
                      null,
                      h(
                        "div",
                        {
                          style: {
                            fontSize: 9,
                            color: th.t3,
                            fontWeight: 700,
                            textTransform: "uppercase",
                            letterSpacing: ".05em",
                            marginBottom: 3,
                          },
                        },
                        "Default Host",
                      ),
                      h(
                        "div",
                        {
                          style: {
                            padding: "5px 8px",
                            borderRadius: 6,
                            background: th.sg,
                            border: "1px solid " + th.bd,
                            fontSize: 10,
                            fontFamily: M,
                            color: th.tx,
                          },
                        },
                        "127.0.0.1",
                      ),
                    ),
                    h(
                      "div",
                      null,
                      h(
                        "div",
                        {
                          style: {
                            fontSize: 9,
                            color: th.t3,
                            fontWeight: 700,
                            textTransform: "uppercase",
                            letterSpacing: ".05em",
                            marginBottom: 3,
                          },
                        },
                        "Default Port",
                      ),
                      h("input", {
                        value: oscPort,
                        onChange: function (e) {
                          setOscPort(e.target.value);
                        },
                        style: {
                          padding: "5px 8px",
                          borderRadius: 6,
                          background: th.wr + "15",
                          border: "1px solid " + th.wr + "40",
                          fontSize: 10,
                          fontFamily: M,
                          color: th.wr,
                          fontWeight: 700,
                          width: "100%",
                          textAlign: "center",
                        },
                      }),
                    ),
                  ),

                  // Runtime status
                  h(
                    "div",
                    {
                      style: {
                        padding: "8px 10px",
                        borderRadius: 6,
                        background:
                          bridgeStatus === "server"
                            ? th.gd + "08"
                            : "#f59e0b10",
                        border:
                          "1px solid " +
                          (bridgeStatus === "server"
                            ? th.gd + "30"
                            : "#f59e0b30"),
                        marginBottom: 12,
                      },
                    },
                    bridgeStatus === "server"
                      ? h(
                          "div",
                          null,
                          h(
                            "div",
                            {
                              style: {
                                fontSize: 9,
                                fontWeight: 700,
                                color: th.gd,
                                marginBottom: 2,
                              },
                            },
                            "\u2713 Python Backend Connected \u2014 Real UDP OSC via python-osc",
                          ),
                          h(
                            "div",
                            { style: { fontSize: 8, color: th.t3 } },
                            "OSC packets sent by the backend to your configured targets.",
                          ),
                        )
                      : h(
                          "div",
                          null,
                          h(
                            "div",
                            {
                              style: {
                                fontSize: 9,
                                fontWeight: 700,
                                color: "#f59e0b",
                                marginBottom: 4,
                              },
                            },
                            "Standalone Mode \u2014 No OSC Output",
                          ),
                          h(
                            "div",
                            {
                              style: {
                                fontSize: 8,
                                color: th.t3,
                                lineHeight: 1.7,
                              },
                            },
                            "For real OSC to Csound/Max, use one of:",
                            h("br"),
                            h("br"),
                            h("b", null, "Option A: Electron app"),
                            " (recommended, no dependencies)",
                            h("br"),
                            h(
                              "span",
                              { style: { fontFamily: M, color: th.ac } },
                              "npm install && npm start",
                            ),
                            h("br"),
                            h("br"),
                            h("b", null, "Option B: Python server"),
                            " (uses a virtual environment to avoid PEP 668 conflicts)",
                            h("br"),
                            h(
                              "span",
                              { style: { fontFamily: M, color: th.ac } },
                              "python3 -m venv .venv && source .venv/bin/activate",
                            ),
                            h("br"),
                            h(
                              "span",
                              { style: { fontFamily: M, color: th.ac } },
                              "pip install fastapi uvicorn python-osc",
                            ),
                            h("br"),
                            h(
                              "span",
                              { style: { fontFamily: M, color: th.ac } },
                              "python neurovis-server.py",
                            ),
                            h("br"),
                            h(
                              "span",
                              {
                                style: {
                                  fontSize: 7,
                                  color: th.t3,
                                  fontStyle: "italic",
                                },
                              },
                              "On Windows: .venv\\Scripts\\activate instead of source .venv/bin/activate",
                            ),
                            h("br"),
                            h("br"),
                            "The OSC Monitor shows what ",
                            h("i", null, "would"),
                            " be sent.",
                          ),
                        ),
                  ),

                  // Stream rate
                  h(
                    "div",
                    { style: { marginBottom: 12 } },
                    h(
                      "div",
                      {
                        style: {
                          fontSize: 9,
                          fontWeight: 700,
                          color: th.t2,
                          textTransform: "uppercase",
                          letterSpacing: ".05em",
                          marginBottom: 4,
                        },
                      },
                      "Stream Rate & Smoothing",
                    ),
                    h(
                      "div",
                      {
                        style: {
                          display: "flex",
                          alignItems: "center",
                          gap: 6,
                          marginBottom: 6,
                        },
                      },
                      h(
                        "span",
                        { style: { fontSize: 9, color: th.t2, width: 80 } },
                        "Send Rate",
                      ),
                      h(
                        "select",
                        {
                          value: oscRate,
                          onChange: function (e) {
                            setOscRate(e.target.value);
                          },
                          style: {
                            padding: "3px 6px",
                            borderRadius: 5,
                            border: "1px solid " + th.bd,
                            background: th.sg,
                            color: th.tx,
                            fontSize: 9,
                            fontFamily: M,
                          },
                        },
                        h(
                          "option",
                          { value: "10" },
                          "10 Hz (Mind Monitor default)",
                        ),
                        h("option", { value: "20" }, "20 Hz"),
                        h("option", { value: "30" }, "30 Hz"),
                        h("option", { value: "60" }, "60 Hz (fast)"),
                      ),
                    ),
                    h(
                      "div",
                      {
                        style: {
                          display: "flex",
                          alignItems: "center",
                          gap: 6,
                        },
                      },
                      h(
                        "span",
                        { style: { fontSize: 9, color: th.t2, width: 80 } },
                        "OSC Smooth",
                      ),
                      h("input", {
                        type: "range",
                        min: 0.01,
                        max: 0.5,
                        step: 0.01,
                        value: oscSmooth,
                        onChange: function (e) {
                          setOscSmooth(+e.target.value);
                        },
                        style: { flex: 1, accentColor: th.ac },
                      }),
                      h(
                        "span",
                        {
                          style: {
                            fontSize: 9,
                            color: th.ac,
                            fontFamily: M,
                            minWidth: 30,
                          },
                        },
                        oscSmooth.toFixed(2),
                      ),
                    ),
                    h(
                      "div",
                      {
                        style: { fontSize: 8, color: th.t3, marginTop: 3 },
                      },
                      "Mind Monitor sends at 10 Hz. Lower smooth = less jitter, slower response.",
                    ),
                    h(
                      "div",
                      {
                        style: {
                          display: "flex",
                          alignItems: "center",
                          gap: 6,
                          marginTop: 6,
                        },
                      },
                      h(
                        "span",
                        { style: { fontSize: 9, color: th.t2, width: 80 } },
                        "OSC Scale",
                      ),
                      h("input", {
                        type: "range",
                        min: 0.1,
                        max: 5.0,
                        step: 0.1,
                        value: oscScale,
                        onChange: function (e) {
                          setOscScale(+e.target.value);
                        },
                        style: { flex: 1, accentColor: th.wr },
                      }),
                      h(
                        "span",
                        {
                          style: {
                            fontSize: 9,
                            color: th.wr,
                            fontFamily: M,
                            minWidth: 30,
                          },
                        },
                        oscScale.toFixed(1) + "x",
                      ),
                    ),
                    h(
                      "div",
                      {
                        style: { fontSize: 8, color: th.t3, marginTop: 2 },
                      },
                      "Scale multiplier for OSC output values. 1.0x = log10(\u00B5V\u00B2/Hz) matching Mind Monitor. Increase for Csound cpspch mapping.",
                    ),
                  ),

                  // Selective band streaming
                  h(
                    "div",
                    { style: { marginBottom: 12 } },
                    h(
                      "div",
                      {
                        style: {
                          fontSize: 9,
                          fontWeight: 700,
                          color: th.t2,
                          textTransform: "uppercase",
                          letterSpacing: ".05em",
                          marginBottom: 4,
                        },
                      },
                      "Select Streams to Send",
                    ),
                    h(
                      "div",
                      {
                        style: {
                          display: "flex",
                          flexWrap: "wrap",
                          gap: 3,
                        },
                      },
                      BANDS.map(function (b) {
                        var on = oscBands.indexOf(b.n) >= 0,
                          c = th === TH.dark ? b.d : b.c;
                        return h(Pill, {
                          key: b.n,
                          on: on,
                          fn: function () {
                            setOscBands(function (p) {
                              return on
                                ? p.filter(function (x) {
                                    return x !== b.n;
                                  })
                                : p.concat([b.n]);
                            });
                          },
                          c: c,
                          t: th,
                          label: b.n + " absolute",
                        });
                      }),
                    ),
                    h(
                      "div",
                      {
                        style: {
                          display: "flex",
                          flexWrap: "wrap",
                          gap: 3,
                          marginTop: 4,
                        },
                      },
                      BANDS.map(function (b) {
                        var key = b.n + "_rel";
                        var on = oscExtras.indexOf(key) >= 0;
                        var c = th === TH.dark ? b.d : b.c;
                        return h(Pill, {
                          key: key,
                          on: on,
                          fn: function () {
                            setOscExtras(function (p) {
                              return on
                                ? p.filter(function (x) {
                                    return x !== key;
                                  })
                                : p.concat([key]);
                            });
                          },
                          c: c,
                          t: th,
                          label: b.n + " relative",
                        });
                      }),
                    ),
                    h(
                      "div",
                      {
                        style: {
                          display: "flex",
                          flexWrap: "wrap",
                          gap: 3,
                          marginTop: 4,
                        },
                      },
                      [
                        { k: "eeg", l: "Raw EEG" },
                        { k: "quality", l: "Quality" },
                        { k: "gate", l: "Gate" },
                        { k: "trigger", l: "Trigger" },
                      ]
                        .concat(
                          hasAux("imu")
                            ? [
                                { k: "acc", l: "Accelerometer" },
                                { k: "gyro", l: "Gyroscope" },
                              ]
                            : [],
                          hasAux("ppg") ? [{ k: "ppg", l: "PPG/HR" }] : [],
                          hasAux("fnirs") ? [{ k: "fnirs", l: "fNIRS" }] : [],
                        )
                        .map(function (p) {
                          var on = oscExtras.indexOf(p.k) >= 0;
                          return h(Pill, {
                            key: p.k,
                            on: on,
                            fn: function () {
                              setOscExtras(function (prev) {
                                return on
                                  ? prev.filter(function (x) {
                                      return x !== p.k;
                                    })
                                  : prev.concat([p.k]);
                              });
                            },
                            c: th.wr,
                            t: th,
                            label: p.l,
                          });
                        }),
                    ),
                    h(
                      "div",
