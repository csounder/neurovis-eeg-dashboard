          setPid = _pid[1];
        var _fp = useState({ a: 0.2, nf: 60, gt: 20, th: 30, hi: 40, lo: 20 }),
          fp = _fp[0],
          setFp = _fp[1];
        var _sb = useState(["Alpha", "Beta", "Theta"]),
          sBands = _sb[0],
          setSBands = _sb[1];
        var _sc = useState([]),
          sChs = _sc[0],
          setSChs = _sc[1];
        var _ao = useState({ fnirs: true, ppg: true, imu: true }),
          auxOn = _ao[0],
          setAuxOn = _ao[1];
        var _of = useState(true),
          oscFilt = _of[0],
          setOscFilt = _of[1];
        var _or = useState("20"),
          oscRate = _or[0],
          setOscRate = _or[1];
        var _os = useState(0.1),
          oscSmooth = _os[0],
          setOscSmooth = _os[1];
        var _osc2 = useState(1.0),
          oscScale = _osc2[0],
          setOscScale = _osc2[1];
        var _oc = useState([]),
          oscChs = _oc[0],
          setOscChs = _oc[1];
        var _ob = useState(["Alpha", "Beta", "Theta"]),
          oscBands = _ob[0],
          setOscBands = _ob[1];
        var _oe = useState(["quality"]),
          oscExtras = _oe[0],
          setOscExtras = _oe[1];
        var _oport = useState("7400"),
          oscPort = _oport[0],
          setOscPort = _oport[1];
        var _otgt = useState([
            { name: "Csound", port: "7400", enabled: true, mode: "A" },
            { name: "Max/MSP", port: "7400", enabled: false, mode: "B" },
            { name: "TouchDesigner", port: "7400", enabled: false, mode: "B" },
            { name: "Unity", port: "7400", enabled: false, mode: "B" },
            { name: "Ableton/Logic", port: "7400", enabled: false, mode: "B" },
          ]),
          oscTargets = _otgt[0],
          setOscTargets = _otgt[1];
        // OLD simple presets (keeping for backward compatibility)
        var _ps = useState([
            { n: "Clean EEG", p: "notch", f: { nf: 60 } },
            { n: "Smooth", p: "ema", f: { a: 0.15 } },
            { n: "Gate", p: "gate", f: { gt: 25 } },
          ]),
          presets = _ps[0],
          setPresets = _ps[1];

        // NEW Performance Presets (complete settings snapshots)
        var _perfPresets = useState([
            {
              name: "🎵 Meditation (Alpha+Theta)",
              id: "meditation",
              dsp: { car: true, notch: true, bandpass: true, smoothing: 15 },
              osc: {
                enabled: true,
                port: "7400",
                rate: "5",
                smoothing: 0.2,
                bands: ["Alpha", "Theta"],
                channels: [],
              },
              display: {
                view: "allbands",
                bandToggles: {
                  delta: false,
                  theta: true,
                  alpha: true,
                  beta: false,
                  gamma: false,
                },
              },
              calibration: { logTransform: false, zScore: true },
            },
            {
              name: "⚡ Focus (Beta+Gamma)",
              id: "focus",
              dsp: { car: true, notch: true, bandpass: true, smoothing: 5 },
              osc: {
                enabled: true,
                port: "7400",
                rate: "20",
                smoothing: 0.05,
                bands: ["Beta", "Gamma"],
                channels: [],
              },
              display: {
                view: "mentalstate",
                bandToggles: {
                  delta: false,
                  theta: false,
                  alpha: false,
                  beta: true,
                  gamma: true,
                },
              },
              calibration: { logTransform: false, zScore: true },
            },
            {
              name: "🌊 Full Spectrum",
              id: "fullspectrum",
              dsp: { car: true, notch: true, bandpass: true, smoothing: 10 },
              osc: {
                enabled: true,
                port: "7400",
                rate: "10",
                smoothing: 0.1,
                bands: ["Delta", "Theta", "Alpha", "Beta", "Gamma"],
                channels: [],
              },
              display: {
                view: "allbands",
                bandToggles: {
                  delta: true,
                  theta: true,
                  alpha: true,
                  beta: true,
                  gamma: true,
                },
              },
              calibration: { logTransform: false, zScore: false },
            },
          ]),
          perfPresets = _perfPresets[0],
          setPerfPresets = _perfPresets[1];

        var _activePreset = useState(null),
          activePreset = _activePreset[0],
          setActivePreset = _activePreset[1];

        // MIDI Control State
        var _midiDevices = useState([]),
          midiDevices = _midiDevices[0],
          setMidiDevices = _midiDevices[1];
        var _midiDevice = useState(null),
          midiDevice = _midiDevice[0],
          setMidiDevice = _midiDevice[1];
        var _midiMappings = useState({}), // { note/cc: presetId }
          midiMappings = _midiMappings[0],
          setMidiMappings = _midiMappings[1];
        var _midiLearn = useState(null), // presetId currently learning
          midiLearn = _midiLearn[0],
          setMidiLearn = _midiLearn[1];
        var _midiActivity = useState(null),
          midiActivity = _midiActivity[0],
          setMidiActivity = _midiActivity[1];
        var _midiLastTrigger = useState(0),
          midiLastTrigger = _midiLastTrigger[0],
          setMidiLastTrigger = _midiLastTrigger[1];

        // Audio Alert State
        var _audioAlerts = useState(false), // Default OFF (no beeping)
          audioAlerts = _audioAlerts[0],
          setAudioAlerts = _audioAlerts[1];
        var _op = useState([
            {
              n: "Csound \u2014 Alpha Only",
              target: "Csound",
              bands: ["Alpha"],
              extras: [],
              rate: "10",
              smooth: 0.1,
              filt: false,
              desc: 'Single alpha_absolute stream at 10Hz. Match with OSClisten "/muse/elements/alpha_absolute"',
            },
            {
              n: "Csound \u2014 All Bands",
              target: "Csound",
              bands: ["Delta", "Theta", "Alpha", "Beta", "Gamma"],
              extras: [],
              rate: "10",
              smooth: 0.1,
              filt: false,
              desc: "All 5 absolute bands. Uncomment one OSClisten at a time in your .csd",
            },
            {
              n: "Max/MSP \u2014 Full",
              target: "Max/MSP",
              bands: ["Alpha", "Beta", "Theta"],
              extras: ["acc", "gyro"],
              rate: "20",
              smooth: 0.05,
              filt: true,
              desc: "3 bands + IMU for Max. Use [udpreceive 7400] \u2192 [OSC-route]",
            },
            {
              n: "TouchDesigner",
              target: "TouchDesigner",
              bands: ["Alpha", "Beta", "Gamma"],
              extras: ["acc"],
              rate: "30",
              smooth: 0.08,
              filt: true,
              desc: "3 bands + accel at 30Hz. Use oscin CHOP, port 7400",
            },
            {
              n: "Unity \u2014 Responsive",
              target: "Unity",
              bands: ["Alpha", "Beta"],
              extras: ["acc", "gyro"],
              rate: "60",
              smooth: 0.02,
              filt: true,
              desc: "2 bands + IMU at 60Hz. Low latency for game control",
            },
            {
              n: "Ableton/Logic \u2014 Slow",
              target: "Ableton",
              bands: ["Alpha", "Theta"],
              extras: [],
              rate: "10",
              smooth: 0.3,
              filt: true,
              desc: "2 bands, heavily smoothed for slow modulation. Use Max for Live OSC Receive",
            },
          ]),
          oscPresets = _op[0],
          setOscPresets = _op[1];
        var aRef = useRef(),
          t0 = useRef();

        var th = TH[theme],
          d = DEVS[dev] || DEVS["muse_s"],
          skin = SKINS[si];
        var _bs = useState("checking"),
          bridgeStatus = _bs[0],
          setBridgeStatus = _bs[1];

        useEffect(
          function () {
            if (!d || !d.eeg) return;
            setSChs(
              d.eeg.map(function (e) {
                return e.id;
              }),
            );
            setOscChs(
              d.eeg.map(function (e) {
                return e.id;
              }),
            );
          },
          [dev],
        );
        useEffect(
          function () {
            window._nv_signal = simMode || !!paired;
          },
          [simMode, paired],
        );
        useEffect(
          function () {
            _oscScale = oscScale;
          },
          [oscScale],
        );
        useEffect(function () {
          var tick = function (ts) {
            if (!t0.current) t0.current = ts;
            setTime((ts - t0.current) / 1000);
            aRef.current = requestAnimationFrame(tick);
          };
          aRef.current = requestAnimationFrame(tick);
          return function () {
            cancelAnimationFrame(aRef.current);
          };
        }, []);

        // ── Detect runtime: check if NeurOSC Python backend is running ──
        useEffect(function () {
          fetch("/api/status")
            .then(function (r) {
              return r.json();
            })
            .then(function (j) {
              setBridgeStatus("server");
              console.log("[NeuroVis] Backend detected:", j);
            })
            .catch(function () {
              setBridgeStatus("standalone");
              console.log("[NeuroVis] No backend — standalone/simulator mode");
            });
        }, []);

        // ── Poll baseline status when Z-Score is enabled ──
        useEffect(
          function () {
            if (!baseNorm) {
              // If Z-Score is off, reset status
              setBaselineStatus({
                ready: false,
                sampleCounts: { CH1: 0, CH2: 0, CH3: 0, CH4: 0 },
              });
              return;
            }
            // Poll every 1 second while Z-Score is enabled
            var interval = setInterval(function () {
              fetch("/api/baseline/status")
                .then(function (r) {
                  return r.json();
                })
                .then(function (data) {
                  setBaselineStatus(data);
                })
                .catch(function (e) {
                  console.error("[NeuroVis] Baseline status fetch error:", e);
                });
            }, 1000);
            // Initial fetch
            fetch("/api/baseline/status")
              .then(function (r) {
                return r.json();
              })
              .then(function (data) {
                setBaselineStatus(data);
              })
              .catch(function (e) {
                console.error("[NeuroVis] Baseline status fetch error:", e);
              });
            return function () {
              clearInterval(interval);
            };
          },
          [baseNorm],
        );

        // ── OSC sending — configure via NeurOSC backend API ──
        var _oscMounted = useRef(false);
        useEffect(
          function () {
            if (!_oscMounted.current) {
              _oscMounted.current = true;
              if (!oscSending) return;
            } // skip disable on mount
            if (!oscSending) {
              console.log("[NeuroVis] OSC: disabling");
              fetch("/api/osc_config", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                  ip: "127.0.0.1",
                  port: parseInt(oscPort) || 7400,
                  enabled: false,
                  send_raw: false,
                  send_bands: false,
                }),
              }).catch(function (e) {
                console.error("[NeuroVis] OSC config error:", e);
              });
              return;
            }
            console.log("[NeuroVis] OSC: enabling on port", oscPort);
            fetch("/api/osc_config", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                ip: "127.0.0.1",
                port: parseInt(oscPort) || 7400,
                enabled: true,
                send_raw: true,
                send_bands: true,
              }),
            })
              .then(function (r) {
                return r.json();
              })
              .then(function (j) {
                console.log("[NeuroVis] OSC config response:", j);
              })
              .catch(function (e) {
                console.error("[NeuroVis] OSC config error:", e);
              });
            // Configure granular settings
            fetch("/api/osc_granular", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                bands: oscBands.map(function (b) {
                  return b.toLowerCase();
                }),
                send_absolute: true,
                send_relative: true,
                send_averages: true,
              }),
            }).catch(function () {});
            return function () {
              fetch("/api/osc_config", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ enabled: false }),
              }).catch(function () {});
            };
          },
          [oscSending, oscPort, oscBands],
        );

        // ══════════════════════════════════════════════════════════════
        // PERFORMANCE PRESET FUNCTIONS
        // ══════════════════════════════════════════════════════════════

        function saveCurrentAsPreset(name) {
          var newPreset = {
            name: name,
            id: Date.now().toString(),
            created: new Date().toISOString(),
            dsp: {
              car: dspCAR,
              notch: dspNotch,
              bandpass: dspBandpass,
              smoothing: 10, // TODO: get from backend
            },
            osc: {
              enabled: oscSending,
              port: oscPort,
              rate: oscRate,
              smoothing: oscSmooth,
              bands: oscBands,
              channels: oscChs,
            },
            display: {
              view: view,
              bandToggles: Object.assign({}, bandToggles),
              autoScales: Object.assign({}, autoScales),
              yAxisRanges: Object.assign({}, yAxisRanges),
            },
            calibration: {
              logTransform: baseLog,
              zScore: baseNorm,
            },
          };

          setPerfPresets(function (prev) {
            return prev.concat([newPreset]);
          });

          setActivePreset(newPreset.id);

          // Save to localStorage
          try {
            var allPresets = perfPresets.concat([newPreset]);
            localStorage.setItem(
              "neurovis_performance_presets",
              JSON.stringify(allPresets),
            );
          } catch (e) {
            console.error("[Presets] LocalStorage save failed:", e);
          }

          return newPreset;
        }

        function loadPreset(preset) {
          // DSP settings
          setDspCAR(preset.dsp.car);
          setDspNotch(preset.dsp.notch);
          setDspBandpass(preset.dsp.bandpass);

          // Send DSP config to backend
          fetch("/api/dsp/config", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              applyCAR: preset.dsp.car,
              applyNotch: preset.dsp.notch,
              applyBandpass: preset.dsp.bandpass,
              smoothingAmount: preset.dsp.smoothing || 10,
            }),
          });

          // OSC settings
          setOscSending(preset.osc.enabled);
          setOscPort(preset.osc.port);
          setOscRate(preset.osc.rate);
          setOscSmooth(preset.osc.smoothing);
          setOscBands(preset.osc.bands);
          setOscChs(preset.osc.channels || []);

          // Display settings
          setView(preset.display.view);
          setBandToggles(preset.display.bandToggles);
          setAutoScales(
            Object.assign({}, autoScales, preset.display.autoScales),
          );
          setYAxisRanges(
            Object.assign({}, yAxisRanges, preset.display.yAxisRanges),
          );

          // Calibration settings
          setBaseLog(preset.calibration.logTransform);
          setBaseNorm(preset.calibration.zScore);

          // Send calibration to backend
          fetch("/api/settings", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              logTransform: preset.calibration.logTransform,
              applyBaseline: preset.calibration.zScore,
            }),
          });

          setActivePreset(preset.id);
          console.log("[Presets] Loaded:", preset.name);
        }

        function exportPreset(preset) {
          var json = JSON.stringify(preset, null, 2);
          var blob = new Blob([json], { type: "application/json" });
          var url = URL.createObjectURL(blob);
          var a = document.createElement("a");
          a.href = url;
          a.download = "neurovis_preset_" + preset.id + ".json";
          a.click();
          URL.revokeObjectURL(url);
        }

        function importPreset(fileContent) {
          try {
            var preset = JSON.parse(fileContent);
            setPerfPresets(function (prev) {
              return prev.concat([preset]);
            });
            // Save to localStorage
            localStorage.setItem(
              "neurovis_performance_presets",
              JSON.stringify(perfPresets.concat([preset])),
            );
            console.log("[Presets] Imported:", preset.name);
          } catch (e) {
            console.error("[Presets] Import failed:", e);
            alert("Invalid preset file");
          }
        }

        function deletePreset(presetId) {
          setPerfPresets(function (prev) {
            return prev.filter(function (p) {
              return p.id !== presetId;
            });
          });
          if (activePreset === presetId) {
            setActivePreset(null);
          }
          // Update localStorage
          var updated = perfPresets.filter(function (p) {
            return p.id !== presetId;
          });
          localStorage.setItem(
            "neurovis_performance_presets",
            JSON.stringify(updated),
          );
        }

        function renamePreset(presetId, newName) {
          setPerfPresets(function (prev) {
            return prev.map(function (p) {
              if (p.id === presetId) {
                return Object.assign({}, p, { name: newName });
              }
              return p;
            });
          });
          // Update localStorage
          var updated = perfPresets.map(function (p) {
            if (p.id === presetId)
              return Object.assign({}, p, { name: newName });
            return p;
          });
          localStorage.setItem(
            "neurovis_performance_presets",
            JSON.stringify(updated),
          );
        }

        // Keyboard shortcuts (1-9 for presets)
        useEffect(
          function () {
            function handleKeyPress(e) {
              // Only trigger if not typing in an input
              if (
                e.target.tagName === "INPUT" ||
                e.target.tagName === "TEXTAREA"
              )
                return;

              var num = parseInt(e.key);
              if (num >= 1 && num <= 9) {
                var presetIndex = num - 1;
                if (perfPresets[presetIndex]) {
                  loadPreset(perfPresets[presetIndex]);
                }
              }
            }

            window.addEventListener("keypress", handleKeyPress);
            return function () {
              window.removeEventListener("keypress", handleKeyPress);
            };
          },
          [perfPresets],
        );

        // Load from localStorage on mount
        useEffect(function () {
          try {
            var saved = localStorage.getItem("neurovis_performance_presets");
            if (saved) {
              var loaded = JSON.parse(saved);
              setPerfPresets(loaded);
              console.log(
                "[Presets] Loaded",
                loaded.length,
                "presets from localStorage",
              );
            }
          } catch (e) {
            console.error("[Presets] LocalStorage load failed:", e);
          }
        }, []);

        // ══════════════════════════════════════════════════════════════
        // MIDI CONTROL SYSTEM (Foot Pedals, Controllers)
        // ══════════════════════════════════════════════════════════════

        // Initialize Web MIDI API
        useEffect(function () {
          if (!navigator.requestMIDIAccess) {
            console.log("[MIDI] Web MIDI API not supported");
            return;
          }

          navigator
            .requestMIDIAccess()
            .then(function (midiAccess) {
              console.log("[MIDI] Access granted");

              // Get available MIDI inputs
              var inputs = [];
              var iter = midiAccess.inputs.values();
              for (var input = iter.next(); !input.done; input = iter.next()) {
                inputs.push(input.value);
              }

              setMidiDevices(inputs);
              console.log("[MIDI] Found", inputs.length, "input devices");

              // Auto-select first device
              if (inputs.length > 0) {
                setMidiDevice(inputs[0].id);
                setupMidiListeners(inputs[0]);
              }

              // Listen for device connect/disconnect
              midiAccess.onstatechange = function (e) {
                var inputs = [];
                var iter = midiAccess.inputs.values();
                for (
                  var input = iter.next();
                  !input.done;
                  input = iter.next()
                ) {
                  inputs.push(input.value);
                }
                setMidiDevices(inputs);
              };
            })
            .catch(function (err) {
              console.error("[MIDI] Access denied:", err);
            });

          // Load MIDI mappings from localStorage
          try {
            var savedMappings = localStorage.getItem("neurovis_midi_mappings");
            if (savedMappings) {
              setMidiMappings(JSON.parse(savedMappings));
              console.log("[MIDI] Loaded mappings from localStorage");
            }
          } catch (e) {
            console.error("[MIDI] Mappings load failed:", e);
          }
        }, []);

        // Setup MIDI listeners for selected device
        function setupMidiListeners(input) {
          input.onmidimessage = function (message) {
            var cmd = message.data[0] >> 4;
            var channel = message.data[0] & 0xf;
            var noteOrCC = message.data[1];
            var velocity = message.data[2];

            // Note On (0x9) or CC (0xB)
            if ((cmd === 9 && velocity > 0) || cmd === 11) {
              var midiKey = (cmd === 9 ? "note" : "cc") + noteOrCC;

              console.log(
                "[MIDI] Message:",
                cmd === 9 ? "Note" : "CC",
                noteOrCC,
                "velocity:",
                velocity,
              );

              // MIDI Learn mode
              if (midiLearn) {
                var newMappings = Object.assign({}, midiMappings);
                newMappings[midiKey] = midiLearn;
                setMidiMappings(newMappings);
                setMidiLearn(null);

                // Save to localStorage
                localStorage.setItem(
                  "neurovis_midi_mappings",
                  JSON.stringify(newMappings),
                );

                console.log("[MIDI] Learned:", midiKey, "→ preset", midiLearn);

                // Flash briefly on learn
                setMidiActivity({ type: "learned", noteOrCC: noteOrCC });
                setTimeout(function () {
                  setMidiActivity(null);
                }, 500);

                return;
              }

              // Check if mapped to a preset
              var presetId = midiMappings[midiKey];
              if (presetId) {
                var preset = perfPresets.find(function (p) {
                  return p.id === presetId;
                });
                if (preset) {
                  console.log("[MIDI] Triggering preset:", preset.name);
                  loadPreset(preset);

                  // Flash briefly when preset triggered
                  setMidiActivity({ type: "preset", name: preset.name });
                  setMidiLastTrigger(Date.now());
                  setTimeout(function () {
                    setMidiActivity(null);
                  }, 800);
                }
              }
            }
          };
        }

        // Update listeners when device changes
        useEffect(
          function () {
            if (!midiDevice || midiDevices.length === 0) return;

            var device = midiDevices.find(function (d) {
              return d.id === midiDevice;
            });
            if (device) {
              setupMidiListeners(device);
              console.log("[MIDI] Listening to:", device.name);
            }
          },
          [midiDevice, midiDevices, midiMappings, midiLearn, perfPresets],
        );

        function clearMidiMapping(midiKey) {
          var newMappings = Object.assign({}, midiMappings);
          delete newMappings[midiKey];
          setMidiMappings(newMappings);
          localStorage.setItem(
            "neurovis_midi_mappings",
            JSON.stringify(newMappings),
          );
        }

        useEffect(
          function () {
            if (!isRec || !d) return;
            var snap = {};
            if (recType === "eeg")
              d.eeg.forEach(function (e) {
                snap[e.id] = eeg(time, e.id, 0, usedPid, usedFp);
              });
            else if (d.aux && d.aux[recType])
              d.aux[recType].ch.forEach(function (c) {
                snap[c] = simAux(time, c);
              });
            setRecBuf(function (p) {
              return p.concat([{ t: time - (recT0 || time), v: snap }]);
            });
          },
          [isRec, Math.floor(time * 4)],
        );

        function toggleRec() {
          if (isRec) {
            var chs = recBuf.length ? Object.keys(recBuf[0].v) : [];
            setRecs(function (p) {
              return p.concat([
                {
                  id: Date.now(),
                  ts: new Date().toLocaleTimeString(),
                  dur: (time - recT0).toFixed(1),
                  smp: recBuf.length,
                  data: recBuf,
                  type: recType,
                  chs: chs,
                  filt: recFilt,
                  pn:
                    (
                      PROCS.find(function (x) {
                        return x.id === pid;
                      }) || {}
                    ).n || "Bypass",
                },
              ]);
            });
            setRecBuf([]);
            setIsRec(false);
          } else {
            setRecT0(time);
            setRecBuf([]);
            setIsRec(true);
          }
        }

        function hasAux(k) {
          return !!(d && d.aux && d.aux[k]) && auxOn[k] !== false;
        }

        // Display IDs available for quad view - REORGANIZED with NeurOSC additions
        var displayOpts = [
          { id: "timeline", l: "1. Power + Timeline" },
          { id: "fft", l: "2. FFT + Bands" },
          { id: "waterfall", l: "3. 3D Waterfall" },
          { id: "traces", l: "4. Traces (NeurOSC)" },
          // { id: "spectrum", l: "5. FFT Spectrum" }, // DISABLED - Uses fake FFT data (scientifically invalid)
          { id: "bands", l: "5. Band Powers" },
          { id: "mentalstate", l: "7. Mental State" },
          { id: "calibration", l: "8. 📊 CALIBRATION" },
          { id: "neuro", l: "9. Neuro Indices" },
          { id: "phase", l: "10. Phase" },
          { id: "coherence", l: "11. Coherence" },
        ].concat(
          hasAux("ppg") ? [{ id: "ppg", l: "12. PPG/HR-Muse" }] : [],
          hasAux("imu") ? [{ id: "imu", l: "13. IMU-Muse" }] : [],
          hasAux("fnirs") ? [{ id: "fnirs", l: "14. fNIRS-Athena" }] : [],
          [
            { id: "connect", l: "15. Sensor Connect" },
            { id: "processing", l: "16. DSP Processing" },
            { id: "presets", l: "17. Presets" },
            { id: "osc", l: "18. OSC Settings" },
            { id: "oscmon", l: "19. OSC Monitor" },
            { id: "recs", l: "20. Recording" },
            { id: "topo", l: "Topo Map" },
            { id: "fullbrain", l: "Full Brain" },
          ],
        );

        // ── OSC Live Monitor ──
        function OSCMonitor() {
          var usedPid = oscFilt ? pid : "none",
            usedFp = oscFilt ? fp : {};
          // Build live message list
          var msgs = [];
          // Muse protocol (Mode A)
          oscBands.forEach(function (bn) {
            var bIdx = BANDS.findIndex(function (b) {
              return b.n === bn;
            });
            if (bIdx < 0) return;
            var vals = d.eeg.map(function (el) {
              return bpowOSC(time, el.id, bIdx, usedPid, usedFp).toFixed(3);
            });
            msgs.push({
              addr: "/muse/elements/" + bn.toLowerCase() + "_absolute",
              tag: '"' + "f".repeat(d.ch) + '"',
              vals: vals.join("  "),
              mode: "A",
            });
          });
          oscExtras.forEach(function (ex) {
            if (ex.indexOf("_rel") > 0) {
              var bn = ex.replace("_rel", "");
              var bIdx = BANDS.findIndex(function (b) {
                return b.n === bn;
              });
              if (bIdx < 0) return;
              var vals = d.eeg.map(function (el) {
                var tot = 0;
                for (var i = 0; i < 5; i++)
                  tot += bpowAbs(time, el.id, i, usedPid, usedFp);
                return (
                  tot > 0
                    ? bpowAbs(time, el.id, bIdx, usedPid, usedFp) / tot
                    : 0
                ).toFixed(3);
              });
              msgs.push({
                addr: "/muse/elements/" + bn.toLowerCase() + "_relative",
                tag: '"' + "f".repeat(d.ch) + '"',
                vals: vals.join("  "),
                mode: "A",
              });
            }
            if (ex === "acc")
              msgs.push({
                addr: "/muse/acc",
                tag: '"fff"',
                vals: [
                  simAux(time, "AccX").toFixed(2),
                  simAux(time, "AccY").toFixed(2),
                  simAux(time, "AccZ").toFixed(2),
                ].join("  "),
                mode: "A",
              });
            if (ex === "gyro")
              msgs.push({
                addr: "/muse/gyro",
                tag: '"fff"',
                vals: [
                  simAux(time, "GyroX").toFixed(1),
                  simAux(time, "GyroY").toFixed(1),
                  simAux(time, "GyroZ").toFixed(1),
                ].join("  "),
                mode: "A",
              });
            if (ex === "ppg")
              msgs.push({
                addr: "/ppg/hr",
                tag: '"f"',
                vals: simAux(time, "PPG1").toFixed(1),
                mode: "B",
              });
            if (ex === "eeg") {
              var vals2 = d.eeg.map(function (el) {
                return eeg(time, el.id, 2, usedPid, usedFp).toFixed(1);
              });
              msgs.push({
                addr: "/muse/eeg",
                tag: '"' + "f".repeat(Math.max(d.ch, 4) + 2) + '"',
                vals: vals2.join("  ") + " 0.0 0.0",
                mode: "A",
              });
            }
          });
          // Mode B scalar messages
          oscBands.forEach(function (bn) {
            var bIdx = BANDS.findIndex(function (b) {
              return b.n === bn;
            });
            if (bIdx < 0) return;
            d.eeg.forEach(function (el) {
              msgs.push({
                addr: "/eeg/" + el.id + "/" + bn.toLowerCase(),
                tag: '"f"',
                vals: bpowOSC(time, el.id, bIdx, usedPid, usedFp).toFixed(3),
                mode: "B",
              });
            });
          });
          if (oscExtras.indexOf("quality") >= 0)
            d.eeg.forEach(function (el) {
              msgs.push({
                addr: "/eeg/" + el.id + "/quality",
                tag: '"f"',
                vals: qual(el.id, time).toFixed(2),
                mode: "B",
              });
            });
          if (oscExtras.indexOf("gate") >= 0)
            msgs.push({
              addr: "/eeg/gate",
              tag: '"f"',
              vals:
                bpow(time, d.eeg[0].id, bi, usedPid, usedFp) > 0.4
                  ? "1.0"
                  : "0.0",
              mode: "B",
            });
          if (oscExtras.indexOf("trigger") >= 0)
            msgs.push({
              addr: "/eeg/trigger",
              tag: '"f"',
              vals: Math.random() > 0.9 ? "1.0" : "0.0",
              mode: "B",
            });

          return h(
            "div",
            { style: { fontFamily: M, fontSize: 8, lineHeight: 1.6 } },
            // Header
            h(
              "div",
              {
                style: {
                  display: "flex",
                  justifyContent: "space-between",
                  alignItems: "center",
                  marginBottom: 6,
                },
              },
              h(
                "div",
                { style: { display: "flex", alignItems: "center", gap: 6 } },
                h("div", {
                  style: {
                    width: 6,
                    height: 6,
                    borderRadius: "50%",
                    background: th.gd,
                    animation: "pulse 1s infinite",
                  },
                }),
                h(
                  "span",
                  { style: { fontSize: 9, fontWeight: 700, color: th.gd } },
                  "LIVE",
                ),
                h(
                  "span",
                  { style: { fontSize: 8, color: th.t3 } },
                  msgs.length +
                    " messages @ " +
                    oscRate +
                    " Hz \u2192 :" +
                    oscPort,
                ),
              ),
              h(
                "div",
                { style: { display: "flex", gap: 4 } },
                h(
                  "span",
                  {
                    style: {
                      fontSize: 7,
                      padding: "1px 5px",
                      borderRadius: 4,
                      background: th.ac + "20",
                      color: th.ac,
                    },
                  },
                  "A=Muse",
                ),
                h(
                  "span",
                  {
                    style: {
                      fontSize: 7,
                      padding: "1px 5px",
                      borderRadius: 4,
                      background: th.wr + "20",
                      color: th.wr,
                    },
                  },
                  "B=Scalar",
                ),
                h(
                  "span",
                  {
                    style: {
                      fontSize: 7,
                      padding: "1px 5px",
                      borderRadius: 4,
                      background: oscFilt ? th.gd + "20" : th.bd + "40",
                      color: oscFilt ? th.gd : th.t3,
                    },
                  },
                  oscFilt ? "Filtered" : "Raw",
                ),
              ),
            ),
            // Messages
            h(
              "div",
              {
                style: {
                  maxHeight: 400,
                  overflowY: "auto",
                  background: th.sg,
                  borderRadius: 6,
                  border: "1px solid " + th.bd,
                  padding: 6,
                },
              },
              msgs.map(function (m, i) {
                var modeCol = m.mode === "A" ? th.ac : th.wr;
                return h(
                  "div",
                  {
                    key: i,
                    style: {
                      display: "flex",
                      gap: 6,
                      alignItems: "baseline",
                      borderBottom: "1px solid " + th.bd + "30",
                      padding: "2px 0",
                    },
                  },
                  h(
                    "span",
                    {
                      style: {
                        fontSize: 6,
                        color: modeCol,
                        fontWeight: 700,
                        width: 10,
                      },
                    },
                    m.mode,
                  ),
                  h("span", { style: { color: th.ac, minWidth: 200 } }, m.addr),
                  h("span", { style: { color: th.t3, minWidth: 40 } }, m.tag),
                  h(
                    "span",
                    { style: { color: th.wr, fontWeight: 600 } },
                    m.vals,
                  ),
                );
              }),
            ),
          );
        }

        // Render any display panel by ID (for quad view reuse)
        function renderPanel(vid) {
          if (vid === "timeline")
            return h(PowerTL, {
              t: th,
              time: time,
              dev: dev,
              bands: sBands,
              pid: pid,
              fp: fp,
              chs: sChs,
              autoScale: autoScales.timeline,
              yAxisRange: yAxisRanges.timeline,
            });
          if (vid === "topo")
            return h(TopoSVG, {
              t: th,
              time: time,
              dev: dev,
              bi: bi,
              skin: skin,
              pid: pid,
              fp: fp,
            });
          if (vid === "waterfall")
            return h(Waterfall, {
              t: th,
              time: time,
              dev: dev,
              bi: bi,
              pid: pid,
              fp: fp,
            });
          if (vid === "fullbrain")
            return h(FullBrain, {
              t: th,
              time: time,
              dev: dev,
              bi: bi,
              skin: skin,
              pid: pid,
              fp: fp,
            });
          if (vid === "phase")
            return h(PhaseView, {
              t: th,
              time: time,
              dev: dev,
              bi: bi,
              pid: pid,
              fp: fp,
            });
          if (vid === "coherence")
            return h(CoherenceView, { t: th, time: time, dev: dev, bi: bi });
          if (vid === "connect")
            return h(ConnectView, { t: th, time: time, dev: dev });
          if (vid === "neuro")
            return h(NeuroView, {
              t: th,
              time: time,
              dev: dev,
              pid: pid,
              fp: fp,
            });
          if (vid === "fft")
            return h(
              "div",
              null,
              h(FFTView, {
                t: th,
                time: time,
                dev: dev,
                pid: pid,
                fp: fp,
                autoScale: autoScales.fft,
                yAxisRange: yAxisRanges.fft,
              }),
              h(ScaleControls, {
                t: th,
                viewId: "fft",
                autoScale: autoScales.fft,
                yAxisRange: yAxisRanges.fft,
                setAutoScales: setAutoScales,
                setYAxisRanges: setYAxisRanges,
              }),
            );
          if (vid === "oscmon") return h(OSCMonitor);
          if (vid === "fnirs")
            return h(
              "div",
              null,
              h(AuxPanel, {
                t: th,
                time: time,
                dev: dev,
                kind: "fnirs",
                auxOn: auxOn,
                autoScale: autoScales.fnirs,
                yAxisRange: yAxisRanges.fnirs,
              }),
              h(ScaleControls, {
                t: th,
                viewId: "fnirs",
                autoScale: autoScales.fnirs,
                yAxisRange: yAxisRanges.fnirs,
                setAutoScales: setAutoScales,
                setYAxisRanges: setYAxisRanges,
              }),
            );
          if (vid === "ppg")
            return h(
              "div",
              null,
              h(AuxPanel, {
                t: th,
                time: time,
                dev: dev,
                kind: "ppg",
                auxOn: auxOn,
                autoScale: autoScales.ppg,
                yAxisRange: yAxisRanges.ppg,
              }),
              h(ScaleControls, {
                t: th,
                viewId: "ppg",
                autoScale: autoScales.ppg,
                yAxisRange: yAxisRanges.ppg,
                setAutoScales: setAutoScales,
                setYAxisRanges: setYAxisRanges,
              }),
            );
          if (vid === "imu")
            return h(
              "div",
              null,
              h(AuxPanel, {
                t: th,
                time: time,
                dev: dev,
                kind: "imu",
                auxOn: auxOn,
                autoScale: autoScales.imu,
                yAxisRange: yAxisRanges.imu,
              }),
              h(ScaleControls, {
                t: th,
                viewId: "imu",
                autoScale: autoScales.imu,
                yAxisRange: yAxisRanges.imu,
                setAutoScales: setAutoScales,
                setYAxisRanges: setYAxisRanges,
              }),
            );
          return h(
            "div",
            { style: { color: th.t3, padding: 20, textAlign: "center" } },
            "Select a display",
          );
        }

        // MAIN TAB BAR - use displayOpts for consistency
        var views = [
          { id: "timeline", l: "Power+Timeline", i: "1️⃣" },
          { id: "allbands", l: "All Bands Timeline", i: "🌈" },
          { id: "fft", l: "FFT+Bands", i: "2️⃣" },
          { id: "waterfall", l: "3D Waterfall", i: "3️⃣" },
          { id: "traces", l: "Traces", i: "4️⃣" },
          // { id: "spectrum", l: "FFT Spectrum", i: "5️⃣" }, // DISABLED - Fake FFT data (research integrity violation)
          { id: "bands", l: "Band Powers", i: "5️⃣" },
          { id: "mentalstate", l: "Mental State", i: "7️⃣" },
          { id: "neuro", l: "Neuro Indices", i: "8️⃣" },
          { id: "filters", l: "Filter Chain", i: "🎛️" },
          { id: "phase", l: "Phase", i: "🔟" },
          { id: "coherence", l: "Coherence", i: "🔢" },
        ].concat(
          hasAux("ppg") ? [{ id: "ppg", l: "PPG/HR", i: "❤️" }] : [],
          hasAux("imu") ? [{ id: "imu", l: "IMU", i: "📱" }] : [],
          hasAux("fnirs") ? [{ id: "fnirs", l: "fNIRS", i: "🔴" }] : [],
          [
            { id: "osc", l: "OSC Settings", i: "↔️" },
            { id: "oscmon", l: "OSC Monitor", i: "📡" },
            { id: "recs", l: "Recording", i: "⏺" },
            { id: "topo", l: "Topo Map", i: "🗺" },
            { id: "fullbrain", l: "Full Brain", i: "🧠" },
          ],
        );

        // Helper function to render a view by ID
        function renderView(vid) {
          if (vid === "timeline")
            return h(
              Card,
              { t: th, title: "Power + Timeline" },
              h(
                "div",
                { style: { fontSize: 8, color: th.t3, marginBottom: 6 } },
                "Real-time band power meters (left) and scrolling EEG waveforms (right) for each selected channel. Power bars show relative amplitude 0–100%. Green dots = sensor quality. Select bands and channels above.",
              ),
              h(PowerTL, {
                t: th,
                time: time,
                dev: dev,
                bands: sBands,
                pid: pid,
                fp: fp,
                chs: sChs,
                autoScale: autoScales.timeline,
                yAxisRange: yAxisRanges.timeline,
              }),
              h(ScaleControls, {
                t: th,
                viewId: "timeline",
                autoScale: autoScales.timeline,
                yAxisRange: yAxisRanges.timeline,
                setAutoScales: setAutoScales,
                setYAxisRanges: setYAxisRanges,
              }),
            );
          if (vid === "allbands")
            return h(
              Card,
              { t: th, title: "All Bands Timeline" },
              h(
                "div",
                { style: { fontSize: 8, color: th.t3, marginBottom: 6 } },
                "All 5 brain wave bands displayed as scrolling timelines.",
              ),
              h(AllBandsTimeline, {
                t: th,
                time: time,
                dev: dev,
                pid: pid,
                fp: fp,
                bandToggles: bandToggles,
              }),
            );
          if (vid === "topo")
            return h(
              Card,
              { t: th, title: "Topographic Map — " + BANDS[bi].n },
              h(
                "div",
                { style: { fontSize: 8, color: th.t3, marginBottom: 6 } },
                "Electrode positions mapped on head outline.",
              ),
              h(TopoSVG, {
                t: th,
                time: time,
                dev: dev,
                bi: bi,
                skin: skin,
                pid: pid,
                fp: fp,
              }),
            );
          if (vid === "traces")
            return h(
              Card,
              { t: th, title: "EEG Traces" },
              h(
                "div",
                { style: { fontSize: 8, color: th.t3, marginBottom: 6 } },
                "Raw EEG waveforms for all channels.",
              ),
              h(TracesView, {
                t: th,
                time: time,
                dev: dev,
                autoScale: autoScales.traces,
                yAxisRange: yAxisRanges.traces,
                deviceModel: deviceModel,
                inputFormat: inputFormat,
              }),
              h(ScaleControls, {
                t: th,
                viewId: "traces",
                autoScale: autoScales.traces,
                yAxisRange: yAxisRanges.traces,
                setAutoScales: setAutoScales,
                setYAxisRanges: setYAxisRanges,
              }),
            );
          if (vid === "bands")
            return h(
              Card,
              { t: th, title: "Band Powers" },
              h(
                "div",
                { style: { fontSize: 8, color: th.t3, marginBottom: 6 } },
                "Relative power distribution across frequency bands.",
              ),
              h(BandPowersView, {
                t: th,
                time: time,
                dev: dev,
                bandToggles: bandToggles,
              }),
            );
          if (vid === "mentalstate")
            return h(
              Card,
              { t: th, title: "Mental State" },
              h(
                "div",
                { style: { fontSize: 8, color: th.t3, marginBottom: 6 } },
                "Engagement, meditation, and focus metrics.",
              ),
              h(MentalStateView, { t: th, time: time, dev: dev }),
            );
          if (vid === "neuro")
            return h(
              Card,
              { t: th, title: "Neuro Indices" },
              h(
                "div",
                { style: { fontSize: 8, color: th.t3, marginBottom: 6 } },
                "Focus, Relax, Meditate, Drowsy ratios.",
              ),
              h(NeuroView, { t: th, time: time, dev: dev, pid: pid, fp: fp }),
            );
          // Add more views as needed
          return h(
            "div",
            { style: { padding: 20, color: th.t3 } },
            "View: " + vid,
          );
        }

        // ── Render ──
        return h(
          "div",
          {
            style: {
              fontFamily: "'IBM Plex Sans',system-ui,sans-serif",
              background: th.bg,
              color: th.tx,
              minHeight: "100vh",
            },
          },

          // ═══════════════════════════════════════════════════════════════
          // HEADER - TWO ROWS
          // ═══════════════════════════════════════════════════════════════
          h(
            "div",
            {
              style: {
                background: th.c1,
                borderBottom: "2px solid " + th.bd,
              },
            },

            // ───────────────────────────────────────────────────────────────
            // ROW 1: Title + Primary Controls
            // ───────────────────────────────────────────────────────────────
            h(
              "div",
              {
                style: {
                  display: "flex",
                  alignItems: "center",
                  justifyContent: "space-between",
                  padding: "12px 16px",
                  borderBottom: "1px solid " + th.bd,
                },
              },
              // Title Section
              h(
                "div",
                { style: { display: "flex", alignItems: "center", gap: 10 } },
                h(
                  "div",
                  {
                    style: {
                      width: 36,
                      height: 36,
                      borderRadius: 8,
                      background:
                        "linear-gradient(135deg," + th.ac + ",#8b5cf6)",
                      display: "flex",
                      alignItems: "center",
                      justifyContent: "center",
                      fontSize: 18,
                      color: "#fff",
                    },
                  },
                  "🧠",
                ),
                h(
                  "div",
                  {
                    style: {
                      fontSize: 20,
                      fontWeight: 700,
                      color: th.tx,
                      letterSpacing: "-0.02em",
                    },
                  },
                  "Dr.C - NeuroViz EEG+",
                ),
                h(
                  "span",
                  {
                    style: {
                      fontSize: 11,
                      fontWeight: 700,
                      color: "#f59e0b",
                      padding: "3px 8px",
                      borderRadius: 4,
                      background: "#f59e0b20",
                      border: "1px solid #f59e0b",
                      marginLeft: 8,
                    },
                  },
                  "v1.06@01:08",
                ),
              ),

              // Primary Controls (right side of Row 1)
              h(
                "div",
                {
                  style: {
                    display: "flex",
                    alignItems: "center",
                    gap: 10,
                  },
                },
                // Connection Status/Device
                paired &&
                  h(
                    "span",
                    {
                      style: {
                        fontSize: 10,
                        padding: "5px 12px",
                        borderRadius: 6,
                        background: th.gd + "20",
                        color: th.gd,
                        fontWeight: 700,
                        border: "2px solid " + th.gd,
                      },
                    },
                    "📡 " + DEVS[paired].name,
                  ),
                // Calibration Controls (Log Transform + Z-Score)
                h(
                  "div",
                  {
                    style: {
                      display: "flex",
                      alignItems: "center",
                      gap: 6,
                      padding: "6px 12px",
                      borderRadius: 6,
                      border: "2px solid " + th.bd,
                      background: th.c2,
                    },
                  },
                  h(
                    "span",
                    {
                      style: {
                        fontSize: 10,
                        fontWeight: 700,
                        color: th.t2,
                        marginRight: 4,
                      },
                    },
                    "📊",
                  ),
                  h(
                    "label",
                    {
                      style: {
                        fontSize: 10,
                        cursor: "pointer",
                        display: "flex",
                        alignItems: "center",
                        gap: 4,
                        color: th.t2,
                      },
                    },
                    h("input", {
                      type: "checkbox",
                      checked: baseLog,
                      onChange: function (e) {
                        setBaseLog(e.target.checked);
                        fetch("/api/settings", {
                          method: "POST",
                          headers: { "Content-Type": "application/json" },
                          body: JSON.stringify({
                            logTransform: e.target.checked,
                          }),
                        });
                      },
                      style: { width: 13, height: 13, cursor: "pointer" },
                    }),
                    "Log",
                  ),
                  h(
                    "label",
                    {
                      style: {
                        fontSize: 10,
                        cursor: "pointer",
                        display: "flex",
                        alignItems: "center",
                        gap: 4,
                        color: th.t2,
                      },
                    },
                    h("input", {
                      type: "checkbox",
                      checked: baseNorm,
                      onChange: function (e) {
                        setBaseNorm(e.target.checked);
                        fetch("/api/settings", {
                          method: "POST",
                          headers: { "Content-Type": "application/json" },
                          body: JSON.stringify({ zScore: e.target.checked }),
                        });
                      },
                      style: { width: 13, height: 13, cursor: "pointer" },
                    }),
                    "Z-Score",
                  ),
                ),
                // Preset Selector
                h(
                  "select",
                  {
                    value: activePreset || "",
                    onChange: function (e) {
                      var presetId = e.target.value;
                      if (presetId) {
                        var preset = perfPresets.find(function (p) {
                          return p.id === presetId;
                        });
                        if (preset) loadPreset(preset);
                      }
                    },
                    style: {
                      fontSize: 11,
                      padding: "6px 12px",
                      borderRadius: 6,
                      border: "2px solid " + (activePreset ? "#10b981" : th.bd),
                      background: activePreset ? "#10b98115" : th.c2,
                      color: activePreset ? "#10b981" : th.t2,
                      fontWeight: 700,
                      cursor: "pointer",
                      minWidth: 180,
                    },
                  },
                  h("option", { value: "" }, "⚡ Load Preset..."),
                  perfPresets.map(function (preset, idx) {
                    return h(
                      "option",
                      { key: preset.id, value: preset.id },
                      idx + 1 + ". " + preset.name,
                    );
                  }),
                ),
                // Device Model Selector
                h(
                  "select",
                  {
                    value: deviceModel,
                    onChange: function (e) {
                      var newDevice = e.target.value;
                      setDeviceModel(newDevice);
                      fetch("/api/dsp/config", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ deviceModel: newDevice }),
                      });
                    },
                    style: {
                      fontSize: 11,
                      fontWeight: 700,
                      padding: "6px 12px",
                      borderRadius: 6,
                      border: "2px solid " + th.ac,
                      background: th.ac + "15",
                      color: th.ac,
                      cursor: "pointer",
                    },
                  },
                  h("option", { value: "Muse 2" }, "📱 Muse 2"),
                  h("option", { value: "Muse S" }, "📱 Muse S"),
                  h("option", { value: "Muse S (Athena)" }, "📱 Muse S Athena"),
                  h("option", { value: "OpenBCI Ganglion" }, "📱 Ganglion"),
                  h("option", { value: "OpenBCI Cyton" }, "📱 Cyton"),
                ),
                // OSC Toggle
                h(
                  "button",
                  {
                    onClick: function () {
                      var nextState = !oscSending;
                      setOscSending(nextState);
                      fetch("/api/settings", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ oscSending: nextState }),
                      });
                    },
                    style: {
                      padding: "6px 14px",
                      borderRadius: 6,
                      border: "2px solid " + (oscSending ? th.gd : th.bd),
                      background: oscSending ? th.gd + "20" : th.c2,
                      color: oscSending ? th.gd : th.t3,
                      fontSize: 11,
                      fontWeight: 700,
                      cursor: "pointer",
                    },
                  },
                  oscSending ? "↔️ OSC ON" : "↔️ OSC OFF",
                ),
                // Simulator Toggle (LAST button in row 1)
                h(
                  "button",
                  {
                    onClick: function () {
                      var nextMode = !simMode;
                      setSimMode(nextMode);
                      fetch("/api/settings", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ simulatorMode: nextMode }),
                      });
                    },
                    style: {
                      padding: "6px 14px",
                      borderRadius: 6,
                      border: "2px solid " + (simMode ? "#f59e0b" : th.bd),
                      background: simMode ? "#f59e0b20" : th.c2,
                      color: simMode ? "#f59e0b" : th.t3,
                      fontSize: 11,
                      fontWeight: 700,
                      cursor: "pointer",
                    },
                  },
                  simMode ? "🎲 Simulator ON" : "🎲 Simulator OFF",
                ),
              ),
            ),

            // ───────────────────────────────────────────────────────────────
            // ROW 2: Secondary Controls (larger, more info, more readable)
            // ───────────────────────────────────────────────────────────────
            h(
              "div",
              {
                style: {
                  display: "flex",
                  alignItems: "center",
                  justifyContent: "space-between",
                  padding: "10px 16px",
                  gap: 10,
                  flexWrap: "wrap",
                },
              },
              // Left group
              h(
                "div",
                { style: { display: "flex", alignItems: "center", gap: 8 } },
                // Recording controls
                h(
                  "button",
                  {
                    onClick: toggleRec,
                    style: {
                      padding: "7px 16px",
                      borderRadius: 6,
                      border: "2px solid " + (isRec ? "#ef4444" : th.ac),
                      background: isRec ? "#ef444420" : th.ac + "15",
                      color: isRec ? "#ef4444" : th.ac,
                      fontSize: 12,
                      fontWeight: 700,
                      cursor: "pointer",
                    },
                  },
                  isRec ? "⏹ Stop Recording" : "⏺ Record",
                ),
                isRec &&
                  h(
                    "span",
                    {
                      style: {
                        fontSize: 11,
                        fontWeight: 700,
                        color: "#ef4444",
                        padding: "5px 10px",
                        borderRadius: 6,
                        background: "#ef444415",
                      },
                    },
                    "● REC " + recType.toUpperCase(),
                  ),
                !isRec &&
                  h(
                    "select",
                    {
                      value: recType,
                      onChange: function (e) {
                        setRecType(e.target.value);
                      },
                      style: {
                        padding: "6px 10px",
                        borderRadius: 6,
                        border: "2px solid " + th.bd,
                        background: th.c2,
                        color: th.t2,
                        fontSize: 11,
                        fontWeight: 600,
                        cursor: "pointer",
                      },
                    },
                    h("option", { value: "eeg" }, "EEG Data"),
                    hasAux("fnirs") &&
                      h("option", { value: "fnirs" }, "fNIRS Data"),
                    hasAux("ppg") &&
                      h("option", { value: "ppg" }, "PPG/Heart Rate"),
                    hasAux("imu") &&
                      h("option", { value: "imu" }, "IMU/Motion"),
                  ),
                h(
                  "button",
                  {
                    onClick: function () {
                      setRecFilt(!recFilt);
                    },
                    style: {
                      padding: "7px 14px",
                      borderRadius: 6,
                      border: "2px solid " + (recFilt ? th.gd : th.bd),
                      background: recFilt ? th.gd + "20" : th.c2,
                      color: recFilt ? th.gd : th.t3,
                      fontSize: 11,
                      fontWeight: 700,
                      cursor: "pointer",
                    },
                  },
                  recFilt ? "✓ Filtered" : "Raw Signal",
                ),
              ),
              // Right group
              h(
                "div",
                { style: { display: "flex", alignItems: "center", gap: 8 } },
                h(
                  "button",
                  {
                    onClick: function () {
                      setView("proc");
                    },
                    style: {
                      padding: "7px 14px",
                      borderRadius: 6,
                      border: "2px solid " + th.ac,
                      background: th.ac + "15",
                      color: th.ac,
                      fontSize: 11,
                      fontWeight: 700,
                      cursor: "pointer",
                    },
                  },
                  "⚙️ Filter Settings",
                ),
                h(
                  "button",
                  {
                    onClick: function () {
                      setView("presets");
                    },
                    style: {
                      padding: "7px 14px",
                      borderRadius: 6,
                      border: "2px solid " + th.t2,
                      background: th.c2,
                      color: th.t2,
                      fontSize: 11,
                      fontWeight: 700,
                      cursor: "pointer",
                    },
                  },
                  "💾 Manage Presets",
                ),
                h(
                  "div",
                  {
                    style: {
                      display: "flex",
                      alignItems: "center",
                      gap: 4,
                    },
                  },
                  h(
                    "button",
                    {
                      onClick: function () {
                        setTheme(
                          theme === "dark"
                            ? "light"
                            : theme === "light"
                              ? "highContrast"
                              : "dark",
                        );
                      },
                      style: {
                        width: 32,
                        height: 32,
                        borderRadius: 6,
                        border: "2px solid " + th.bd,
                        background: th.c2,
                        color: th.tx,
                        fontSize: 14,
                        display: "flex",
                        alignItems: "center",
                        justifyContent: "center",
                        cursor: "pointer",
                      },
                      title: "Theme: " + theme,
                    },
                    theme === "dark" ? "🌙" : theme === "light" ? "☀️" : "⚫",
                  ),
                  h(
                    "span",
                    {
                      style: {
                        fontSize: 10,
                        fontWeight: 700,
                        color: th.t3,
                        textTransform: "uppercase",
                      },
                    },
                    theme === "dark"
                      ? "Dark"
                      : theme === "light"
                        ? "Light"
                        : "Hi-Con",
                  ),
                ),
              ),
            ),
          ),

          // ═══════════════════════════════════════════════════════════════
          // MAIN LAYOUT: LEFT SIDEBAR + RIGHT DISPLAY AREA
          // ═══════════════════════════════════════════════════════════════
          h(
            "div",
            {
              style: {
                display: "flex",
                height: "calc(100vh - 140px)",
                overflow: "hidden",
              },
            },
            // ─────────────────────────────────────────────────────────────
            // LEFT SIDEBAR (Display Mode + View Selection)
            // ─────────────────────────────────────────────────────────────
            h(
              "div",
              {
                style: {
                  width: 200,
                  borderLeft: "2px solid " + th.bd,
                  background: th.c1,
                  overflowY: "auto",
                  display: "flex",
                  flexDirection: "column",
                  gap: 12,
                  padding: "12px",
                  order: 2,
                },
              },
              // Display Mode Selection
              h(
                "div",
                null,
                h(
                  "div",
                  {
                    style: {
                      fontSize: 7,
                      fontWeight: 700,
                      color: th.t3,
                      textTransform: "uppercase",
                      letterSpacing: "0.05em",
                      marginBottom: 6,
                    },
                  },
                  "DISPLAY MODE",
                ),
                h(
                  "div",
                  {
                    style: {
                      display: "flex",
                      flexDirection: "column",
                      gap: 2,
                    },
                  },
                  [
                    { id: "single", label: "📱 Single View" },
                    { id: "dual", label: "⚏ Dual View" },
                    { id: "quad", label: "▦ Quad View" },
                  ].map(function (mode) {
                    var isActive = displayMode === mode.id;
                    return h(
                      "button",
                      {
                        key: mode.id,
                        onClick: function () {
                          setDisplayMode(mode.id);
                          if (mode.id === "quad") setQuadMode(true);
                          else setQuadMode(false);
                        },
                        style: {
                          padding: "6px 10px",
                          borderRadius: 5,
                          border: "1px solid " + (isActive ? th.ac : th.bd),
                          background: isActive ? th.ac + "20" : th.c2,
                          color: isActive ? th.ac : th.t2,
                          fontSize: 10,
                          fontWeight: isActive ? 700 : 400,
                          textAlign: "left",
                          cursor: "pointer",
                          transition: "all 0.2s",
                        },
                      },
                      mode.label,
                    );
                  }),
                ),
              ),
              // View Selection (for Single/Dual mode)
              displayMode !== "quad" &&
                h(
                  "div",
                  null,
                  h(
                    "div",
                    {
                      style: {
                        fontSize: 7,
                        fontWeight: 700,
                        color: th.t3,
                        textTransform: "uppercase",
                        letterSpacing: "0.05em",
                        marginBottom: 6,
                      },
                    },
                    displayMode === "dual" ? "LEFT DISPLAY" : "DISPLAYS",
                  ),
                  h(
                    "div",
                    {
                      style: {
                        display: "flex",
                        flexDirection: "column",
                        gap: 2,
                      },
                    },
                    views.map(function (v) {
                      var isActive =
                        displayMode === "single"
                          ? view === v.id
                          : dualPanels[0] === v.id;
                      return h(
                        "button",
                        {
                          key: v.id,
                          onClick: function () {
                            if (displayMode === "single") {
                              setView(v.id);
                            } else {
                              setDualPanels([v.id, dualPanels[1]]);
                            }
                          },
                          style: {
                            padding: "6px 10px",
                            borderRadius: 5,
                            border: "1px solid " + (isActive ? th.ac : th.bd),
                            background: isActive ? th.ac + "20" : th.c2,
                            color: isActive ? th.ac : th.t2,
                            fontSize: 10,
                            fontWeight: isActive ? 700 : 400,
                            textAlign: "left",
                            cursor: "pointer",
                            transition: "all 0.2s",
                          },
                        },
                        v.i + " " + v.l,
                      );
                    }),
                  ),
                ),
              // Right Display Selection (Dual mode only)
              displayMode === "dual" &&
                h(
                  "div",
                  null,
                  h(
                    "div",
                    {
                      style: {
                        fontSize: 7,
                        fontWeight: 700,
                        color: th.t3,
                        textTransform: "uppercase",
                        letterSpacing: "0.05em",
                        marginBottom: 6,
                      },
                    },
                    "RIGHT DISPLAY",
                  ),
                  h(
                    "div",
                    {
                      style: {
                        display: "flex",
                        flexDirection: "column",
                        gap: 2,
                      },
                    },
                    views.map(function (v) {
                      var isActive = dualPanels[1] === v.id;
                      return h(
                        "button",
                        {
                          key: v.id,
                          onClick: function () {
                            setDualPanels([dualPanels[0], v.id]);
                          },
                          style: {
                            padding: "6px 10px",
                            borderRadius: 5,
                            border:
                              "1px solid " + (isActive ? "#f59e0b" : th.bd),
                            background: isActive ? "#f59e0b20" : th.c2,
                            color: isActive ? "#f59e0b" : th.t2,
                            fontSize: 10,
                            fontWeight: isActive ? 700 : 400,
                            textAlign: "left",
                            cursor: "pointer",
                            transition: "all 0.2s",
                          },
                        },
                        v.i + " " + v.l,
                      );
                    }),
                  ),
                ),
              h(
                "div",
                {
                  style: {
                    display: "flex",
                    flexDirection: "column",
                    gap: 2,
                  },
                },
                views.map(function (v) {
                  var isActive = view === v.id;
                  return h(
                    "button",
                    {
                      key: v.id,
                      onClick: function () {
                        setView(v.id);
                      },
                      style: {
                        padding: "6px 10px",
                        borderRadius: 5,
                        border: "1px solid " + (isActive ? th.ac : th.bd),
                        background: isActive ? th.ac + "20" : th.c2,
                        color: isActive ? th.ac : th.t2,
                        fontSize: 10,
                        fontWeight: isActive ? 700 : 400,
                        textAlign: "left",
                        cursor: "pointer",
                        transition: "all 0.2s",
                      },
                    },
                    v.i + " " + v.l,
                  );
                }),
              ),
            ),
          ),
          // ─────────────────────────────────────────────────────────────
          // RIGHT DISPLAY AREA
          // ─────────────────────────────────────────────────────────────
          h(
            "div",
            {
              style: {
                flex: 1,
                display: "flex",
                flexDirection: "column",
                overflow: "hidden",
                order: 1,
              },
            },
            // BAND FILTERS & CHANNELS (Horizontal bar above displays)
            h(
              "div",
              {
                style: {
                  padding: "10px 12px",
                  borderBottom: "2px solid " + th.bd,
                  background: th.c1,
                  display: "flex",
                  alignItems: "center",
                  gap: 20,
                  flexWrap: "wrap",
                },
              },
              // Band Filters
              h(
                "div",
                {
                  style: {
                    display: "flex",
                    alignItems: "center",
                    gap: 6,
                  },
                },
                h(
                  "span",
                  {
                    style: {
                      fontSize: 7,
                      fontWeight: 700,
                      color: th.t3,
                      textTransform: "uppercase",
                      letterSpacing: "0.05em",
                      marginRight: 4,
                    },
                  },
                  "BANDS:",
                ),
                BANDS.map(function (band, bi) {
                  var bandKey = band.n.toLowerCase();
                  var isEnabled = bandToggles[bandKey];
                  var color = th.isDark ? band.d : band.c;
                  return h(
                    "label",
                    {
                      key: bandKey,
                      style: {
                        display: "flex",
                        alignItems: "center",
                        gap: 4,
                        padding: "4px 8px",
                        borderRadius: 5,
                        border: "1px solid " + (isEnabled ? color : th.bd),
                        background: isEnabled ? color + "15" : th.c2,
                        cursor: "pointer",
                        fontSize: 9,
                        fontWeight: 600,
                        fontFamily: M,
                        transition: "all 0.2s",
                      },
                    },
                    h("input", {
                      type: "checkbox",
                      checked: isEnabled,
                      onChange: function () {
                        var next = {};
                        Object.keys(bandToggles).forEach(function (k) {
                          next[k] = bandToggles[k];
                        });
                        next[bandKey] = !next[bandKey];
                        setBandToggles(next);
                        setSBands(function (p) {
                          var isCurrentlyEnabled = p.indexOf(band.n) >= 0;
                          return isCurrentlyEnabled
                            ? p.filter(function (x) {
                                return x !== band.n;
                              })
                            : p.concat([band.n]);
                        });
                        setBi(bi);
                      },
                      style: { width: 13, height: 13, cursor: "pointer" },
                    }),
                    h(
                      "span",
                      { style: { color: isEnabled ? color : th.t3 } },
                      band.n,
                    ),
                    h(
                      "span",
                      {
                        style: {
                          fontSize: 7,
                          color: th.t3,
                          marginLeft: 2,
                        },
                      },
                      band.r + " Hz",
                    ),
                  );
                }),
              ),
              // Separator
              h("div", {
                style: {
                  width: 1,
                  height: 20,
                  background: th.bd,
                },
              }),
              // Channel Select
              h(
                "div",
                {
                  style: {
                    display: "flex",
                    alignItems: "center",
                    gap: 6,
                  },
                },
                h(
                  "span",
                  {
                    style: {
                      fontSize: 7,
                      fontWeight: 700,
                      color: th.t3,
                      textTransform: "uppercase",
                      letterSpacing: "0.05em",
                      marginRight: 4,
                    },
                  },
                  "CHANNELS:",
                ),
                d.eeg.map(function (el, idx) {
                  var isActive = sChs.indexOf(el.id) >= 0;
                  var chColor = th.isDark ? BANDS[idx % 5].d : BANDS[idx % 5].c;
                  return h(
                    "button",
                    {
                      key: el.id,
                      onClick: function () {
                        setSChs(function (p) {
                          return p.indexOf(el.id) >= 0
                            ? p.filter(function (x) {
                                return x !== el.id;
                              })
                            : p.concat([el.id]);
                        });
                      },
                      style: {
                        padding: "4px 12px",
                        borderRadius: 5,
                        border: "1px solid " + (isActive ? chColor : th.bd),
                        background: isActive ? chColor + "15" : th.c2,
                        color: isActive ? chColor : th.t3,
                        fontSize: 9,
                        fontWeight: 600,
                        fontFamily: M,
                        cursor: "pointer",
                        transition: "all 0.2s",
                      },
                    },
                    el.id,
                  );
                }),
              ),
            ),
            // CONTENT AREA (scrollable displays)
            h(
              "div",
              {
                style: {
                  flex: 1,
                  overflowY: "auto",
                  padding: "12px",
                  background: th.bg,
                  display: displayMode === "dual" ? "flex" : "block",
                  gap: displayMode === "dual" ? 12 : 0,
                },
              },
              // DISPLAY MODE RENDERING
              // ═══════════════════════════════════════════════════════

              // Single View Mode
              displayMode === "single" && renderView(view),

              // Dual View Mode (50/50 split)
              displayMode === "dual" &&
                h(
                  Fragment,
                  null,
                  h(
                    "div",
                    { style: { flex: 1, minWidth: 0 } },
                    renderView(dualPanels[0]),
                  ),
                  h(
                    "div",
                    { style: { flex: 1, minWidth: 0 } },
                    renderView(dualPanels[1]),
                  ),
                ),

              // Quad View Mode (2x2 grid)
              displayMode === "quad" &&
                h(
                  "div",
                  {
                    style: {
                      display: "grid",
                      gridTemplateColumns: "1fr 1fr",
                      gap: 12,
                      height: "100%",
                    },
                  },
                  quadPanels.map(function (vid) {
                    return h(
                      "div",
                      { key: vid, style: { minWidth: 0, minHeight: 0 } },
                      renderView(vid),
                    );
                  }),
                ),

              // Legacy: Keep existing view rendering for any views not in renderView()
              displayMode === "single" &&
                view === "timeline___OLD" &&
                h(
                  Card,
                  { t: th, title: "Power + Timeline" },
                  h(
                    "div",
                    {
                      style: { fontSize: 8, color: th.t3, marginBottom: 6 },
                    },
                    "Real-time band power meters (left) and scrolling EEG waveforms (right) for each selected channel. Power bars show relative amplitude 0\u2013100%. Green dots = sensor quality. Select bands and channels above.",
                  ),
                  h(PowerTL, {
                    t: th,
                    time: time,
                    dev: dev,
                    bands: sBands,
                    pid: pid,
                    fp: fp,
                    chs: sChs,
                    autoScale: autoScales.timeline,
                    yAxisRange: yAxisRanges.timeline,
                  }),
                  h(ScaleControls, {
                    t: th,
                    viewId: "timeline",
                    autoScale: autoScales.timeline,
                    yAxisRange: yAxisRanges.timeline,
                    setAutoScales: setAutoScales,
                    setYAxisRanges: setYAxisRanges,
                  }),
                ),
              displayMode === "single" &&
                view === "allbands" &&
                h(
                  Card,
                  { t: th, title: "All Bands Timeline" },
                  h(
                    "div",
                    {
                      style: { fontSize: 8, color: th.t3, marginBottom: 6 },
                    },
                    "Mind Monitor style: All 5 brain wave bands (Delta, Theta, Alpha, Beta, Gamma) displayed simultaneously as scrolling timelines. Each band has a unique color. Values are averaged across all active channels. Use the BAND FILTERS above to show/hide specific bands.",
                  ),
                  h(AllBandsTimeline, {
                    t: th,
                    time: time,
                    dev: dev,
                    pid: pid,
                    fp: fp,
                    bandToggles: bandToggles,
                  }),
                ),
              displayMode === "single" &&
                view === "topo" &&
                h(
                  Card,
                  { t: th, title: "Topographic Map \u2014 " + BANDS[bi].n },
                  h(
                    "div",
                    {
                      style: { fontSize: 8, color: th.t3, marginBottom: 6 },
                    },
                    d.name +
                      ": " +
                      d.ch +
                      " electrodes (" +
                      d.eeg
                        .map(function (e) {
                          return e.id;
                        })
                        .join(", ") +
                      ") mapped onto a head outline. Color intensity = " +
                      BANDS[bi].n +
                      " band power. Quality rings show electrode contact. Nose is at top.",
                  ),
                  h(TopoSVG, {
                    t: th,
                    time: time,
                    dev: dev,
                    bi: bi,
                    skin: skin,
                    pid: pid,
                    fp: fp,
                  }),
                ),
              displayMode === "single" &&
                view === "traces" &&
                h(
                  Card,
                  { t: th, title: "EEG Traces (NeurOSC Style)" },
                  h(
                    "div",
                    {
                      style: { fontSize: 8, color: th.t3, marginBottom: 6 },
                    },
                    "Raw EEG waveforms for all channels. 4-second window showing microVolt fluctuations. Each channel rendered in a different color with auto-scaling or manual range control.",
                  ),
                  h(TracesView, {
                    t: th,
                    time: time,
                    dev: dev,
                    autoScale: autoScales.traces,
                    yAxisRange: yAxisRanges.traces,
                    deviceModel: deviceModel,
                    inputFormat: inputFormat,
                  }),
                  h(ScaleControls, {
                    t: th,
                    viewId: "traces",
                    autoScale: autoScales.traces,
                    yAxisRange: yAxisRanges.traces,
                    setAutoScales: setAutoScales,
                    setYAxisRanges: setYAxisRanges,
                  }),
                ),
              displayMode === "single" &&
                view === "mentalstate" &&
                h(
                  Card,
                  { t: th, title: "Mental State (NeurOSC)" },
                  h(
                    "div",
                    {
                      style: { fontSize: 8, color: th.t3, marginBottom: 6 },
                    },
                    "Real-time mental state classification based on EEG band power ratios. Engagement index (Beta/Alpha+Theta), meditation score, and focus level. State automatically classified as Calm, Meditative, Focused, or Drowsy.",
                  ),
                  h(MentalStateView, {
                    t: th,
                    time: time,
                    dev: dev,
                  }),
                ),
              displayMode === "single" &&
                view === "filters" &&
                h(
                  Card,
                  { t: th, title: "DSP Filter Chain" },
                  h(
                    "div",
                    {
                      style: { fontSize: 9, color: th.t3, marginBottom: 6 },
                    },
                    "Complete settings snapshots for live performance. Each preset saves: DSP filters, OSC config, display view, band toggles, scales, and calibration.",
                  ),
                  h(
                    "div",
                    {
                      style: {
                        fontSize: 8,
                        color: "#10b981",
                        fontWeight: 700,
                        padding: "4px 8px",
                        background: "#10b98110",
                        borderRadius: 5,
                        display: "inline-block",
                        marginBottom: 10,
                      },
                    },
                    "⌨️ Keyboard: Press 1-9 to load presets instantly",
                  ),

                  // CAR Filter
                  h(
                    "div",
                    {
                      style: {
                        marginBottom: 16,
                        padding: 12,
                        background: th.c1,
                        borderRadius: 6,
                      },
                    },
                    h(
                      "label",
                      {
                        style: {
                          display: "flex",
                          alignItems: "center",
                          gap: 8,
                          cursor: "pointer",
                        },
                      },
                      h("input", {
                        type: "checkbox",
                        checked: dspCAR,
                        onChange: function (e) {
                          setDspCAR(e.target.checked);
                          fetch("/api/dsp/config", {
                            method: "POST",
                            headers: { "Content-Type": "application/json" },
                            body: JSON.stringify({
                              applyCAR: e.target.checked,
                            }),
                          });
                        },
                      }),
                      h(
                        "span",
                        { style: { fontWeight: 700, fontSize: 12 } },
                        "CAR - Common Average Reference",
                      ),
                    ),
                    h(
                      "div",
                      {
                        style: {
                          fontSize: 9,
                          color: th.t3,
                          marginTop: 4,
                          marginLeft: 24,
                        },
                      },
                      "Spatial filter: Subtracts mean of all channels to remove global noise (60Hz hum, muscle artifacts)",
                    ),
                  ),

                  // Notch Filter
                  h(
                    "div",
                    {
                      style: {
                        marginBottom: 16,
                        padding: 12,
                        background: th.c1,
                        borderRadius: 6,
                      },
                    },
                    h(
                      "label",
                      {
                        style: {
                          display: "flex",
                          alignItems: "center",
                          gap: 8,
                          cursor: "pointer",
                        },
                      },
                      h("input", {
                        type: "checkbox",
                        checked: dspNotch,
                        onChange: function (e) {
                          setDspNotch(e.target.checked);
                          fetch("/api/dsp/config", {
                            method: "POST",
                            headers: { "Content-Type": "application/json" },
                            body: JSON.stringify({
                              applyNotch: e.target.checked,
                            }),
                          });
                        },
                      }),
                      h(
                        "span",
                        { style: { fontWeight: 700, fontSize: 12 } },
                        "Notch Filter (60 Hz)",
                      ),
                    ),
                    h(
                      "div",
                      {
                        style: {
                          fontSize: 9,
                          color: th.t3,
                          marginTop: 4,
                          marginLeft: 24,
                        },
                      },
                      "Removes power line interference at 60 Hz (50 Hz for EU)",
                    ),
                  ),

                  // Bandpass Filter
                  h(
                    "div",
                    {
                      style: {
                        marginBottom: 16,
                        padding: 12,
                        background: th.c1,
                        borderRadius: 6,
                      },
                    },
                    h(
                      "label",
                      {
                        style: {
                          display: "flex",
                          alignItems: "center",
                          gap: 8,
                          cursor: "pointer",
                        },
                      },
                      h("input", {
                        type: "checkbox",
                        checked: dspBandpass,
                        onChange: function (e) {
                          setDspBandpass(e.target.checked);
                          fetch("/api/dsp/config", {
                            method: "POST",
                            headers: { "Content-Type": "application/json" },
                            body: JSON.stringify({
                              applyBandpass: e.target.checked,
                            }),
                          });
                        },
                      }),
                      h(
                        "span",
                        { style: { fontWeight: 700, fontSize: 12 } },
                        "Bandpass Filter (1-45 Hz)",
                      ),
                    ),
                    h(
                      "div",
                      {
                        style: {
                          fontSize: 9,
                          color: th.t3,
                          marginTop: 4,
                          marginLeft: 24,
                        },
                      },
                      "Isolates brain wave frequencies: removes DC offset and high-frequency muscle artifacts",
                    ),
                  ),

                  // Processing Chain Diagram
                  h(
                    "div",
                    {
                      style: {
                        marginTop: 24,
                        padding: 16,
                        background: th.c2,
                        borderRadius: 6,
                      },
                    },
                    h(
                      "div",
                      {
                        style: {
                          fontWeight: 700,
                          fontSize: 11,
                          marginBottom: 12,
                        },
                      },
                      "Active Processing Chain:",
                    ),
                    h(
                      "div",
                      {
                        style: {
                          fontSize: 10,
                          color: th.t2,
                          fontFamily: "monospace",
                          lineHeight: 1.6,
                        },
                      },
                      "Raw EEG → " +
                        (dspCAR ? "CAR → " : "") +
                        (dspNotch ? "Notch(60Hz) → " : "") +
                        (dspBandpass ? "Bandpass(1-45Hz) → " : "") +
                        "Smoothing → Output",
                    ),
                  ),
                ),
            ),
            displayMode === "single" &&
              view === "spectrum" &&
              h(
                Card,
                { t: th, title: "FFT Spectrum" },
                h(
                  "div",
                  { style: { fontSize: 8, color: th.t3, marginBottom: 6 } },
                  "Frequency spectrum analysis from 0.5-40 Hz. Shows power distribution across brain wave bands (delta, theta, alpha, beta, gamma). Each channel plotted in a different color for comparison.",
                ),
                h(SpectrumView, {
                  t: th,
                  time: time,
                  dev: dev,
                  bandToggles: bandToggles,
                }),
              ),
            displayMode === "single" &&
              view === "bands" &&
              h(
                Card,
                { t: th, title: "Band Powers" },
                h(
                  "div",
                  { style: { fontSize: 8, color: th.t3, marginBottom: 6 } },
                  "Relative power in each EEG frequency band (delta, theta, alpha, beta, gamma) shown as horizontal bars. Values normalized to percentages per channel. Color-coded by band type.",
                ),
                h(BandPowersView, {
                  t: th,
                  time: time,
                  dev: dev,
                  bandToggles: bandToggles,
                }),
              ),
            displayMode === "single" &&
              view === "waterfall" &&
              h(
                Card,
                {
                  t: th,
                  title: "3D Waterfall \u2014 " + BANDS[bi].n + " (IBVA-style)",
                },
                h(
                  "div",
                  { style: { fontSize: 8, color: th.t3, marginBottom: 6 } },
                  "Band power across all " +
                    d.ch +
                    " electrodes stacked in time (newer traces in front). Each line = one time snapshot. Height = amplitude. Inspired by the IBVA system\u2019s waterfall display for seeing temporal patterns in band power.",
                ),
                h(Waterfall, {
                  t: th,
                  time: time,
                  dev: dev,
                  bi: bi,
                  pid: pid,
                  fp: fp,
                }),
              ),
            displayMode === "single" &&
              view === "fullbrain" &&
              h(
                Card,
                {
                  t: th,
                  title: "Full Brain \u2014 " + BANDS[bi].n + " (EPOC-style)",
                },
                h(FullBrain, {
                  t: th,
                  time: time,
                  dev: dev,
                  bi: bi,
                  skin: skin,
                  pid: pid,
                  fp: fp,
                }),
              ),
            displayMode === "single" &&
              view === "phase" &&
              h(
                Card,
                { t: th, title: "Phase - Selected Bands" },
                h(
                  "div",
                  { style: { fontSize: 8, color: th.t3, marginBottom: 6 } },
                  "Polar plot showing phase angle and magnitude of selected band oscillations per electrode. Distance from center = power. Angle = instantaneous phase. When electrodes cluster together, the brain regions are synchronizing.",
                ),
                h(PhaseView, {
                  t: th,
                  time: time,
                  dev: dev,
                  bi: bi,
                  pid: pid,
                  fp: fp,
                  bandToggles: bandToggles,
                }),
              ),
            displayMode === "single" &&
              view === "coherence" &&
              h(
                Card,
                { t: th, title: "Coherence Matrix" },
                h(
                  "div",
                  { style: { fontSize: 8, color: th.t3, marginBottom: 6 } },
                  "Cross-electrode coherence: how synchronized oscillations are between each pair of electrodes. 100% = perfectly in phase. High coherence suggests functional connectivity between brain regions.",
                ),
                h(CoherenceView, {
                  t: th,
                  time: time,
                  dev: dev,
                  bi: bi,
                  bandToggles: bandToggles,
                }),
              ),
            displayMode === "single" &&
              view === "connect" &&
              h(
                Card,
                { t: th, title: "Sensor Connectivity \u2014 " + d.name },
                h(ConnectView, { t: th, time: time, dev: dev }),
              ),
            displayMode === "single" &&
              view === "neuro" &&
              h(
                Card,
                { t: th, title: "Neuro Indices" },
                h(
                  "div",
                  { style: { fontSize: 8, color: th.t3, marginBottom: 6 } },
                  "Computed ratios from band powers, averaged across electrodes. Focus = Beta/Theta (attention). Relax = Alpha/Beta (calm). Meditate = Theta/Alpha (deep states). Drowsy = Delta/Alpha (fatigue). Values are smoothed for stability.",
                ),
                h(
                  "div",
                  { style: { maxWidth: "50%", margin: "0 auto" } },
                  h(NeuroView, {
                    t: th,
                    time: time,
                    dev: dev,
                    pid: pid,
                    fp: fp,
                  }),
                ),
              ),
            displayMode === "single" &&
              view === "fft" &&
              h(
                Card,
                { t: th, title: "FFT Spectrum + Power Bands" },
                h(
                  "div",
                  { style: { fontSize: 8, color: th.t3, marginBottom: 6 } },
                  "Left: live frequency spectrum (0\u201360 Hz) with band regions color-coded. Right: all 5 band powers as animated bars with sparkline histories. Shows how spectral energy distributes across bands in real time.",
                ),
                h(FFTView, {
                  t: th,
                  time: time,
                  dev: dev,
                  pid: pid,
                  fp: fp,
                  autoScale: autoScales.fft,
                  yAxisRange: yAxisRanges.fft,
                }),
                h(ScaleControls, {
                  t: th,
                  viewId: "fft",
                  autoScale: autoScales.fft,
                  yAxisRange: yAxisRanges.fft,
                  setAutoScales: setAutoScales,
                  setYAxisRanges: setYAxisRanges,
                }),
              ),
            displayMode === "single" &&
              view === "fnirs" &&
              h(
                Card,
                { t: th, title: "fNIRS \u2014 Hemodynamic Response" },
                h(
                  "div",
                  { style: { fontSize: 8, color: th.t3, marginBottom: 6 } },
                  "Functional near-infrared spectroscopy measures blood oxygenation changes in the prefrontal cortex. Traces show oxygenated (HbO) and deoxygenated (HbR) hemoglobin concentration. Increases in HbO indicate increased neural activity in that region.",
                ),
                h(
                  "div",
                  {
                    style: {
                      display: "flex",
                      gap: 6,
                      marginBottom: 8,
                      justifyContent: "center",
                    },
                  },
                  ["HbO", "HbR", "HbT"].map(function (ch) {
                    var chColors = {
                      HbO: "#ef4444",
                      HbR: "#22c55e",
                      HbT: "#3b82f6",
                    };
                    var chLabels = {
                      HbO: "HbO (Oxy)",
                      HbR: "HbR (Deoxy)",
                      HbT: "HbT (Total)",
                    };
                    return h(
                      "label",
                      {
                        key: ch,
                        style: {
                          display: "flex",
                          alignItems: "center",
                          gap: 4,
                          padding: "4px 8px",
                          borderRadius: 6,
                          border:
                            "2px solid " +
                            (fnirsToggles[ch] ? chColors[ch] : th.bd),
                          background: fnirsToggles[ch]
                            ? chColors[ch] + "20"
                            : th.c2,
                          cursor: "pointer",
                          fontSize: 8,
                          fontWeight: 600,
                        },
                      },
                      h("input", {
                        type: "checkbox",
                        checked: fnirsToggles[ch],
                        onChange: function () {
                          var next = {};
                          Object.keys(fnirsToggles).forEach(function (k) {
                            next[k] = fnirsToggles[k];
                          });
                          next[ch] = !next[ch];
                          setFnirsToggles(next);
                        },
                        style: { width: 12, height: 12 },
                      }),
                      h(
                        "span",
                        {
                          style: {
                            color: fnirsToggles[ch] ? chColors[ch] : th.t3,
                          },
                        },
                        chLabels[ch],
                      ),
                    );
                  }),
                ),
                h(AuxPanel, {
                  t: th,
                  time: time,
                  dev: dev,
                  kind: "fnirs",
                  auxOn: auxOn,
                  autoScale: autoScales.fnirs,
                  yAxisRange: yAxisRanges.fnirs,
                  fnirsToggles: fnirsToggles,
                }),
                h(ScaleControls, {
                  t: th,
                  viewId: "fnirs",
                  autoScale: autoScales.fnirs,
                  yAxisRange: yAxisRanges.fnirs,
                  setAutoScales: setAutoScales,
                  setYAxisRanges: setYAxisRanges,
                }),
              ),
            displayMode === "single" &&
              view === "ppg" &&
              h(
                Card,
                { t: th, title: "PPG / Heart Rate" },
                h(
                  "div",
                  { style: { fontSize: 8, color: th.t3, marginBottom: 6 } },
                  "Photoplethysmography measures blood volume pulse via infrared light. The BPM readout is smoothed. The waveform shows the cardiac cycle. Heart rate variability (HRV) can be observed in the spacing between peaks.",
                ),
                h(AuxPanel, {
                  t: th,
                  time: time,
                  dev: dev,
                  kind: "ppg",
                  auxOn: auxOn,
                  autoScale: autoScales.ppg,
                  yAxisRange: yAxisRanges.ppg,
                }),
                h(ScaleControls, {
                  t: th,
                  viewId: "ppg",
                  autoScale: autoScales.ppg,
                  yAxisRange: yAxisRanges.ppg,
                  setAutoScales: setAutoScales,
                  setYAxisRanges: setYAxisRanges,
                }),
              ),
            displayMode === "single" &&
              view === "imu" &&
              h(
                Card,
                { t: th, title: "IMU \u2014 Motion Sensors" },
                h(
                  "div",
                  { style: { fontSize: 8, color: th.t3, marginBottom: 6 } },
                  "6-axis inertial measurement unit: accelerometer (AccX/Y/Z in g-force, Z\u22489.8 at rest) and gyroscope (GyroX/Y/Z in \u00B0/s). Useful for detecting head movement artifacts and meditation stillness.",
                ),
                h(AuxPanel, {
                  t: th,
                  time: time,
                  dev: dev,
                  kind: "imu",
                  auxOn: auxOn,
                  autoScale: autoScales.imu,
                  yAxisRange: yAxisRanges.imu,
                }),
                h(ScaleControls, {
                  t: th,
                  viewId: "imu",
                  autoScale: autoScales.imu,
                  yAxisRange: yAxisRanges.imu,
                  setAutoScales: setAutoScales,
                  setYAxisRanges: setYAxisRanges,
                }),
              ),

            displayMode === "single" &&
              view === "oscmon" &&
              h(Card, { t: th, title: "OSC Stream Monitor" }, h(OSCMonitor)),

            displayMode === "single" &&
              view === "quad" &&
              h(
                "div",
                {
                  style: {
                    display: "grid",
                    gridTemplateColumns: "1fr 1fr",
                    gridTemplateRows: "minmax(240px,1fr) minmax(240px,1fr)",
                    gap: 8,
                    minHeight: 520,
                  },
                },
                [0, 1, 2, 3].map(function (qi) {
                  var panelId = quadPanels[qi];
                  var panelLabel =
                    (
                      displayOpts.find(function (o) {
                        return o.id === panelId;
                      }) || {}
                    ).l || "Select";
                  return h(
                    "div",
                    {
                      key: qi,
                      style: {
                        background: th.c1,
                        borderRadius: 10,
                        border: "1px solid " + th.bd,
                        overflow: "hidden",
                        display: "flex",
                        flexDirection: "column",
                      },
                    },
                    // Quadrant header with dropdown
                    h(
                      "div",
                      {
                        style: {
                          padding: "4px 8px",
                          borderBottom: "1px solid " + th.bd,
                          display: "flex",
                          justifyContent: "space-between",
                          alignItems: "center",
                          background: th.c2,
                          flexShrink: 0,
                        },
                      },
                      h(
                        "span",
                        {
                          style: {
                            fontSize: 8,
                            fontWeight: 700,
                            color: th.t3,
                          },
                        },
                        ["A", "B", "C", "D"][qi],
                      ),
                      h(
                        "select",
                        {
                          value: panelId,
                          onChange: function (e) {
                            setQuadPanels(function (p) {
                              var n = p.slice();
                              n[qi] = e.target.value;
                              return n;
                            });
                          },
                          style: {
                            padding: "2px 4px",
                            borderRadius: 4,
                            border: "1px solid " + th.bd,
                            background: th.sg,
                            color: th.tx,
                            fontSize: 8,
                            fontFamily: M,
                            maxWidth: 140,
                          },
                        },
                        displayOpts.map(function (o) {
                          return h("option", { key: o.id, value: o.id }, o.l);
                        }),
                      ),
                    ),
                    // Quadrant content
                    h(
                      "div",
                      {
                        style: {
                          padding: 8,
                          flex: 1,
                          overflow: "auto",
                          minHeight: 0,
                        },
                      },
                      renderPanel(panelId),
                    ),
                  );
                }),
              ),

            displayMode === "single" &&
              view === "proc" &&
              h(
                "div",
                {
                  style: {
                    display: "grid",
                    gridTemplateColumns: "340px 1fr",
                    gap: 12,
                    minHeight: 300,
                  },
                },
                // LEFT: Filter controls panel
                h(
                  Card,
                  { t: th, title: "Signal Processing" },
                  h(
                    "div",
                    null,
                    ["Filter", "Smooth", "Gate", "Shape"].map(function (cat) {
                      return h(
                        "div",
                        { key: cat, style: { marginBottom: 8 } },
                        h(
                          "div",
                          {
                            style: {
                              fontSize: 8,
                              fontWeight: 700,
                              color: th.t3,
                              textTransform: "uppercase",
                              letterSpacing: ".05em",
                              marginBottom: 3,
                            },
                          },
                          cat,
                        ),
                        h(
                          "div",
                          {
                            style: {
                              display: "flex",
                              flexWrap: "wrap",
                              gap: 3,
                            },
                          },
                          PROCS.filter(function (p) {
                            return p.cat === cat;
                          }).map(function (p) {
                            return h(
                              "button",
                              {
                                key: p.id,
                                onClick: function () {
                                  setPid(p.id);
                                },
                                style: {
                                  padding: "4px 8px",
                                  borderRadius: 6,
                                  border:
                                    "1px solid " +
                                    (pid === p.id ? th.ac : th.bd),
                                  background:
                                    pid === p.id ? th.ac + "18" : "transparent",
                                  fontSize: 9,
                                  fontWeight: pid === p.id ? 700 : 400,
                                  color: pid === p.id ? th.ac : th.tx,
                                },
                              },
                              p.n,
                            );
                          }),
                        ),
                      );
                    }),
                    h(
                      "div",
                      {
                        style: {
                          marginTop: 8,
                          padding: "8px 10px",
                          borderRadius: 8,
                          background: th.sg,
                          border: "1px solid " + th.bd,
                        },
                      },
                      h(
                        "div",
                        {
                          style: {
                            fontSize: 10,
                            fontWeight: 700,
                            color: th.t2,
                            marginBottom: 4,
                          },
                        },
                        "Active: " +
                          (
                            PROCS.find(function (p) {
                              return p.id === pid;
                            }) || {}
                          ).n,
                      ),
                      (pid === "lp" || pid === "ema" || pid === "hp") &&
                        h(
                          "div",
                          {
                            style: {
                              display: "flex",
                              alignItems: "center",
                              gap: 6,
                            },
                          },
                          h(
                            "span",
                            {
                              style: {
                                fontSize: 9,
                                color: th.t2,
                                width: 50,
                              },
                            },
                            "Alpha",
                          ),
                          h("input", {
                            type: "range",
                            min: 0.01,
                            max: 0.99,
                            step: 0.01,
                            value: fp.a || 0.2,
                            onChange: function (e) {
                              setFp(
                                Object.assign({}, fp, {
                                  a: +e.target.value,
                                }),
                              );
                            },
                            style: { flex: 1, accentColor: th.ac },
                          }),
                          h(
                            "span",
                            {
                              style: {
                                fontSize: 9,
                                color: th.ac,
                                fontFamily: M,
                              },
                            },
                            (fp.a || 0.2).toFixed(2),
                          ),
                        ),
                      pid === "notch" &&
                        h(
                          "div",
                          { style: { display: "flex", gap: 4 } },
                          [50, 60].map(function (f) {
                            return h(Pill, {
                              key: f,
                              on: (fp.nf || 60) === f,
                              fn: function () {
                                setFp(Object.assign({}, fp, { nf: f }));
                              },
                              c: th.ac,
                              t: th,
                              label: f + " Hz",
                            });
                          }),
                        ),
                      pid === "gate" &&
                        h(
                          "div",
                          {
                            style: {
                              display: "flex",
                              alignItems: "center",
                              gap: 6,
                            },
                          },
                          h(
                            "span",
                            {
                              style: {
                                fontSize: 9,
                                color: th.t2,
                                width: 60,
                              },
                            },
                            "Threshold",
                          ),
                          h("input", {
                            type: "range",
                            min: 1,
                            max: 80,
                            step: 1,
                            value: fp.gt || 20,
                            onChange: function (e) {
                              setFp(
                                Object.assign({}, fp, {
                                  gt: +e.target.value,
                                }),
                              );
                            },
                            style: { flex: 1, accentColor: th.ac },
                          }),
                          h(
                            "span",
                            {
                              style: {
                                fontSize: 9,
                                color: th.ac,
                                fontFamily: M,
                              },
                            },
                            fp.gt || 20,
                          ),
                        ),
                      pid === "hyst" &&
                        h(
                          Fragment,
                          null,
                          h(
                            "div",
                            {
                              style: {
                                display: "flex",
                                alignItems: "center",
                                gap: 6,
                              },
                            },
                            h(
                              "span",
                              {
                                style: {
                                  fontSize: 9,
                                  color: th.t2,
                                  width: 60,
                                },
                              },
                              "High",
                            ),
                            h("input", {
                              type: "range",
                              min: 10,
                              max: 100,
                              step: 1,
                              value: fp.hi || 40,
                              onChange: function (e) {
                                setFp(
                                  Object.assign({}, fp, {
                                    hi: +e.target.value,
                                  }),
                                );
                              },
                              style: { flex: 1, accentColor: th.ac },
                            }),
                            h(
                              "span",
                              {
                                style: {
                                  fontSize: 9,
                                  color: th.ac,
                                  fontFamily: M,
                                },
                              },
                              fp.hi || 40,
                            ),
                          ),
                          h(
                            "div",
                            {
                              style: {
                                display: "flex",
                                alignItems: "center",
                                gap: 6,
                                marginTop: 4,
                              },
                            },
                            h(
                              "span",
                              {
                                style: {
                                  fontSize: 9,
                                  color: th.t2,
                                  width: 60,
                                },
                              },
                              "Low",
                            ),
                            h("input", {
                              type: "range",
                              min: 1,
                              max: 80,
                              step: 1,
                              value: fp.lo || 20,
                              onChange: function (e) {
                                setFp(
                                  Object.assign({}, fp, {
                                    lo: +e.target.value,
                                  }),
                                );
                              },
                              style: { flex: 1, accentColor: th.ac },
                            }),
                            h(
                              "span",
                              {
                                style: {
                                  fontSize: 9,
                                  color: th.ac,
                                  fontFamily: M,
                                },
                              },
                              fp.lo || 20,
                            ),
                          ),
                        ),
                      (pid === "savgol" ||
                        pid === "median" ||
                        pid === "rms" ||
                        pid === "gauss") &&
                        h(
                          "div",
                          {
                            style: {
                              display: "flex",
                              alignItems: "center",
                              gap: 6,
                            },
                          },
                          h(
                            "span",
                            {
                              style: {
                                fontSize: 9,
                                color: th.t2,
                                width: 60,
                              },
                            },
                            "Window",
                          ),
                          h("input", {
                            type: "range",
                            min: 3,
                            max: 21,
                            step: 2,
                            value: fp.win || 7,
                            onChange: function (e) {
                              setFp(
                                Object.assign({}, fp, {
                                  win: +e.target.value,
                                }),
                              );
                            },
                            style: { flex: 1, accentColor: th.ac },
                          }),
                          h(
                            "span",
                            {
                              style: {
                                fontSize: 9,
                                color: th.ac,
                                fontFamily: M,
                              },
                            },
                            fp.win || 7,
                          ),
                        ),
                      pid === "thresh" &&
                        h(
                          "div",
                          {
                            style: {
                              display: "flex",
                              alignItems: "center",
                              gap: 6,
                            },
                          },
                          h(
                            "span",
                            {
                              style: {
                                fontSize: 9,
                                color: th.t2,
                                width: 60,
                              },
                            },
                            "Threshold",
                          ),
                          h("input", {
                            type: "range",
                            min: 1,
                            max: 80,
                            step: 1,
                            value: fp.th || 30,
                            onChange: function (e) {
                              setFp(
                                Object.assign({}, fp, {
                                  th: +e.target.value,
                                }),
                              );
                            },
                            style: { flex: 1, accentColor: th.ac },
                          }),
                          h(
                            "span",
                            {
                              style: {
                                fontSize: 9,
                                color: th.ac,
                                fontFamily: M,
                              },
                            },
                            fp.th || 30,
                          ),
                        ),
                      pid === "slew" &&
                        h(
                          "div",
                          {
                            style: {
                              display: "flex",
                              alignItems: "center",
                              gap: 6,
                            },
                          },
                          h(
                            "span",
                            {
                              style: {
                                fontSize: 9,
                                color: th.t2,
                                width: 60,
                              },
                            },
                            "Rate",
                          ),
                          h("input", {
                            type: "range",
                            min: 0.5,
                            max: 30,
                            step: 0.5,
                            value: fp.sr || 5,
                            onChange: function (e) {
                              setFp(
                                Object.assign({}, fp, {
                                  sr: +e.target.value,
                                }),
                              );
                            },
                            style: { flex: 1, accentColor: th.ac },
                          }),
                          h(
                            "span",
                            {
                              style: {
                                fontSize: 9,
                                color: th.ac,
                                fontFamily: M,
                              },
                            },
                            fp.sr || 5,
                          ),
                        ),
                      pid === "clip" &&
                        h(
                          "div",
                          {
                            style: {
                              display: "flex",
                              alignItems: "center",
                              gap: 6,
                            },
                          },
                          h(
                            "span",
                            {
                              style: {
                                fontSize: 9,
                                color: th.t2,
                                width: 60,
                              },
                            },
                            "Drive",
                          ),
                          h("input", {
                            type: "range",
                            min: 0.005,
                            max: 0.2,
                            step: 0.005,
                            value: fp.cd || 0.05,
                            onChange: function (e) {
                              setFp(
                                Object.assign({}, fp, {
                                  cd: +e.target.value,
                                }),
