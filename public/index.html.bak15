                            : "Toggle 'OSC Sending' in the header to start",
                        ),
                        h(
                          "span",
                          {
                            style: {
                              fontSize: 7,
                              padding: "1px 6px",
                              borderRadius: 4,
                              fontWeight: 700,
                              background:
                                bridgeStatus === "server"
                                  ? th.gd + "20"
                                  : "#f59e0b20",
                              color:
                                bridgeStatus === "server" ? th.gd : "#f59e0b",
                            },
                          },
                          bridgeStatus === "server"
                            ? "\u25CF Backend Connected"
                            : "\u25CB Standalone",
                        ),
                      ),
                    ),
                    h(
                      "button",
                      {
                        onClick: function () {
                          setOscSending(!oscSending);
                        },
                        style: {
                          padding: "5px 14px",
                          borderRadius: 7,
                          border: "1px solid " + (oscSending ? th.rd : th.gd),
                          background: oscSending ? th.rd + "15" : th.gd + "15",
                          color: oscSending ? th.rd : th.gd,
                          fontSize: 10,
                          fontWeight: 700,
                        },
                      },
                      oscSending
                        ? "\u23F9 Stop Sending"
                        : "\u25B6 Start Sending",
                    ),
                  ),

                  // Filtered/Raw
                  h(
                    "div",
                    {
                      style: {
                        display: "flex",
                        alignItems: "center",
                        justifyContent: "space-between",
                        padding: "8px 10px",
                        borderRadius: 8,
                        background: oscFilt ? th.ac + "10" : th.sg,
                        border: "1px solid " + (oscFilt ? th.ac + "40" : th.bd),
