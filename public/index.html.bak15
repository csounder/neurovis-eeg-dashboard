                      pid === "deltafilt" &&
                        h(
                          "div",
                          { style: { fontSize: 9, color: th.t3 } },
                          "High-pass filter at ~4 Hz. Removes slow delta-band drift and low-frequency noise that dominates raw EEG. Useful when delta overwhelms other bands.",
                        ),
                      pid === "none" &&
                        h(
                          "div",
                          { style: { fontSize: 9, color: th.t3 } },
                          "Bypass \u2014 no processing",
                        ),
                    ),
                  ),
                ),
                // RIGHT: Live data display
                h(
                  "div",
                  {
                    style: {
                      display: "flex",
                      flexDirection: "column",
                      gap: 12,
                    },
                  },
                  h(
                    Card,
                    {
                      t: th,
                      title:
                        "Live Data \u2014 " +
                        BANDS[bi].n +
                        " (" +
                        ((
                          PROCS.find(function (p) {
                            return p.id === pid;
                          }) || {}
                        ).n || "Bypass") +
                        ")",
                    },
                    h(PowerTL, {
                      t: th,
                      time: time,
                      dev: dev,
                      bands: sBands,
                      pid: pid,
                      fp: fp,
                      chs: sChs,
                      autoScale: autoScales.timeline,
                      yAxisRange: yAxisRanges.timeline,
                    }),
                    h(ScaleControls, {
                      t: th,
                      viewId: "timeline",
                      autoScale: autoScales.timeline,
                      yAxisRange: yAxisRanges.timeline,
                      setAutoScales: setAutoScales,
                      setYAxisRanges: setYAxisRanges,
                    }),
                  ),
                  h(
                    Card,
                    { t: th, title: "Topo \u2014 " + BANDS[bi].n },
                    h(TopoSVG, {
                      t: th,
                      time: time,
                      dev: dev,
                      bi: bi,
                      skin: skin,
                      pid: pid,
                      fp: fp,
                    }),
                  ),
                ),
              ),

            displayMode === "single" &&
              view === "osc" &&
              h(
                Card,
                { t: th, title: "OSC Output" },
                h(
                  "div",
                  null,
                  // Send status + bridge status
                  h(
                    "div",
                    {
                      style: {
                        display: "flex",
                        alignItems: "center",
                        justifyContent: "space-between",
                        padding: "8px 10px",
                        borderRadius: 8,
                        background: oscSending ? th.gd + "10" : th.sg,
                        border:
                          "1px solid " + (oscSending ? th.gd + "40" : th.bd),
                        marginBottom: 10,
                      },
                    },
                    h(
                      "div",
                      null,
                      h(
                        "div",
                        {
                          style: {
                            fontSize: 11,
                            fontWeight: 700,
                            color: oscSending ? th.gd : th.tx,
                          },
                        },
                        oscSending ? "OSC Streaming Active" : "OSC Stopped",
                      ),
                      h(
                        "div",
                        {
                          style: {
                            display: "flex",
                            alignItems: "center",
                            gap: 6,
                            marginTop: 2,
