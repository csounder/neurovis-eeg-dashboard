                        ),
                      pid === "artifact" &&
                        h(
                          "div",
                          {
                            style: {
                              display: "flex",
                              alignItems: "center",
                              gap: 6,
                            },
                          },
                          h(
                            "span",
                            {
                              style: {
                                fontSize: 9,
                                color: th.t2,
                                width: 60,
                              },
                            },
                            "Reject >",
                          ),
                          h("input", {
                            type: "range",
                            min: 20,
                            max: 150,
                            step: 5,
                            value: fp.at || 80,
                            onChange: function (e) {
                              setFp(
                                Object.assign({}, fp, {
                                  at: +e.target.value,
                                }),
                              );
                            },
                            style: { flex: 1, accentColor: th.ac },
