<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <!-- CACHE BUSTING - Force browser to reload fresh version -->
    <meta
      http-equiv="Cache-Control"
      content="no-cache, no-store, must-revalidate"
    />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />
    <title>NeuroVis EEG v1.15 — 01:53 AM</title>
    <!-- VERSION: HARDWARE_SELECTOR_FULL_2026-04-19-01:53 -->
    <style>
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      body {
        font-family: "IBM Plex Sans", system-ui, sans-serif;
        overflow-x: hidden;
      }
      ::-webkit-scrollbar {
        width: 5px;
        height: 5px;
      }
      ::-webkit-scrollbar-thumb {
        background: #1a2540;
        border-radius: 3px;
      }
      button,
      select {
        font-family: inherit;
        cursor: pointer;
      }
      input[type="range"] {
        height: 4px;
        border-radius: 2px;
      }
      @keyframes pulse {
        0%,
        100% {
          opacity: 1;
        }
        50% {
          opacity: 0.3;
        }
      }
      @keyframes spin {
        to {
          transform: rotate(360deg);
        }
      }
      canvas {
        display: block;
      }
    </style>
  </head>
  <body>
    <div id="root"></div>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/react/18.2.0/umd/react.production.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/react-dom/18.2.0/umd/react-dom.production.min.js"></script>
    <script>
      const h = React.createElement,
        { useState, useEffect, useRef, useCallback, Fragment } = React;
      const M = "'JetBrains Mono',monospace";
      window._nv_signal = true; // default: simulator on

      // ── Live Data Ingestion (from BrainFlow backend) ──
      // When _liveData is populated, bpow/bpowAbs read from it instead of simulator
      var _liveData = {}; // keyed by "channelId_bandIndex" → normalized 0-1 value
      var _liveRaw = {}; // keyed by "channelId_bandIndex" → absolute µV² value
      var _liveQuality = {}; // keyed by channelId → 0-1 quality
      var _liveActive = false;
      var _simulatorEnabled = false; // Global flag for simulator state
      var _livePollTimer = null;

      // Band name → index mapping matching BANDS array
      var _bandNameToIdx = { delta: 0, theta: 1, alpha: 2, beta: 3, gamma: 4 };

      function _startLivePoll() {
        if (_livePollTimer) return;
        _liveActive = true;
        window._nv_signal = true; // Enable live data display mode
        console.log("[NeuroVis] Live polling started — using real Muse data");
        var _logCount = 0;
        _livePollTimer = setInterval(function () {
          fetch("/api/bands")
            .then(function (r) {
              return r.json();
            })
            .then(function (j) {
              if (!j.channels || j.channels.length === 0) return;
              if (_logCount < 3) {
                console.log(
                  "[NeuroVis] ✓ Real Muse data:",
                  j.channels.length,
                  "channels,",
                  j.bands.join("/"),
                  ", sample values:",
                  j.values[0] &&
                    j.values[0].map(function (v) {
                      return v.toFixed(2);
                    }),
                );
                _logCount++;
              }
              // j.channels = ["CH1","CH2",...] or ["TP9","AF7",...]
              // j.bands = ["delta","theta","alpha","beta","gamma"]
              // j.values = [[ch1_delta,ch1_theta,...],[ch2_delta,...]]
              for (var ci = 0; ci < j.channels.length; ci++) {
                var chId = j.channels[ci];
                var chVals = j.values[ci] || [];
                var totalPow = 0;
                for (var k = 0; k < chVals.length; k++)
                  totalPow += Math.abs(chVals[k]);
                for (var bi = 0; bi < j.bands.length; bi++) {
                  var bIdx = _bandNameToIdx[j.bands[bi]];
                  if (bIdx === undefined) continue;
                  var key = chId + "_" + bIdx;
                  var raw = Math.abs(chVals[bi] || 0);
                  // Normalize to 0-1 for display (relative %)
                  _liveData[key] =
                    totalPow > 0 ? Math.min(1, raw / totalPow) : 0;
                  _liveRaw[key] = raw;
                }
                // Signal quality from data presence
                _liveQuality[chId] =
                  totalPow > 0.1 ? Math.min(1, 0.5 + totalPow * 0.005) : 0.1;
              }
            })
            .catch(function () {});
        }, 100); // 10 Hz polling
      }
      function _stopLivePoll() {
        _liveActive = false;
        if (_livePollTimer) {
          clearInterval(_livePollTimer);
          _livePollTimer = null;
        }
        _liveData = {};
        _liveRaw = {};
        _liveQuality = {};
      }

      // Auto-detect if backend is already streaming (started from /control page)
      (function _autoDetectStreaming() {
        fetch("/api/status")
          .then(function (r) {
            return r.json();
          })
          .then(function (j) {
            if (j.streaming) {
              console.log(
                "[NeuroVis Dashboard] Backend already streaming — starting live data feed",
              );
              window._nv_signal = true;
              _startLivePoll();
            }
          })
          .catch(function () {});
        // Keep checking every 3 seconds in case user starts streaming from control panel
        setInterval(function () {
          fetch("/api/status")
            .then(function (r) {
              return r.json();
            })
            .then(function (j) {
              if (j.streaming && !_liveActive) {
                console.log(
                  "[NeuroVis Dashboard] Streaming detected — starting live data feed",
                );
                window._nv_signal = true;
                _startLivePoll();
              } else if (!j.streaming && _liveActive) {
                console.log("[NeuroVis Dashboard] Streaming stopped");
                _stopLivePoll();
              }
            })
            .catch(function () {});
        }, 3000);
      })();

      // ── Device Profiles ──
      const DEVS = {
        muse_s: {
          name: "MUSE S (Athena)",
          brand: "Interaxon",
          ch: 4,
          hz: 256,
          addr: "MUSE-S-FDE6",
          icon: "\u{1F9D8}",
          color: "#7c3aed",
          eeg: [
            { id: "TP9", x: 14, y: 55 },
            { id: "AF7", x: 25, y: 20 },
            { id: "AF8", x: 75, y: 20 },
            { id: "TP10", x: 86, y: 55 },
          ],
          aux: {
            fnirs: {
              ch: ["HbO", "HbR", "HbT"],
              d: "Near-infrared spectroscopy",
            },
            ppg: { ch: ["PPG1", "PPG2", "PPG3"], d: "Heart rate" },
            imu: {
              ch: ["AccX", "AccY", "AccZ", "GyroX", "GyroY", "GyroZ"],
              d: "6-axis motion",
            },
          },
        },
        muse_2: {
          name: "MUSE 2",
          brand: "Interaxon",
          ch: 4,
          hz: 256,
          addr: "MUSE-2-A31B",
          icon: "\u{1F9D8}",
          color: "#0891b2",
          eeg: [
            { id: "TP9", x: 14, y: 55 },
            { id: "AF7", x: 25, y: 20 },
            { id: "AF8", x: 75, y: 20 },
            { id: "TP10", x: 86, y: 55 },
          ],
          aux: {
            ppg: { ch: ["PPG1", "PPG2", "PPG3"], d: "Heart rate" },
            imu: {
              ch: ["AccX", "AccY", "AccZ", "GyroX", "GyroY", "GyroZ"],
              d: "6-axis motion",
            },
          },
        },
        ganglion: {
          name: "OpenBCI Ganglion",
          brand: "OpenBCI",
          ch: 4,
          hz: 200,
          addr: "Ganglion-8C4F",
          icon: "\u{1F52C}",
          color: "#059669",
          eeg: [
            { id: "Ch1", x: 35, y: 28 },
            { id: "Ch2", x: 65, y: 28 },
            { id: "Ch3", x: 35, y: 68 },
            { id: "Ch4", x: 65, y: 68 },
          ],
          aux: {},
        },
        ultracortex: {
          name: "OpenBCI Ultracortex",
          brand: "OpenBCI",
          ch: 16,
          hz: 250,
          addr: "UCortex-72E1",
          icon: "\u{1F9E0}",
          color: "#dc2626",
          eeg: [
            { id: "Fp1", x: 38, y: 12 },
            { id: "Fp2", x: 62, y: 12 },
            { id: "F7", x: 18, y: 28 },
            { id: "F3", x: 35, y: 28 },
            { id: "F4", x: 65, y: 28 },
            { id: "F8", x: 82, y: 28 },
            { id: "T3", x: 10, y: 50 },
            { id: "C3", x: 32, y: 48 },
            { id: "C4", x: 68, y: 48 },
            { id: "T4", x: 90, y: 50 },
            { id: "P3", x: 35, y: 68 },
            { id: "P4", x: 65, y: 68 },
            { id: "T5", x: 18, y: 70 },
            { id: "T6", x: 82, y: 70 },
            { id: "O1", x: 38, y: 86 },
            { id: "O2", x: 62, y: 86 },
          ],
          aux: {},
        },
      };

      const BANDS = [
        { n: "Delta", r: "0.5-4", c: "#6366f1", d: "#a5b4fc", f: 2, a: 40 },
        { n: "Theta", r: "4-8", c: "#0891b2", d: "#22d3ee", f: 6, a: 35 },
        { n: "Alpha", r: "8-13", c: "#059669", d: "#34d399", f: 10, a: 50 },
        { n: "Beta", r: "13-30", c: "#d97706", d: "#fbbf24", f: 20, a: 25 },
        { n: "Gamma", r: "30-100", c: "#dc2626", d: "#f87171", f: 45, a: 12 },
      ];

      const SKINS = [
        { brain: "#fde8d0", skull: "#f5d6b8", sulci: "#c9868b" },
        { brain: "#e8c9a0", skull: "#d4b08c", sulci: "#b07070" },
        { brain: "#c8a882", skull: "#b8956e", sulci: "#985858" },
        { brain: "#a08060", skull: "#8c6e50", sulci: "#804848" },
        { brain: "#785838", skull: "#6a4c30", sulci: "#683838" },
      ];

      const PROCS = [
        { id: "none", n: "Bypass", cat: "Filter" },
        { id: "lp", n: "Low Pass", cat: "Filter" },
        { id: "hp", n: "High Pass", cat: "Filter" },
        { id: "notch", n: "Notch 50/60", cat: "Filter" },
        { id: "bp", n: "Band Pass", cat: "Filter" },
        { id: "dc", n: "DC Block", cat: "Filter" },
        { id: "deltafilt", n: "Delta Suppress", cat: "Filter" },
        { id: "ema", n: "EMA", cat: "Smooth" },
        { id: "savgol", n: "Savitzky-Golay", cat: "Smooth" },
        { id: "median", n: "Median", cat: "Smooth" },
        { id: "kalman", n: "Kalman", cat: "Smooth" },
        { id: "rms", n: "RMS Env", cat: "Smooth" },
        { id: "gauss", n: "Gaussian", cat: "Smooth" },
        { id: "gate", n: "Noise Gate", cat: "Gate" },
        { id: "thresh", n: "Threshold", cat: "Gate" },
        { id: "hyst", n: "Hysteresis", cat: "Gate" },
        { id: "peak", n: "Peak Detect", cat: "Gate" },
        { id: "zerox", n: "Zero-Cross", cat: "Gate" },
        { id: "artifact", n: "Artifact Rej", cat: "Gate" },
        { id: "envf", n: "Env Follow", cat: "Shape" },
        { id: "slew", n: "Slew Limit", cat: "Shape" },
        { id: "clip", n: "Soft Clip", cat: "Shape" },
        { id: "rect", n: "Rectifier", cat: "Shape" },
      ];

      const TH = {
        dark: {
          isDark: true, // Use lighter band colors for dark backgrounds
          bg: "#060a14",
          c1: "#0c1222",
          c2: "#0a0f1c",
          bd: "#1a2540",
          tx: "#d8e2f0",
          t2: "#7e92b0",
          t3: "#4a5e7a",
          ac: "#6366f1",
          sg: "#070d1a",
          gd: "#22c55e",
          wr: "#eab308",
          rd: "#ef4444",
        },
        light: {
          isDark: false, // Use darker band colors for light backgrounds
          bg: "#edf1f7",
          c1: "#fff",
          c2: "#f4f6fa",
          bd: "#d4dae6",
          tx: "#1a2540",
          t2: "#4a5e7a",
          t3: "#8899b0",
          ac: "#4f46e5",
          sg: "#f7f9fd",
          gd: "#16a34a",
          wr: "#ca8a04",
          rd: "#dc2626",
        },
        highContrast: {
          isDark: true, // Use lighter band colors for black backgrounds
          bg: "#000000",
          c1: "#1a1a1a",
          c2: "#0d0d0d",
          bd: "#404040",
          tx: "#ffffff",
          t2: "#d0d0d0",
          t3: "#a0a0a0",
          ac: "#00ffff",
          sg: "#0a0a0a",
          gd: "#00ff00",
          wr: "#ffff00",
          rd: "#ff0000",
        },
      };

      // ── Signal Engine ──
      const _s = {};
      function gs(k) {
        if (!_s[k]) _s[k] = { p: 0, b: [], kP: 1, kX: 0, env: 0, hy: 0, pv: 0 };
        return _s[k];
      }
      function rawEEG(t, id, bi) {
        const s = (id.charCodeAt(0) || 0) * 137 + (id.charCodeAt(1) || 0) * 31;
        const b = BANDS[bi],
          f = b.f,
          a = b.a,
          p = (s % 100) / 15;
        return (
          a *
            Math.sin(2 * Math.PI * f * t + p) *
            (0.7 + 0.3 * Math.sin(t * 0.5 + s)) +
          (a / 3) * Math.sin(2 * Math.PI * f * 1.3 * t + p * 2) +
          (Math.random() - 0.5) * a * 0.3
        );
      }
      function proc(v, pid, k, fp) {
        const f = gs(k);
        if (pid === "none") return v;
        if (pid === "lp") {
          const a = fp.a || 0.15;
          f.p = f.p * a + v * (1 - a);
          return f.p;
        }
        if (pid === "hp") {
          const a = fp.a || 0.95;
          const o = a * (f.p + v - (f.b[0] || v));
          f.b[0] = v;
          f.p = o;
          return o;
        }
        if (pid === "notch") {
          f.b.push(v);
          if (f.b.length > 3) f.b.shift();
          if (f.b.length < 3) return v;
          const w = (2 * Math.PI * (fp.nf || 60)) / 256;
          const r = 0.985;
          return (
            f.b[2] -
            2 * Math.cos(w) * f.b[1] +
            f.b[0] +
            2 * r * Math.cos(w) * f.p -
            r * r * f.b[2]
          );
        }
        if (pid === "bp")
          return proc(proc(v, "lp", k + "l", { a: 0.3 }), "hp", k + "h", {
            a: 0.9,
          });
        if (pid === "dc") {
          const r = 0.995;
          const o = v - f.p + r * (f.b[0] || 0);
          f.p = v;
          f.b[0] = o;
          return o;
        }
        if (pid === "deltafilt") {
          const a = 0.92;
          const o = a * (f.p + v - (f.b[0] || v));
          f.b[0] = v;
          f.p = o;
          return o;
        }
        if (pid === "ema") {
          const a = fp.a || 0.2;
          f.p = a * v + (1 - a) * f.p;
          return f.p;
        }
        if (pid === "savgol") {
          f.b.push(v);
          if (f.b.length > 7) f.b.shift();
          if (f.b.length < 7) return v;
          const c = [-2, 3, 6, 7, 6, 3, -2];
          let s = 0,
            w = 0;
          f.b.forEach(function (x, i) {
            s += x * c[i];
            w += c[i];
          });
          return s / w;
        }
        if (pid === "median") {
          f.b.push(v);
          if (f.b.length > 5) f.b.shift();
          return f.b.slice().sort(function (a, b) {
            return a - b;
          })[Math.floor(f.b.length / 2)];
        }
        if (pid === "kalman") {
          f.kP += 0.1;
          var K = f.kP / (f.kP + 0.5);
          f.kX += K * (v - f.kX);
          f.kP *= 1 - K;
          return f.kX;
        }
        if (pid === "rms") {
          f.b.push(v * v);
          if (f.b.length > 16) f.b.shift();
          return Math.sqrt(
            f.b.reduce(function (a, b) {
              return a + b;
            }, 0) / f.b.length,
          );
        }
        if (pid === "gauss") {
          f.b.push(v);
          if (f.b.length > 7) f.b.shift();
          if (f.b.length < 3) return v;
          let s = 0,
            w = 0;
          f.b.forEach(function (x, i) {
            const g = Math.exp(-Math.pow(i - f.b.length / 2, 2) / 2);
            s += x * g;
            w += g;
          });
          return s / w;
        }
        if (pid === "gate") return Math.abs(v) < (fp.gt || 20) ? 0 : v;
        if (pid === "thresh") return Math.abs(v) > (fp.th || 30) ? 1 : 0;
        if (pid === "hyst") {
          if (Math.abs(v) > (fp.hi || 40)) f.hy = 1;
          if (Math.abs(v) < (fp.lo || 20)) f.hy = 0;
          return f.hy;
        }
        if (pid === "peak") {
          const p2 = f.b[0] || 0;
          f.b[0] = f.pv;
          f.pv = v;
          return f.pv > p2 && f.pv > v && f.pv > 10 ? f.pv : 0;
        }
        if (pid === "zerox") {
          const p = f.pv;
          f.pv = v;
          return (p >= 0 && v < 0) || (p < 0 && v >= 0) ? 1 : 0;
        }
        if (pid === "artifact") {
          if (Math.abs(v) > 80) {
            f.hy = 8;
            return 0;
          }
          if (f.hy > 0) {
            f.hy--;
            return 0;
          }
          return v;
        }
        if (pid === "envf") {
          const abs = Math.abs(v);
          f.env =
            abs > f.env
              ? 0.01 * abs + 0.99 * f.env
              : 0.001 * abs + 0.999 * f.env;
          return f.env;
        }
        if (pid === "slew") {
          const d = Math.max(-5, Math.min(5, v - f.p));
          f.p += d;
          return f.p;
        }
        if (pid === "clip") return Math.tanh(v * 0.05) / 0.05;
        if (pid === "rect") return Math.abs(v);
        return v;
      }
      function eeg(t, id, bi, pid, fp) {
        if (!window._nv_signal) return 0;
        // Use real live data if available
        if (_liveActive && _liveRaw[id + "_" + bi] !== undefined) {
          return (
            _liveRaw[id + "_" + bi] * 0.5 * (0.8 + 0.2 * Math.sin(t * 2 + bi))
          );
        }
        // Only generate simulated data if simulator is enabled
        if (!_simulatorEnabled) return 0;
        return proc(rawEEG(t, id, bi), pid, id + "_" + bi, fp);
      }
      // bpow returns normalized 0-1 for displays
      function bpow(t, id, bi, pid, fp) {
        if (!window._nv_signal) return 0;
        if (_liveActive && _liveData[id + "_" + bi] !== undefined)
          return _liveData[id + "_" + bi];
        return Math.min(1, Math.abs(eeg(t, id, bi, pid, fp)) / 60);
      }
      // bpowAbs returns Mind Monitor-compatible absolute power: log10(µV²/Hz), range ~0.0-3.0
      function bpowAbs(t, id, bi, pid, fp) {
        if (!window._nv_signal) return 0;
        if (_liveActive && _liveRaw[id + "_" + bi] !== undefined) {
          return Math.max(0, Math.log10(_liveRaw[id + "_" + bi] + 1) * 1.2);
        }
        var raw = Math.abs(eeg(t, id, bi, pid, fp));
        return Math.max(0, Math.log10(raw * raw + 1) * 1.2);
      }
      // bpowScaled returns value * user scale factor for OSC output
      var _oscScale = 1.0;
      function bpowOSC(t, id, bi, pid, fp) {
        return bpowAbs(t, id, bi, pid, fp) * _oscScale;
      }
      // Smoothed quality — uses live quality when available
      var _qualSmooth = {};
      function qual(id, t) {
        if (!window._nv_signal) return 0;
        if (_liveActive && _liveQuality[id] !== undefined) {
          if (!_qualSmooth[id]) _qualSmooth[id] = _liveQuality[id];
          _qualSmooth[id] = _qualSmooth[id] * 0.95 + _liveQuality[id] * 0.05;
          return _qualSmooth[id];
        }
        var s = (id.charCodeAt(0) || 0) * 7 + (id.charCodeAt(1) || 0) * 13;
        var raw = Math.max(
          0,
          Math.min(
            1,
            0.7 +
              0.25 * Math.sin(t * 0.008 + s * 0.3) +
              0.05 * Math.sin(t * 0.04 + s * 0.7),
          ),
        );
        if (!_qualSmooth[id]) _qualSmooth[id] = raw;
        _qualSmooth[id] = _qualSmooth[id] * 0.97 + raw * 0.03;
        return _qualSmooth[id];
      }
      // Smoothed band power for meters (avoids jumpiness in bar displays)
      var _meterSmooth = {};
      function bpowSmooth(t, id, bi, pid, fp) {
        var k = id + "_" + bi;
        var raw = bpow(t, id, bi, pid, fp);
        if (!_meterSmooth[k]) _meterSmooth[k] = raw;
        _meterSmooth[k] = _meterSmooth[k] * 0.92 + raw * 0.08;
        return _meterSmooth[k];
      }
      function qc(q, th) {
        return q > 0.8 ? th.gd : q > 0.6 ? th.wr : th.rd;
      }
      function simAux(t, ch) {
        if (!window._nv_signal)
          return ch.indexOf("PPG") === 0
            ? 0
            : ch.indexOf("Acc") === 0 && ch[3] === "Z"
              ? 9.8
              : 0;
        // Only generate simulated data if simulator is enabled
        if (!_simulatorEnabled)
          return ch.indexOf("Acc") === 0 && ch[3] === "Z" ? 9.8 : 0;
        // fNIRS: Realistic hemodynamic response simulation
        if (ch === "HbO" || ch === "HbR" || ch === "HbT") {
          // Three channels: HbO (oxygenated), HbR (deoxygenated), HbT (total)
          // Slow oscillations mimicking brain hemodynamics (0.05-0.2 Hz)
          var baseline = 0.5;
          var slowWave = 0.15 * Math.sin(t * 0.1); // ~0.016 Hz
          var taskResponse = 0.1 * Math.sin(t * 0.05 + ch.charCodeAt(2) * 3);
          var noise = (Math.random() - 0.5) * 0.01;

          if (ch === "HbO") {
            // HbO (oxygenated) - increases during activation
            return baseline + slowWave + taskResponse + noise + 0.1;
          } else if (ch === "HbR") {
            // HbR (deoxygenated) - decreases during activation (inverse)
            return baseline + slowWave - taskResponse * 0.7 + noise - 0.05;
          } else {
            // HbT (total) - sum of both
            return baseline + slowWave + taskResponse * 0.5 + noise + 0.05;
          }
        }
        if (ch.indexOf("PPG") === 0)
          return (
            72 +
            8 * Math.sin(t * 0.05) +
            3 * Math.sin(t * 1.2) +
            Math.random() * 2
          );
        if (ch.indexOf("Acc") === 0)
          return (
            (ch[3] === "Z" ? 9.8 : 0) +
            0.15 * Math.sin(t * 0.3 + ch.charCodeAt(3) * 5) +
            Math.random() * 0.08
          );
        if (ch.indexOf("Gyro") === 0)
          return (
            2 * Math.sin(t * 0.2 + ch.charCodeAt(4) * 3) + Math.random() * 0.5
          );
        return 0;
      }

      // ── UI Helpers ──
      function Card(p) {
        return h(
          "div",
          {
            style: {
              background: p.t.c1,
              borderRadius: 10,
              border: "1px solid " + p.t.bd,
              boxShadow: "0 4px 24px rgba(0,0,0,.3)",
              overflow: "hidden",
            },
          },
          p.title &&
            h(
              "div",
              {
                style: {
                  padding: "8px 12px",
                  borderBottom: "1px solid " + p.t.bd,
                  display: "flex",
                  justifyContent: "space-between",
                  alignItems: "center",
                  gap: 6,
                  flexWrap: "wrap",
                },
              },
              h("span", { style: { fontSize: 9, fontWeight: 700 } }, p.title),
              p.right,
            ),
          h("div", { style: { padding: 12 } }, p.children),
        );
      }

      function Pill(p) {
        return h(
          "button",
          {
            onClick: p.fn,
            style: {
              padding: "2px 8px",
              borderRadius: 12,
              border: "1px solid " + (p.on ? p.c : p.t.bd),
              background: p.on ? p.c + "20" : "transparent",
              color: p.on ? p.c : p.t.t3,
              fontSize: 8,
              fontWeight: 600,
              fontFamily: M,
              whiteSpace: "nowrap",
            },
          },
          p.label,
        );
      }

      // ── Device Connection Menu (uses NeurOSC Python backend + BrainFlow) ──
      var DEV_API_MAP = {
        muse_s: "muse_athena",
        muse_2: "muse_2",
        ganglion: "ganglion",
        ultracortex: "ganglion",
      };

      function ConnMenu(p) {
        var _s = useState(false),
          open = _s[0],
          setOpen = _s[1];
        var _bt = useState([]),
          btDevs = _bt[0],
          setBtDevs = _bt[1];
        var _pts = useState([]),
          ports = _pts[0],
          setPorts = _pts[1];
        var _sc = useState(false),
          scanning = _sc[0],
          setScanning = _sc[1];
        var _cng = useState(false),
          connecting = _cng[0],
          setConnecting = _cng[1];
        var _stg = useState(false),
          starting = _stg[0],
          setStarting = _stg[1];
        var _hw = useState(false),
          hwConn = _hw[0],
          setHwConn = _hw[1];
        var _str = useState(false),
          streaming = _str[0],
          setStreaming = _str[1];
        var _err = useState(""),
          connErr = _err[0],
          setConnErr = _err[1];
        var _sim = useState(false),
          useSim = _sim[0],
          setUseSim = _sim[1];

        // Sync global simulator flag
        useEffect(
          function () {
            _simulatorEnabled = useSim;
            console.log(
              "[NeuroVis] Simulator state changed:",
              useSim ? "ENABLED" : "DISABLED",
            );
          },
          [useSim],
        );
        var _smd = useState("normal"),
          simMode = _smd[0],
          setSimMd = _smd[1];

        // Granular OSC state (independent toggles)
        var _oscCh = useState({ CH1: true, CH2: true, CH3: true, CH4: true }),
          oscCh = _oscCh[0],
          setOscCh = _oscCh[1];
        var _oscBands = useState({
            delta: true,
            theta: true,
            alpha: true,
            beta: true,
            gamma: true,
          }),
          oscBands = _oscBands[0],
          setOscBands = _oscBands[1];
        var _oscVals = useState({
            absolute: true,
            relative: true,
            averages: true,
          }),
          oscVals = _oscVals[0],
          setOscVals = _oscVals[1];
        var th = p.t;

        function scanPorts() {
          setScanning(true);
          setConnErr("");
          fetch("/api/ports")
            .then(function (r) {
              return r.json();
            })
            .then(function (j) {
              setPorts(j.ports || []);
              setBtDevs(j.bluetooth || []);
              setScanning(false);
            })
            .catch(function () {
              setScanning(false);
              setConnErr("Backend not running. Start: python launcher.py");
            });
        }
        function toggleSim() {
          var next = !useSim;
          fetch("/api/use_simulator", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ enabled: next }),
          })
            .then(function (r) {
              return r.json();
            })
            .then(function (result) {
              console.log("[NeuroVis] Simulator toggle result:", result);
              setUseSim(next);
              if (next) {
                // Simulator is now generating data - start polling
                setHwConn(true);
                p.setPaired(p.dev);
                setStreaming(true);
                window._nv_signal = true;
                _startLivePoll();
                console.log("[NeuroVis] ✓ Simulator ON - live polling started");
              } else {
                // Stop simulator and polling
                _stopLivePoll();
                setStreaming(false);
                setHwConn(false);
                window._nv_signal = false;
                console.log("[NeuroVis] ✓ Simulator OFF - polling stopped");
              }
            })
            .catch(function (err) {
              console.error("[NeuroVis] Simulator toggle error:", err);
              setConnErr("Backend not running");
            });
        }
        function doSimMode(m) {
          fetch("/api/simulator/mode", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ mode: m }),
          })
            .then(function () {
              setSimMd(m);
            })
            .catch(function () {});
        }
        function doConnect() {
          setConnecting(true);
          setConnErr("");
          var apiDev = DEV_API_MAP[p.dev] || "ganglion";
          var macAddr = "";
          var deviceName = "";
          btDevs.forEach(function (bt) {
            if (bt.device_type === apiDev) {
              macAddr = bt.mac;
              deviceName = bt.name;
            }
          });
          var timeout = apiDev.indexOf("muse") >= 0 ? 30 : 15;
          console.log("[NeuroVis] Connecting:", {
            dev: p.dev,
            apiDev: apiDev,
            deviceName: deviceName,
            mac: macAddr,
            timeout: timeout,
          });

          // Helper function to send WebSocket message
          var tryWebSocketConnect = function (retries) {
            if (retries === undefined) retries = 10;

            if (window.ws && window.ws.readyState === WebSocket.OPEN) {
              console.log(
                "[NeuroVis] ✓ WebSocket OPEN — Sending select_device:",
                deviceName,
              );
              window.ws.send(
                JSON.stringify({
                  type: "select_device",
                  name: deviceName,
                }),
              );

              // Mark as connected and start streaming
              setHwConn(true);
              setConnecting(false);
              p.setPaired(p.dev);
              // DO NOT set window._nv_signal = true here!
              // Wait for real Muse data to arrive via _startLivePoll
              console.log(
                "[NeuroVis] Device paired - waiting for real Muse packets...",
              );

              fetch("/api/start", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ buffer_size: 45000 }),
              })
                .then(function (r2) {
                  return r2.json();
                })
                .then(function (j2) {
                  if (j2.status === "ok") {
                    setStreaming(true);
                    _startLivePoll();
                    console.log("[NeuroVis] ✓ Streaming started");
                  }
                })
                .catch(function () {});
            } else if (retries > 0) {
              console.log(
                "[NeuroVis] WebSocket not ready yet (readyState=" +
                  (window.ws ? window.ws.readyState : "undefined") +
                  "), retrying in 100ms... (" +
                  retries +
                  " attempts left)",
              );
              setTimeout(function () {
                tryWebSocketConnect(retries - 1);
              }, 100);
            } else {
              console.error(
                "[NeuroVis] WebSocket failed to connect, giving up",
              );
              setConnecting(false);
              setConnErr("WebSocket connection failed. Restart server.");
            }
          };

          // Start trying to connect via WebSocket
          tryWebSocketConnect();
        }
        function doStart() {
          setStarting(true);
          fetch("/api/start", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ buffer_size: 45000 }),
          })
            .then(function (r) {
              return r.json();
            })
            .then(function (j) {
              if (j.status === "ok") {
                setStreaming(true);
                setStarting(false);
                _startLivePoll();
              } else {
                setStarting(false);
                setConnErr(j.message || "Start failed");
              }
            })
            .catch(function (e) {
              setStarting(false);
              setConnErr(e.message);
            });
        }
        function doStop() {
          fetch("/api/stop", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({}),
          })
            .then(function () {
              setStreaming(false);
              _stopLivePoll();
            })
            .catch(function () {});
        }
        function doDisconnect() {
          fetch("/api/disconnect", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({}),
          })
            .then(function () {
              setHwConn(false);
              setStreaming(false);
              _stopLivePoll();
              p.setPaired(null);
            })
            .catch(function () {});
        }

        useEffect(
          function () {
            if (open && ports.length === 0 && !scanning) scanPorts();
          },
          [open],
        );

        // Register callback for server device_list messages
        useEffect(function () {
          // Store setBtDevs in global so app.js can call it when device_list arrives
          window._reactSetBtDevs = function (devices) {
            console.log(
              "[NeuroVis] Auto-updating device list from WebSocket:",
              devices.length,
              "devices",
            );
            console.log(
              "[NeuroVis] Received devices:",
              JSON.stringify(devices, null, 2),
            );
            setBtDevs(devices);
            // Auto-select the connected device
            if (devices.length > 0) {
              var deviceType =
                devices[0].device_type || devices[0].modelKey || "muse_2";
              console.log(
                "[NeuroVis] Auto-selecting device:",
                deviceType,
                "from device:",
                devices[0],
              );
              p.setDev(deviceType);
              p.setPaired(deviceType);
            }
          };
          return function () {
            window._reactSetBtDevs = null;
          };
        }, []);

        var statusCol = streaming ? th.gd : hwConn ? th.wr : th.t3;
        var statusText = streaming
          ? "\u25CF Streaming"
          : hwConn
            ? "Connected \u2014 press Start"
            : useSim
              ? "\u25B6 Simulator"
              : "Not connected";

        var btn = h(
          "button",
          {
            onClick: function () {
              setOpen(!open);
            },
            style: {
              display: "flex",
              alignItems: "center",
              gap: 5,
              padding: "4px 10px",
              borderRadius: 7,
              border:
                "1px solid " + (streaming ? th.gd : hwConn ? th.wr : th.bd),
              background: streaming
                ? th.gd + "08"
                : hwConn
                  ? th.wr + "08"
                  : th.c2,
              color: th.tx,
              fontSize: 9,
              fontWeight: 600,
            },
          },
          h("span", {
            style: {
              width: 6,
              height: 6,
              borderRadius: "50%",
              background: statusCol,
              flexShrink: 0,
            },
          }),
          p.paired
            ? h(Fragment, null, DEVS[p.paired].icon, " ", DEVS[p.paired].name)
            : h("span", { style: { color: th.t3 } }, "Connect Device..."),
          h(
            "span",
            { style: { fontSize: 7, opacity: 0.4, marginLeft: 3 } },
            open ? "\u25B2" : "\u25BC",
          ),
        );

        var dropdown =
          open &&
          h(
            "div",
            {
              style: {
                position: "absolute",
                top: "100%",
                right: 0,
                marginTop: 4,
                background: th.c1,
                border: "1px solid " + th.bd,
                borderRadius: 10,
                boxShadow: "0 8px 30px rgba(0,0,0,.5)",
                zIndex: 200,
                width: 420,
                overflow: "hidden",
                maxHeight: "80vh",
                overflowY: "auto",
              },
            },
            h(
              "div",
              {
                style: {
                  padding: "8px 14px",
                  background: statusCol + "10",
                  borderBottom: "1px solid " + th.bd,
                  display: "flex",
                  alignItems: "center",
                  gap: 6,
                },
              },
              h("div", {
                style: {
                  width: 8,
                  height: 8,
                  borderRadius: "50%",
                  background: statusCol,
                  animation: streaming ? "pulse 1.5s infinite" : "none",
                },
              }),
              h(
                "span",
                { style: { fontSize: 9, fontWeight: 600, color: statusCol } },
                statusText,
              ),
            ),
            connErr &&
              h(
                "div",
                {
                  style: {
                    padding: "4px 8px",
                    background: th.rd + "10",
                    borderBottom: "1px solid " + th.rd + "30",
                    fontSize: 8,
                    color: th.rd,
                  },
                },
                connErr,
              ),
            // Simulator toggle
            h(
              "div",
              {
                style: {
                  padding: "8px 14px",
                  borderBottom: "1px solid " + th.bd,
                  background: th.c2,
                },
              },
              h(
                "div",
                {
                  style: {
                    display: "flex",
                    alignItems: "center",
                    justifyContent: "space-between",
                    marginBottom: useSim ? 6 : 0,
                  },
                },
                h(
                  "div",
                  null,
                  h(
                    "span",
                    { style: { fontSize: 9, fontWeight: 700 } },
                    "Simulator",
                  ),
                  h(
                    "span",
                    { style: { fontSize: 8, color: th.t3, marginLeft: 6 } },
                    "Synthetic EEG for testing",
                  ),
                ),
                h(
                  "button",
                  {
                    onClick: toggleSim,
                    style: {
                      width: 34,
                      height: 18,
                      borderRadius: 9,
                      border: "none",
                      background: useSim ? th.wr : th.bd,
                      position: "relative",
                    },
                  },
                  h("div", {
                    style: {
                      width: 14,
                      height: 14,
                      borderRadius: 7,
                      background: "#fff",
                      position: "absolute",
                      top: 2,
                      left: useSim ? 18 : 2,
                      transition: "left .2s",
                    },
                  }),
                ),
              ),
              useSim &&
                h(
                  "div",
                  { style: { display: "flex", gap: 3 } },
                  ["normal", "meditation", "focused", "drowsy"].map(
                    function (m) {
                      return h(
                        "button",
                        {
                          key: m,
                          onClick: function () {
                            doSimMode(m);
                          },
                          style: {
                            padding: "2px 8px",
                            borderRadius: 10,
                            border:
                              "1px solid " + (simMode === m ? th.wr : th.bd),
                            background:
                              simMode === m ? th.wr + "18" : "transparent",
                            color: simMode === m ? th.wr : th.t3,
                            fontSize: 8,
                            fontWeight: 600,
                            textTransform: "capitalize",
                          },
                        },
                        m,
                      );
                    },
                  ),
                ),
            ),
            // Device selection
            h(
              "div",
              {
                style: {
                  padding: "10px 14px",
                  borderBottom: "1px solid " + th.bd,
                },
              },
              h(
                "div",
                {
                  style: {
                    fontSize: 9,
                    fontWeight: 600,
                    color: th.t2,
                    textTransform: "uppercase",
                    letterSpacing: ".05em",
                    marginBottom: 6,
                  },
                },
                "Select Device",
              ),
              h(
                "div",
                { style: { display: "flex", flexDirection: "column", gap: 3 } },
                Object.keys(DEVS).map(function (k) {
                  var dv = DEVS[k],
                    isSel = p.dev === k;
                  return h(
                    "div",
                    {
                      key: k,
                      onClick: function () {
                        p.setDev(k);
                      },
                      style: {
                        display: "flex",
                        alignItems: "center",
                        gap: 8,
                        padding: "6px 8px",
                        borderRadius: 7,
                        border:
                          "1px solid " + (isSel ? dv.color + "40" : th.bd),
                        background: isSel ? dv.color + "08" : "transparent",
                        cursor: "pointer",
                      },
                    },
                    h(
                      "div",
                      {
                        style: {
                          width: 28,
                          height: 28,
                          borderRadius: 7,
                          background: dv.color + "18",
                          display: "flex",
                          alignItems: "center",
                          justifyContent: "center",
                          fontSize: 13,
                        },
                      },
                      dv.icon,
                    ),
                    h(
                      "div",
                      { style: { flex: 1 } },
                      h(
                        "span",
                        {
                          style: {
                            fontSize: 9,
                            fontWeight: isSel ? 700 : 500,
                          },
                        },
                        dv.name,
                      ),
                      h(
                        "span",
                        { style: { fontSize: 8, color: th.t3, marginLeft: 6 } },
                        dv.ch + "ch " + dv.hz + "Hz",
                      ),
                    ),
                    isSel &&
                      h(
                        "span",
                        {
                          style: {
                            fontSize: 7,
                            color: dv.color,
                            fontWeight: 600,
                          },
                        },
                        "\u2713",
                      ),
                  );
                }),
              ),
            ),
            // Bluetooth / Serial ports
            !useSim &&
              h(
                "div",
                {
                  style: {
                    padding: "10px 14px",
                    borderBottom: "1px solid " + th.bd,
                  },
                },
                h(
                  "div",
                  {
                    style: {
                      display: "flex",
                      justifyContent: "space-between",
                      alignItems: "center",
                      marginBottom: 6,
                    },
                  },
                  h(
                    "span",
                    {
                      style: {
                        fontSize: 9,
                        fontWeight: 600,
                        color: th.t2,
                        textTransform: "uppercase",
                        letterSpacing: ".05em",
                      },
                    },
                    "Detected Devices",
                  ),
                  h(
                    "button",
                    {
                      onClick: scanPorts,
                      style: {
                        padding: "2px 8px",
                        borderRadius: 5,
                        border: "1px solid " + th.ac,
                        background: th.ac + "12",
                        color: th.ac,
                        fontSize: 8,
                        fontWeight: 600,
                      },
                    },
                    scanning ? "Scanning..." : "\u27F3 Scan",
                  ),
                ),
                // Calibration Controls (Log Transform + Z-Score)
                h(
                  "div",
                  {
                    style: {
                      display: "flex",
                      alignItems: "center",
                      gap: 6,
                      padding: "4px 8px",
                      borderRadius: 5,
                      border: "1px solid " + th.bd,
                      background: th.c2,
                    },
                  },
                  h(
                    "span",
                    {
                      style: {
                        fontSize: 9,
                        fontWeight: 600,
                        color: th.t2,
                        marginRight: 4,
                      },
                    },
                    "📊",
                  ),
                  h(
                    "label",
                    {
                      style: {
                        fontSize: 9,
                        cursor: "pointer",
                        display: "flex",
                        alignItems: "center",
                        gap: 4,
                        color: th.t2,
                      },
                    },
                    h("input", {
                      type: "checkbox",
                      checked: baseLog,
                      onChange: function (e) {
                        setBaseLog(e.target.checked);
                        fetch("/api/settings", {
                          method: "POST",
                          headers: { "Content-Type": "application/json" },
                          body: JSON.stringify({
                            logTransform: e.target.checked,
                          }),
                        });
                      },
                      style: { width: 13, height: 13, cursor: "pointer" },
                    }),
                    "Log",
                  ),
                  h(
                    "label",
                    {
                      style: {
                        fontSize: 9,
                        cursor: "pointer",
                        display: "flex",
                        alignItems: "center",
                        gap: 4,
                        color: th.t2,
                      },
                    },
                    h("input", {
                      type: "checkbox",
                      checked: baseNorm,
                      onChange: function (e) {
                        setBaseNorm(e.target.checked);
                        fetch("/api/settings", {
                          method: "POST",
                          headers: { "Content-Type": "application/json" },
                          body: JSON.stringify({ zScore: e.target.checked }),
                        });
                      },
                      style: { width: 13, height: 13, cursor: "pointer" },
                    }),
                    "Z-Score",
                  ),
                ),
                // Preset Selector
                h(
                  "select",
                  {
                    value: activePreset || "",
                    onChange: function (e) {
                      var presetId = e.target.value;
                      if (presetId) {
                        var preset = perfPresets.find(function (p) {
                          return p.id === presetId;
                        });
                        if (preset) loadPreset(preset);
                      }
                    },
                    style: {
                      fontSize: 9,
                      padding: "4px 8px",
                      borderRadius: 5,
                      border: "1px solid " + (activePreset ? "#10b981" : th.bd),
                      background: activePreset ? "#10b98115" : th.c2,
                      color: activePreset ? "#10b981" : th.t2,
                      fontWeight: 600,
                      cursor: "pointer",
                      minWidth: 180,
                    },
                  },
                  h("option", { value: "" }, "⚡ Load Preset..."),
                  perfPresets.map(function (preset, idx) {
                    return h(
                      "option",
                      { key: preset.id, value: preset.id },
                      idx + 1 + ". " + preset.name,
                    );
                  }),
                ),
                // Device Model Selector
                h(
                  "select",
                  {
                    value: deviceModel,
                    onChange: function (e) {
                      var newDevice = e.target.value;
                      setDeviceModel(newDevice);
                      fetch("/api/dsp/config", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ deviceModel: newDevice }),
                      });
                    },
                    style: {
                      fontSize: 9,
                      fontWeight: 600,
                      padding: "4px 8px",
                      borderRadius: 5,
                      border: "1px solid " + th.ac,
                      background: th.ac + "15",
                      color: th.ac,
                      cursor: "pointer",
                    },
                  },
                  h("option", { value: "Muse 2" }, "📱 Muse 2"),
                  h("option", { value: "Muse S" }, "📱 Muse S"),
                  h("option", { value: "Muse S (Athena)" }, "📱 Muse S Athena"),
                  h("option", { value: "OpenBCI Ganglion" }, "📱 Ganglion"),
                  h("option", { value: "OpenBCI Cyton" }, "📱 Cyton"),
                ),
                // OSC Toggle
                h(
                  "button",
                  {
                    onClick: function () {
                      var nextState = !oscSending;
                      setOscSending(nextState);
                      fetch("/api/settings", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ oscSending: nextState }),
                      });
                    },
                    style: {
                      padding: "4px 8px",
                      borderRadius: 5,
                      border: "1px solid " + (oscSending ? th.gd : th.bd),
                      background: oscSending ? th.gd + "20" : th.c2,
                      color: oscSending ? th.gd : th.t3,
                      fontSize: 9,
                      fontWeight: 600,
                      cursor: "pointer",
                    },
                  },
                  oscSending ? "↔️ OSC ON" : "↔️ OSC OFF",
                ),
                // OSC Monitor Button
                h(
                  "button",
                  {
                    onClick: function () {
                      if (view === "oscmon") {
                        // Turn OFF - go back to timeline
                        setView("timeline");
                      } else {
                        // Turn ON - show OSC Monitor
                        setView("oscmon");
                        setDisplayMode("single");
                      }
                    },
                    style: {
                      padding: "4px 8px",
                      borderRadius: 5,
                      border:
                        "1px solid " + (view === "oscmon" ? th.gd : th.bd),
                      background: view === "oscmon" ? th.gd + "20" : th.c2,
                      color: view === "oscmon" ? th.gd : th.t3,
                      fontSize: 9,
                      fontWeight: 600,
                      cursor: "pointer",
                    },
                  },
                  view === "oscmon"
                    ? "📡 OSC Monitor ON"
                    : "📡 OSC Monitor OFF",
                ),
              ),
            ),

            // ───────────────────────────────────────────────────────────────
            // ROW 2: Secondary Controls (larger, more info, more readable)
            // ───────────────────────────────────────────────────────────────
            h(
              "div",
              {
                style: {
                  display: "flex",
                  alignItems: "center",
                  justifyContent: "space-between",
                  padding: "10px 16px",
                  gap: 10,
                  flexWrap: "wrap",
                },
              },
              // Left group
              h(
                "div",
                { style: { display: "flex", alignItems: "center", gap: 8 } },
                // Recording controls
                h(
                  "button",
                  {
                    onClick: toggleRec,
                    style: {
                      padding: "4px 8px",
                      borderRadius: 5,
                      border: "1px solid " + (isRec ? "#ef4444" : th.ac),
                      background: isRec ? "#ef444420" : th.ac + "15",
                      color: isRec ? "#ef4444" : th.ac,
                      fontSize: 9,
                      fontWeight: 600,
                      cursor: "pointer",
                    },
                  },
                  isRec ? "⏹ Stop Recording" : "⏺ Record",
                ),
                isRec &&
                  h(
                    "span",
                    {
                      style: {
                        fontSize: 9,
                        fontWeight: 600,
                        color: "#ef4444",
                        padding: "5px 10px",
                        borderRadius: 5,
                        background: "#ef444415",
                      },
                    },
                    "● REC " + recType.toUpperCase(),
                  ),
                !isRec &&
                  h(
                    "select",
                    {
                      value: recType,
                      onChange: function (e) {
                        setRecType(e.target.value);
                      },
                      style: {
                        padding: "6px 10px",
                        borderRadius: 5,
                        border: "1px solid " + th.bd,
                        background: th.c2,
                        color: th.t2,
                        fontSize: 9,
                        fontWeight: 600,
                        cursor: "pointer",
                      },
                    },
                    h("option", { value: "eeg" }, "EEG Data"),
                    hasAux("fnirs") &&
                      h("option", { value: "fnirs" }, "fNIRS Data"),
                    hasAux("ppg") &&
                      h("option", { value: "ppg" }, "PPG/Heart Rate"),
                    hasAux("imu") &&
                      h("option", { value: "imu" }, "IMU/Motion"),
                  ),
                h(
                  "button",
                  {
                    onClick: function () {
                      setRecFilt(!recFilt);
                    },
                    style: {
                      padding: "4px 8px",
                      borderRadius: 5,
                      border: "1px solid " + (recFilt ? th.gd : th.bd),
                      background: recFilt ? th.gd + "20" : th.c2,
                      color: recFilt ? th.gd : th.t3,
                      fontSize: 9,
                      fontWeight: 600,
                      cursor: "pointer",
                    },
                  },
                  recFilt ? "✓ Filtered" : "Raw Signal",
                ),
              ),
              // Right group
              h(
                "div",
                { style: { display: "flex", alignItems: "center", gap: 8 } },
                h(
                  "button",
                  {
                    onClick: function () {
                      setView("proc");
                    },
                    style: {
                      padding: "4px 8px",
                      borderRadius: 5,
                      border: "1px solid " + th.ac,
                      background: th.ac + "15",
                      color: th.ac,
                      fontSize: 9,
                      fontWeight: 600,
                      cursor: "pointer",
                    },
                  },
                  "⚙️ Filter Settings",
                ),
                h(
                  "button",
                  {
                    onClick: function () {
                      setView("presets");
                    },
                    style: {
                      padding: "4px 8px",
                      borderRadius: 5,
                      border: "1px solid " + th.t2,
                      background: th.c2,
                      color: th.t2,
                      fontSize: 9,
                      fontWeight: 600,
                      cursor: "pointer",
                    },
                  },
                  "💾 Manage Presets",
                ),
              ),
              // ───────────────────────────────────────────────────────────────
              // ROW 3: Band & Channel Selectors
              // ───────────────────────────────────────────────────────────────
              // BAND FILTERS & CHANNELS (Horizontal bar above displays)
              h(
                "div",
                {
                  style: {
                    padding: "10px 12px",
                    borderBottom: "2px solid " + th.bd,
                    background: th.c1,
                    display: "flex",
                    alignItems: "center",
                    gap: 20,
                    flexWrap: "wrap",
                  },
                },
                // Band Filters
                h(
                  "div",
                  {
                    style: {
                      display: "flex",
                      alignItems: "center",
                      gap: 6,
                    },
                  },
                  h(
                    "span",
                    {
                      style: {
                        fontSize: 7,
                        fontWeight: 600,
                        color: th.t3,
                        textTransform: "uppercase",
                        letterSpacing: "0.05em",
                        marginRight: 4,
                      },
                    },
                    "BANDS:",
                  ),
                  BANDS.map(function (band, bi) {
                    var bandKey = band.n.toLowerCase();
                    var isEnabled = bandToggles[bandKey];
                    var color = th.isDark ? band.d : band.c;
                    return h(
                      "label",
                      {
                        key: bandKey,
                        style: {
                          display: "flex",
                          alignItems: "center",
                          gap: 4,
                          padding: "4px 8px",
                          borderRadius: 5,
                          border: "1px solid " + (isEnabled ? color : th.bd),
                          background: isEnabled ? color + "15" : th.c2,
                          cursor: "pointer",
                          fontSize: 9,
                          fontWeight: 600,
                          fontFamily: M,
                          transition: "all 0.2s",
                        },
                      },
                      h("input", {
                        type: "checkbox",
                        checked: isEnabled,
                        onChange: function () {
                          var next = {};
                          Object.keys(bandToggles).forEach(function (k) {
                            next[k] = bandToggles[k];
                          });
                          next[bandKey] = !next[bandKey];
                          setBandToggles(next);
                          setSBands(function (p) {
                            var isCurrentlyEnabled = p.indexOf(band.n) >= 0;
                            return isCurrentlyEnabled
                              ? p.filter(function (x) {
                                  return x !== band.n;
                                })
                              : p.concat([band.n]);
                          });
                          setBi(bi);
                        },
                        style: { width: 13, height: 13, cursor: "pointer" },
                      }),
                      h(
                        "span",
                        { style: { color: isEnabled ? color : th.t3 } },
                        band.n,
                      ),
                      h(
                        "span",
                        {
                          style: {
                            fontSize: 7,
                            color: th.t3,
                            marginLeft: 2,
                          },
                        },
                        band.r + " Hz",
                      ),
                    );
                  }),
                ),
                // Separator
                h("div", {
                  style: {
                    width: 1,
                    height: 20,
                    background: th.bd,
                  },
                }),
                // Channel Select
                h(
                  "div",
                  {
                    style: {
                      display: "flex",
                      alignItems: "center",
                      gap: 6,
                    },
                  },
                  h(
                    "span",
                    {
                      style: {
                        fontSize: 7,
                        fontWeight: 600,
                        color: th.t3,
                        textTransform: "uppercase",
                        letterSpacing: "0.05em",
                        marginRight: 4,
                      },
                    },
                    "CHANNELS:",
                  ),
                  d.eeg.map(function (el, idx) {
                    var isActive = sChs.indexOf(el.id) >= 0;
                    var chColor = th.isDark
                      ? BANDS[idx % 5].d
                      : BANDS[idx % 5].c;
                    return h(
                      "button",
                      {
                        key: el.id,
                        onClick: function () {
                          setSChs(function (p) {
                            return p.indexOf(el.id) >= 0
                              ? p.filter(function (x) {
                                  return x !== el.id;
                                })
                              : p.concat([el.id]);
                          });
                        },
                        style: {
                          padding: "4px 12px",
                          borderRadius: 5,
                          border: "1px solid " + (isActive ? chColor : th.bd),
                          background: isActive ? chColor + "15" : th.c2,
                          color: isActive ? chColor : th.t3,
                          fontSize: 9,
                          fontWeight: 600,
                          fontFamily: M,
                          cursor: "pointer",
                          transition: "all 0.2s",
                        },
                      },
                      el.id,
                    );
                  }),
                ),
                // Separator
                h("div", {
                  style: {
                    width: 1,
                    height: 20,
                    background: th.bd,
                  },
                }),
                // Display Mode Buttons
                h(
                  "div",
                  {
                    style: {
                      display: "flex",
                      alignItems: "center",
                      gap: 6,
                    },
                  },
                  h(
                    "span",
                    {
                      style: {
                        fontSize: 7,
                        fontWeight: 700,
                        color: th.t3,
                        textTransform: "uppercase",
                        letterSpacing: "0.05em",
                        marginRight: 4,
                      },
                    },
                    "VIEW:",
                  ),
                  ["single", "dual", "quad"].map(function (mode) {
                    var isActive = displayMode === mode;
                    var icon =
                      mode === "single" ? "📱" : mode === "dual" ? "⚏" : "▦";
                    var label = mode.charAt(0).toUpperCase() + mode.slice(1);
                    return h(
                      "button",
                      {
                        key: mode,
                        onClick: function () {
                          setDisplayMode(mode);
                        },
                        style: {
                          padding: "4px 8px",
                          borderRadius: 5,
                          border: "1px solid " + (isActive ? th.ac : th.bd),
                          background: isActive ? th.ac + "20" : th.c2,
                          color: isActive ? th.ac : th.t3,
                          fontSize: 9,
                          fontWeight: 600,
                          fontFamily: M,
                          cursor: "pointer",
                          transition: "all 0.2s",
                        },
                      },
                      icon + " " + label,
                    );
                  }),
                ),
              ),
              // CONTENT AREA (scrollable displays)
            ),
          ),

          // ═══════════════════════════════════════════════════════════════
          // MAIN LAYOUT: LEFT SIDEBAR + RIGHT DISPLAY AREA
          // ═══════════════════════════════════════════════════════════════
          h(
            "div",
            {
              style: {
                display: "flex",
                height: "calc(100vh - 180px)",
                overflow: "hidden",
              },
            },
            // ─────────────────────────────────────────────────────────────
            // LEFT SIDEBAR (Display Mode + View Selection)
            // ─────────────────────────────────────────────────────────────
            h(
              "div",
              {
                style: {
                  width: 200,
                  borderLeft: "2px solid " + th.bd,
                  background: th.c1,
                  overflowY: "auto",
                  display: "flex",
                  flexDirection: "column",
                  gap: 12,
                  padding: "12px",
                  order: 2,
                },
              },
              // View Selection (for Single/Dual mode)
              displayMode !== "quad" &&
                h(
                  "div",
                  null,
                  h(
                    "div",
                    {
                      style: {
                        fontSize: 7,
                        fontWeight: 600,
                        color: th.t3,
                        textTransform: "uppercase",
                        letterSpacing: "0.05em",
                        marginBottom: 6,
                      },
                    },
                    displayMode === "dual" ? "LEFT DISPLAY" : "DISPLAYS",
                  ),
                  h(
                    "div",
                    {
                      style: {
                        display: "flex",
                        flexDirection: "column",
                        gap: 2,
                      },
                    },
                    views.map(function (v) {
                      var isActive =
                        displayMode === "single"
                          ? view === v.id
                          : dualPanels[0] === v.id;
                      return h(
                        "button",
                        {
                          key: v.id,
                          onClick: function () {
                            if (displayMode === "single") {
                              setView(v.id);
                            } else {
                              setDualPanels([v.id, dualPanels[1]]);
                            }
                          },
                          style: {
                            padding: "6px 10px",
                            borderRadius: 5,
                            border: "1px solid " + (isActive ? th.ac : th.bd),
                            background: isActive ? th.ac + "20" : th.c2,
                            color: isActive ? th.ac : th.t2,
                            fontSize: 9,
                            fontWeight: isActive ? 700 : 400,
                            textAlign: "left",
                            cursor: "pointer",
                            transition: "all 0.2s",
                          },
                        },
                        v.i + " " + v.l,
                      );
                    }),
                  ),
                ),
              // Right Display Selection (Dual mode only)
              displayMode === "dual" &&
                h(
                  "div",
                  null,
                  h(
                    "div",
                    {
                      style: {
                        fontSize: 7,
                        fontWeight: 600,
                        color: th.t3,
                        textTransform: "uppercase",
                        letterSpacing: "0.05em",
                        marginBottom: 6,
                      },
                    },
                    "RIGHT DISPLAY",
                  ),
                  h(
                    "div",
                    {
                      style: {
                        display: "flex",
                        flexDirection: "column",
                        gap: 2,
                      },
                    },
                    views.map(function (v) {
                      var isActive = dualPanels[1] === v.id;
                      return h(
                        "button",
                        {
                          key: v.id,
                          onClick: function () {
                            setDualPanels([dualPanels[0], v.id]);
                          },
                          style: {
                            padding: "6px 10px",
                            borderRadius: 5,
                            border:
                              "1px solid " + (isActive ? "#f59e0b" : th.bd),
                            background: isActive ? "#f59e0b20" : th.c2,
                            color: isActive ? "#f59e0b" : th.t2,
                            fontSize: 9,
                            fontWeight: isActive ? 700 : 400,
                            textAlign: "left",
                            cursor: "pointer",
                            transition: "all 0.2s",
                          },
                        },
                        v.i + " " + v.l,
                      );
                    }),
                  ),
                ),
              h(
                "div",
                {
                  style: {
                    display: "flex",
                    flexDirection: "column",
                    gap: 2,
                  },
                },
                views.map(function (v) {
                  var isActive = view === v.id;
                  return h(
                    "button",
                    {
                      key: v.id,
                      onClick: function () {
                        setView(v.id);
                      },
                      style: {
                        padding: "6px 10px",
                        borderRadius: 5,
                        border: "1px solid " + (isActive ? th.ac : th.bd),
                        background: isActive ? th.ac + "20" : th.c2,
                        color: isActive ? th.ac : th.t2,
                        fontSize: 9,
                        fontWeight: isActive ? 700 : 400,
                        textAlign: "left",
                        cursor: "pointer",
                        transition: "all 0.2s",
                      },
                    },
                    v.i + " " + v.l,
                  );
                }),
              ),
            ),
          ),
          // ─────────────────────────────────────────────────────────────
          // RIGHT DISPLAY AREA
          // ─────────────────────────────────────────────────────────────
          h(
            "div",
            {
              style: {
                flex: 1,
                display: "flex",
                flexDirection: "column",
                overflow: "hidden",
                order: 1,
              },
            },
            h(
              "div",
              {
                style: {
                  flex: 1,
                  overflowY: "auto",
                  padding: "12px",
                  background: th.bg,
                  display: displayMode === "dual" ? "flex" : "block",
                  gap: displayMode === "dual" ? 12 : 0,
                },
              },
              // DISPLAY MODE RENDERING
              // ═══════════════════════════════════════════════════════

              // Single View Mode
              displayMode === "single" && renderView(view),

              // Dual View Mode (50/50 split)
              displayMode === "dual" &&
                h(
                  Fragment,
                  null,
                  h(
                    "div",
                    { style: { flex: 1, minWidth: 0 } },
                    renderView(dualPanels[0]),
                  ),
                  h(
                    "div",
                    { style: { flex: 1, minWidth: 0 } },
                    renderView(dualPanels[1]),
                  ),
                ),

              // Quad View Mode (2x2 grid)
              displayMode === "quad" &&
                h(
                  "div",
                  {
                    style: {
                      display: "grid",
                      gridTemplateColumns: "1fr 1fr",
                      gap: 12,
                      height: "100%",
                    },
                  },
                  quadPanels.map(function (vid) {
                    return h(
                      "div",
                      { key: vid, style: { minWidth: 0, minHeight: 0 } },
                      renderView(vid),
                    );
                  }),
                ),

              // Legacy: Keep existing view rendering for any views not in renderView()
              displayMode === "single" &&
                view === "timeline___OLD" &&
                h(
                  Card,
                  { t: th, title: "Power + Timeline" },
                  h(
                    "div",
                    {
                      style: { fontSize: 8, color: th.t3, marginBottom: 6 },
                    },
                    "Real-time band power meters (left) and scrolling EEG waveforms (right) for each selected channel. Power bars show relative amplitude 0\u2013100%. Green dots = sensor quality. Select bands and channels above.",
                  ),
                  h(PowerTL, {
                    t: th,
                    time: time,
                    dev: dev,
                    bands: sBands,
                    pid: pid,
                    fp: fp,
                    chs: sChs,
                    autoScale: autoScales.timeline,
                    yAxisRange: yAxisRanges.timeline,
                  }),
                  h(ScaleControls, {
                    t: th,
                    viewId: "timeline",
                    autoScale: autoScales.timeline,
                    yAxisRange: yAxisRanges.timeline,
                    setAutoScales: setAutoScales,
                    setYAxisRanges: setYAxisRanges,
                  }),
                ),
              displayMode === "single" &&
                view === "allbands" &&
                h(
                  Card,
                  { t: th, title: "All Bands Timeline" },
                  h(
                    "div",
                    {
                      style: { fontSize: 8, color: th.t3, marginBottom: 6 },
                    },
                    "Mind Monitor style: All 5 brain wave bands (Delta, Theta, Alpha, Beta, Gamma) displayed simultaneously as scrolling timelines. Each band has a unique color. Values are averaged across all active channels. Use the BAND FILTERS above to show/hide specific bands.",
                  ),
                  h(AllBandsTimeline, {
                    t: th,
                    time: time,
                    dev: dev,
                    pid: pid,
                    fp: fp,
                    bandToggles: bandToggles,
                  }),
                ),
              displayMode === "single" &&
                view === "topo" &&
                h(
                  Card,
                  { t: th, title: "Topographic Map \u2014 " + BANDS[bi].n },
                  h(
                    "div",
                    {
                      style: { fontSize: 8, color: th.t3, marginBottom: 6 },
                    },
                    d.name +
                      ": " +
                      d.ch +
                      " electrodes (" +
                      d.eeg
                        .map(function (e) {
                          return e.id;
                        })
                        .join(", ") +
                      ") mapped onto a head outline. Color intensity = " +
                      BANDS[bi].n +
                      " band power. Quality rings show electrode contact. Nose is at top.",
                  ),
                  h(TopoSVG, {
                    t: th,
                    time: time,
                    dev: dev,
                    bi: bi,
                    skin: skin,
                    pid: pid,
                    fp: fp,
                  }),
                ),
              displayMode === "single" &&
                view === "traces" &&
                h(
                  Card,
                  { t: th, title: "EEG Traces (NeurOSC Style)" },
                  h(
                    "div",
                    {
                      style: { fontSize: 8, color: th.t3, marginBottom: 6 },
                    },
                    "Raw EEG waveforms for all channels. 4-second window showing microVolt fluctuations. Each channel rendered in a different color with auto-scaling or manual range control.",
                  ),
                  h(TracesView, {
                    t: th,
                    time: time,
                    dev: dev,
                    autoScale: autoScales.traces,
                    yAxisRange: yAxisRanges.traces,
                    deviceModel: deviceModel,
                    inputFormat: inputFormat,
                  }),
                  h(ScaleControls, {
                    t: th,
                    viewId: "traces",
                    autoScale: autoScales.traces,
                    yAxisRange: yAxisRanges.traces,
                    setAutoScales: setAutoScales,
                    setYAxisRanges: setYAxisRanges,
                  }),
                ),
              displayMode === "single" &&
                view === "mentalstate" &&
                h(
                  Card,
                  { t: th, title: "Mental State (NeurOSC)" },
                  h(
                    "div",
                    {
                      style: { fontSize: 8, color: th.t3, marginBottom: 6 },
                    },
                    "Real-time mental state classification based on EEG band power ratios. Engagement index (Beta/Alpha+Theta), meditation score, and focus level. State automatically classified as Calm, Meditative, Focused, or Drowsy.",
                  ),
                  h(MentalStateView, {
                    t: th,
                    time: time,
                    dev: dev,
                  }),
                ),
              displayMode === "single" &&
                view === "filters" &&
                h(
                  Card,
                  { t: th, title: "DSP Filter Chain" },
                  h(
                    "div",
                    {
                      style: { fontSize: 9, color: th.t3, marginBottom: 6 },
                    },
                    "Complete settings snapshots for live performance. Each preset saves: DSP filters, OSC config, display view, band toggles, scales, and calibration.",
                  ),
                  h(
                    "div",
                    {
                      style: {
                        fontSize: 8,
                        color: "#10b981",
                        fontWeight: 600,
                        padding: "4px 8px",
                        background: "#10b98110",
                        borderRadius: 5,
                        display: "inline-block",
                        marginBottom: 10,
                      },
                    },
                    "⌨️ Keyboard: Press 1-9 to load presets instantly",
                  ),

                  // CAR Filter
                  h(
                    "div",
                    {
                      style: {
                        marginBottom: 16,
                        padding: 12,
                        background: th.c1,
                        borderRadius: 5,
                      },
                    },
                    h(
                      "label",
                      {
                        style: {
                          display: "flex",
                          alignItems: "center",
                          gap: 8,
                          cursor: "pointer",
                        },
                      },
                      h("input", {
                        type: "checkbox",
                        checked: dspCAR,
                        onChange: function (e) {
                          setDspCAR(e.target.checked);
                          fetch("/api/dsp/config", {
                            method: "POST",
                            headers: { "Content-Type": "application/json" },
                            body: JSON.stringify({
                              applyCAR: e.target.checked,
                            }),
                          });
                        },
                      }),
                      h(
                        "span",
                        { style: { fontWeight: 600, fontSize: 12 } },
                        "CAR - Common Average Reference",
                      ),
                    ),
                    h(
                      "div",
                      {
                        style: {
                          fontSize: 9,
                          color: th.t3,
                          marginTop: 4,
                          marginLeft: 24,
                        },
                      },
                      "Spatial filter: Subtracts mean of all channels to remove global noise (60Hz hum, muscle artifacts)",
                    ),
                  ),

                  // Notch Filter
                  h(
                    "div",
                    {
                      style: {
                        marginBottom: 16,
                        padding: 12,
                        background: th.c1,
                        borderRadius: 5,
                      },
                    },
                    h(
                      "label",
                      {
                        style: {
                          display: "flex",
                          alignItems: "center",
                          gap: 8,
                          cursor: "pointer",
                        },
                      },
                      h("input", {
                        type: "checkbox",
                        checked: dspNotch,
                        onChange: function (e) {
                          setDspNotch(e.target.checked);
                          fetch("/api/dsp/config", {
                            method: "POST",
                            headers: { "Content-Type": "application/json" },
                            body: JSON.stringify({
                              applyNotch: e.target.checked,
                            }),
                          });
                        },
                      }),
                      h(
                        "span",
                        { style: { fontWeight: 600, fontSize: 12 } },
                        "Notch Filter (60 Hz)",
                      ),
                    ),
                    h(
                      "div",
                      {
                        style: {
                          fontSize: 9,
                          color: th.t3,
                          marginTop: 4,
                          marginLeft: 24,
                        },
                      },
                      "Removes power line interference at 60 Hz (50 Hz for EU)",
                    ),
                  ),

                  // Bandpass Filter
                  h(
                    "div",
                    {
                      style: {
                        marginBottom: 16,
                        padding: 12,
                        background: th.c1,
                        borderRadius: 5,
                      },
                    },
                    h(
                      "label",
                      {
                        style: {
                          display: "flex",
                          alignItems: "center",
                          gap: 8,
                          cursor: "pointer",
                        },
                      },
                      h("input", {
                        type: "checkbox",
                        checked: dspBandpass,
                        onChange: function (e) {
                          setDspBandpass(e.target.checked);
                          fetch("/api/dsp/config", {
                            method: "POST",
                            headers: { "Content-Type": "application/json" },
                            body: JSON.stringify({
                              applyBandpass: e.target.checked,
                            }),
                          });
                        },
                      }),
                      h(
                        "span",
                        { style: { fontWeight: 600, fontSize: 12 } },
                        "Bandpass Filter (1-45 Hz)",
                      ),
                    ),
                    h(
                      "div",
                      {
                        style: {
                          fontSize: 9,
                          color: th.t3,
                          marginTop: 4,
                          marginLeft: 24,
                        },
                      },
                      "Isolates brain wave frequencies: removes DC offset and high-frequency muscle artifacts",
                    ),
                  ),

                  // Processing Chain Diagram
                  h(
                    "div",
                    {
                      style: {
                        marginTop: 24,
                        padding: 16,
                        background: th.c2,
                        borderRadius: 5,
                      },
                    },
                    h(
                      "div",
                      {
                        style: {
                          fontWeight: 600,
                          fontSize: 9,
                          marginBottom: 12,
                        },
                      },
                      "Active Processing Chain:",
                    ),
                    h(
                      "div",
                      {
                        style: {
                          fontSize: 9,
                          color: th.t2,
                          fontFamily: "monospace",
                          lineHeight: 1.6,
                        },
                      },
                      "Raw EEG → " +
                        (dspCAR ? "CAR → " : "") +
                        (dspNotch ? "Notch(60Hz) → " : "") +
                        (dspBandpass ? "Bandpass(1-45Hz) → " : "") +
                        "Smoothing → Output",
                    ),
                  ),
                ),
            ),
            displayMode === "single" &&
              view === "spectrum" &&
              h(
                Card,
                { t: th, title: "FFT Spectrum" },
                h(
                  "div",
                  { style: { fontSize: 8, color: th.t3, marginBottom: 6 } },
                  "Frequency spectrum analysis from 0.5-40 Hz. Shows power distribution across brain wave bands (delta, theta, alpha, beta, gamma). Each channel plotted in a different color for comparison.",
                ),
                h(SpectrumView, {
                  t: th,
                  time: time,
                  dev: dev,
                  bandToggles: bandToggles,
                }),
              ),
            displayMode === "single" &&
              view === "bands" &&
              h(
                Card,
                { t: th, title: "Band Powers" },
                h(
                  "div",
                  { style: { fontSize: 8, color: th.t3, marginBottom: 6 } },
                  "Relative power in each EEG frequency band (delta, theta, alpha, beta, gamma) shown as horizontal bars. Values normalized to percentages per channel. Color-coded by band type.",
                ),
                h(BandPowersView, {
                  t: th,
                  time: time,
                  dev: dev,
                  bandToggles: bandToggles,
                }),
              ),
            displayMode === "single" &&
              view === "waterfall" &&
              h(
                Card,
                {
                  t: th,
                  title: "3D Waterfall \u2014 " + BANDS[bi].n + " (IBVA-style)",
                },
                h(
                  "div",
                  { style: { fontSize: 8, color: th.t3, marginBottom: 6 } },
                  "Band power across all " +
                    d.ch +
                    " electrodes stacked in time (newer traces in front). Each line = one time snapshot. Height = amplitude. Inspired by the IBVA system\u2019s waterfall display for seeing temporal patterns in band power.",
                ),
                h(Waterfall, {
                  t: th,
                  time: time,
                  dev: dev,
                  bi: bi,
                  pid: pid,
                  fp: fp,
                }),
              ),
            displayMode === "single" &&
              view === "fullbrain" &&
              h(
                Card,
                {
                  t: th,
                  title: "Full Brain \u2014 " + BANDS[bi].n + " (EPOC-style)",
                },
                h(FullBrain, {
                  t: th,
                  time: time,
                  dev: dev,
                  bi: bi,
                  skin: skin,
                  pid: pid,
                  fp: fp,
                }),
              ),
            displayMode === "single" &&
              view === "phase" &&
              h(
                Card,
                { t: th, title: "Phase - Selected Bands" },
                h(
                  "div",
                  { style: { fontSize: 8, color: th.t3, marginBottom: 6 } },
                  "Polar plot showing phase angle and magnitude of selected band oscillations per electrode. Distance from center = power. Angle = instantaneous phase. When electrodes cluster together, the brain regions are synchronizing.",
                ),
                h(PhaseView, {
                  t: th,
                  time: time,
                  dev: dev,
                  bi: bi,
                  pid: pid,
                  fp: fp,
                  bandToggles: bandToggles,
                }),
              ),
            displayMode === "single" &&
              view === "coherence" &&
              h(
                Card,
                { t: th, title: "Coherence Matrix" },
                h(
                  "div",
                  { style: { fontSize: 8, color: th.t3, marginBottom: 6 } },
                  "Cross-electrode coherence: how synchronized oscillations are between each pair of electrodes. 100% = perfectly in phase. High coherence suggests functional connectivity between brain regions.",
                ),
                h(CoherenceView, {
                  t: th,
                  time: time,
                  dev: dev,
                  bi: bi,
                  bandToggles: bandToggles,
                }),
              ),
            displayMode === "single" &&
              view === "connect" &&
              h(
                Card,
                { t: th, title: "Sensor Connectivity \u2014 " + d.name },
                h(ConnectView, { t: th, time: time, dev: dev }),
              ),
            displayMode === "single" &&
              view === "neuro" &&
              h(
                Card,
                { t: th, title: "Neuro Indices" },
                h(
                  "div",
                  { style: { fontSize: 8, color: th.t3, marginBottom: 6 } },
                  "Computed ratios from band powers, averaged across electrodes. Focus = Beta/Theta (attention). Relax = Alpha/Beta (calm). Meditate = Theta/Alpha (deep states). Drowsy = Delta/Alpha (fatigue). Values are smoothed for stability.",
                ),
                h(
                  "div",
                  { style: { maxWidth: "50%", margin: "0 auto" } },
                  h(NeuroView, {
                    t: th,
                    time: time,
                    dev: dev,
                    pid: pid,
                    fp: fp,
                  }),
                ),
              ),
            displayMode === "single" &&
              view === "fft" &&
              h(
                Card,
                { t: th, title: "FFT Spectrum + Power Bands" },
                h(
                  "div",
                  { style: { fontSize: 8, color: th.t3, marginBottom: 6 } },
                  "Left: live frequency spectrum (0\u201360 Hz) with band regions color-coded. Right: all 5 band powers as animated bars with sparkline histories. Shows how spectral energy distributes across bands in real time.",
                ),
                h(FFTView, {
                  t: th,
                  time: time,
                  dev: dev,
                  pid: pid,
                  fp: fp,
                  autoScale: autoScales.fft,
                  yAxisRange: yAxisRanges.fft,
                }),
                h(ScaleControls, {
                  t: th,
                  viewId: "fft",
                  autoScale: autoScales.fft,
                  yAxisRange: yAxisRanges.fft,
                  setAutoScales: setAutoScales,
                  setYAxisRanges: setYAxisRanges,
                }),
              ),
            displayMode === "single" &&
              view === "fnirs" &&
              h(
                Card,
                { t: th, title: "fNIRS \u2014 Hemodynamic Response" },
                h(
                  "div",
                  { style: { fontSize: 8, color: th.t3, marginBottom: 6 } },
                  "Functional near-infrared spectroscopy measures blood oxygenation changes in the prefrontal cortex. Traces show oxygenated (HbO) and deoxygenated (HbR) hemoglobin concentration. Increases in HbO indicate increased neural activity in that region.",
                ),
                h(
                  "div",
                  {
                    style: {
                      display: "flex",
                      gap: 6,
                      marginBottom: 8,
                      justifyContent: "center",
                    },
                  },
                  ["HbO", "HbR", "HbT"].map(function (ch) {
                    var chColors = {
                      HbO: "#ef4444",
                      HbR: "#22c55e",
                      HbT: "#3b82f6",
                    };
                    var chLabels = {
                      HbO: "HbO (Oxy)",
                      HbR: "HbR (Deoxy)",
                      HbT: "HbT (Total)",
                    };
                    return h(
                      "label",
                      {
                        key: ch,
                        style: {
                          display: "flex",
                          alignItems: "center",
                          gap: 4,
                          padding: "4px 8px",
                          borderRadius: 5,
                          border:
                            "2px solid " +
                            (fnirsToggles[ch] ? chColors[ch] : th.bd),
                          background: fnirsToggles[ch]
                            ? chColors[ch] + "20"
                            : th.c2,
                          cursor: "pointer",
                          fontSize: 8,
                          fontWeight: 600,
                        },
                      },
                      h("input", {
                        type: "checkbox",
                        checked: fnirsToggles[ch],
                        onChange: function () {
                          var next = {};
                          Object.keys(fnirsToggles).forEach(function (k) {
                            next[k] = fnirsToggles[k];
                          });
                          next[ch] = !next[ch];
                          setFnirsToggles(next);
                        },
                        style: { width: 12, height: 12 },
                      }),
                      h(
                        "span",
                        {
                          style: {
                            color: fnirsToggles[ch] ? chColors[ch] : th.t3,
                          },
                        },
                        chLabels[ch],
                      ),
                    );
                  }),
                ),
                h(AuxPanel, {
                  t: th,
                  time: time,
                  dev: dev,
                  kind: "fnirs",
                  auxOn: auxOn,
                  autoScale: autoScales.fnirs,
                  yAxisRange: yAxisRanges.fnirs,
                  fnirsToggles: fnirsToggles,
                }),
                h(ScaleControls, {
                  t: th,
                  viewId: "fnirs",
                  autoScale: autoScales.fnirs,
                  yAxisRange: yAxisRanges.fnirs,
                  setAutoScales: setAutoScales,
                  setYAxisRanges: setYAxisRanges,
                }),
              ),
            displayMode === "single" &&
              view === "ppg" &&
              h(
                Card,
                { t: th, title: "PPG / Heart Rate" },
                h(
                  "div",
                  { style: { fontSize: 8, color: th.t3, marginBottom: 6 } },
                  "Photoplethysmography measures blood volume pulse via infrared light. The BPM readout is smoothed. The waveform shows the cardiac cycle. Heart rate variability (HRV) can be observed in the spacing between peaks.",
                ),
                h(AuxPanel, {
                  t: th,
                  time: time,
                  dev: dev,
                  kind: "ppg",
                  auxOn: auxOn,
                  autoScale: autoScales.ppg,
                  yAxisRange: yAxisRanges.ppg,
                }),
                h(ScaleControls, {
                  t: th,
                  viewId: "ppg",
                  autoScale: autoScales.ppg,
                  yAxisRange: yAxisRanges.ppg,
                  setAutoScales: setAutoScales,
                  setYAxisRanges: setYAxisRanges,
                }),
              ),
            displayMode === "single" &&
              view === "imu" &&
              h(
                Card,
                { t: th, title: "IMU \u2014 Motion Sensors" },
                h(
                  "div",
                  { style: { fontSize: 8, color: th.t3, marginBottom: 6 } },
                  "6-axis inertial measurement unit: accelerometer (AccX/Y/Z in g-force, Z\u22489.8 at rest) and gyroscope (GyroX/Y/Z in \u00B0/s). Useful for detecting head movement artifacts and meditation stillness.",
                ),
                h(AuxPanel, {
                  t: th,
                  time: time,
                  dev: dev,
                  kind: "imu",
                  auxOn: auxOn,
                  autoScale: autoScales.imu,
                  yAxisRange: yAxisRanges.imu,
                }),
                h(ScaleControls, {
                  t: th,
                  viewId: "imu",
                  autoScale: autoScales.imu,
                  yAxisRange: yAxisRanges.imu,
                  setAutoScales: setAutoScales,
                  setYAxisRanges: setYAxisRanges,
                }),
              ),

            displayMode === "single" &&
              view === "oscmon" &&
              h(Card, { t: th, title: "OSC Stream Monitor" }, h(OSCMonitor)),

            displayMode === "single" &&
              view === "quad" &&
              h(
                "div",
                {
                  style: {
                    display: "grid",
                    gridTemplateColumns: "1fr 1fr",
                    gridTemplateRows: "minmax(240px,1fr) minmax(240px,1fr)",
                    gap: 8,
                    minHeight: 520,
                  },
                },
                [0, 1, 2, 3].map(function (qi) {
                  var panelId = quadPanels[qi];
                  var panelLabel =
                    (
                      displayOpts.find(function (o) {
                        return o.id === panelId;
                      }) || {}
                    ).l || "Select";
                  return h(
                    "div",
                    {
                      key: qi,
                      style: {
                        background: th.c1,
                        borderRadius: 10,
                        border: "1px solid " + th.bd,
                        overflow: "hidden",
                        display: "flex",
                        flexDirection: "column",
                      },
                    },
                    // Quadrant header with dropdown
                    h(
                      "div",
                      {
                        style: {
                          padding: "4px 8px",
                          borderBottom: "1px solid " + th.bd,
                          display: "flex",
                          justifyContent: "space-between",
                          alignItems: "center",
                          background: th.c2,
                          flexShrink: 0,
                        },
                      },
                      h(
                        "span",
                        {
                          style: {
                            fontSize: 8,
                            fontWeight: 600,
                            color: th.t3,
                          },
                        },
                        ["A", "B", "C", "D"][qi],
                      ),
                      h(
                        "select",
                        {
                          value: panelId,
                          onChange: function (e) {
                            setQuadPanels(function (p) {
                              var n = p.slice();
                              n[qi] = e.target.value;
                              return n;
                            });
                          },
                          style: {
                            padding: "2px 4px",
                            borderRadius: 5,
                            border: "1px solid " + th.bd,
                            background: th.sg,
                            color: th.tx,
                            fontSize: 8,
                            fontFamily: M,
                            maxWidth: 140,
                          },
                        },
                        displayOpts.map(function (o) {
                          return h("option", { key: o.id, value: o.id }, o.l);
                        }),
                      ),
                    ),
                    // Quadrant content
                    h(
                      "div",
                      {
                        style: {
                          padding: 8,
                          flex: 1,
                          overflow: "auto",
                          minHeight: 0,
                        },
                      },
                      renderPanel(panelId),
                    ),
                  );
                }),
              ),

            displayMode === "single" &&
              view === "proc" &&
              h(
                "div",
                {
                  style: {
                    display: "grid",
                    gridTemplateColumns: "340px 1fr",
                    gap: 12,
                    minHeight: 300,
                  },
                },
                // LEFT: Filter controls panel
                h(
                  Card,
                  { t: th, title: "Signal Processing" },
                  h(
                    "div",
                    null,
                    ["Filter", "Smooth", "Gate", "Shape"].map(function (cat) {
                      return h(
                        "div",
                        { key: cat, style: { marginBottom: 8 } },
                        h(
                          "div",
                          {
                            style: {
                              fontSize: 8,
                              fontWeight: 600,
                              color: th.t3,
                              textTransform: "uppercase",
                              letterSpacing: ".05em",
                              marginBottom: 3,
                            },
                          },
                          cat,
                        ),
                        h(
                          "div",
                          {
                            style: {
                              display: "flex",
                              flexWrap: "wrap",
                              gap: 3,
                            },
                          },
                          PROCS.filter(function (p) {
                            return p.cat === cat;
                          }).map(function (p) {
                            return h(
                              "button",
                              {
                                key: p.id,
                                onClick: function () {
                                  setPid(p.id);
                                },
                                style: {
                                  padding: "4px 8px",
                                  borderRadius: 5,
                                  border:
                                    "1px solid " +
                                    (pid === p.id ? th.ac : th.bd),
                                  background:
                                    pid === p.id ? th.ac + "18" : "transparent",
                                  fontSize: 9,
                                  fontWeight: pid === p.id ? 700 : 400,
                                  color: pid === p.id ? th.ac : th.tx,
                                },
                              },
                              p.n,
                            );
                          }),
                        ),
                      );
                    }),
                    h(
                      "div",
                      {
                        style: {
                          marginTop: 8,
                          padding: "8px 10px",
                          borderRadius: 8,
                          background: th.sg,
                          border: "1px solid " + th.bd,
                        },
                      },
                      h(
                        "div",
                        {
                          style: {
                            fontSize: 9,
                            fontWeight: 600,
                            color: th.t2,
                            marginBottom: 4,
                          },
                        },
                        "Active: " +
                          (
                            PROCS.find(function (p) {
                              return p.id === pid;
                            }) || {}
                          ).n,
                      ),
                      (pid === "lp" || pid === "ema" || pid === "hp") &&
                        h(
                          "div",
                          {
                            style: {
                              display: "flex",
                              alignItems: "center",
                              gap: 6,
                            },
                          },
                          h(
                            "span",
                            {
                              style: {
                                fontSize: 9,
                                color: th.t2,
                                width: 50,
                              },
                            },
                            "Alpha",
                          ),
                          h("input", {
                            type: "range",
                            min: 0.01,
                            max: 0.99,
                            step: 0.01,
                            value: fp.a || 0.2,
                            onChange: function (e) {
                              setFp(
                                Object.assign({}, fp, {
                                  a: +e.target.value,
                                }),
                              );
                            },
                            style: { flex: 1, accentColor: th.ac },
                          }),
                          h(
                            "span",
                            {
                              style: {
                                fontSize: 9,
                                color: th.ac,
                                fontFamily: M,
                              },
                            },
                            (fp.a || 0.2).toFixed(2),
                          ),
                        ),
                      pid === "notch" &&
                        h(
                          "div",
                          { style: { display: "flex", gap: 4 } },
                          [50, 60].map(function (f) {
                            return h(Pill, {
                              key: f,
                              on: (fp.nf || 60) === f,
                              fn: function () {
                                setFp(Object.assign({}, fp, { nf: f }));
                              },
                              c: th.ac,
                              t: th,
                              label: f + " Hz",
                            });
                          }),
                        ),
                      pid === "gate" &&
                        h(
                          "div",
                          {
                            style: {
                              display: "flex",
                              alignItems: "center",
                              gap: 6,
                            },
                          },
                          h(
                            "span",
                            {
                              style: {
                                fontSize: 9,
                                color: th.t2,
                                width: 60,
                              },
                            },
                            "Threshold",
                          ),
                          h("input", {
                            type: "range",
                            min: 1,
                            max: 80,
                            step: 1,
                            value: fp.gt || 20,
                            onChange: function (e) {
                              setFp(
                                Object.assign({}, fp, {
                                  gt: +e.target.value,
                                }),
                              );
                            },
                            style: { flex: 1, accentColor: th.ac },
                          }),
                          h(
                            "span",
                            {
                              style: {
                                fontSize: 9,
                                color: th.ac,
                                fontFamily: M,
                              },
                            },
                            fp.gt || 20,
                          ),
                        ),
                      pid === "hyst" &&
                        h(
                          Fragment,
                          null,
                          h(
                            "div",
                            {
                              style: {
                                display: "flex",
                                alignItems: "center",
                                gap: 6,
                              },
                            },
                            h(
                              "span",
                              {
                                style: {
                                  fontSize: 9,
                                  color: th.t2,
                                  width: 60,
                                },
                              },
                              "High",
                            ),
                            h("input", {
                              type: "range",
                              min: 10,
                              max: 100,
                              step: 1,
                              value: fp.hi || 40,
                              onChange: function (e) {
                                setFp(
                                  Object.assign({}, fp, {
                                    hi: +e.target.value,
                                  }),
                                );
                              },
                              style: { flex: 1, accentColor: th.ac },
                            }),
                            h(
                              "span",
                              {
                                style: {
                                  fontSize: 9,
                                  color: th.ac,
                                  fontFamily: M,
                                },
                              },
                              fp.hi || 40,
                            ),
                          ),
                          h(
                            "div",
                            {
                              style: {
                                display: "flex",
                                alignItems: "center",
                                gap: 6,
                                marginTop: 4,
                              },
                            },
                            h(
                              "span",
                              {
                                style: {
                                  fontSize: 9,
                                  color: th.t2,
                                  width: 60,
                                },
                              },
                              "Low",
                            ),
                            h("input", {
                              type: "range",
                              min: 1,
                              max: 80,
                              step: 1,
                              value: fp.lo || 20,
                              onChange: function (e) {
                                setFp(
                                  Object.assign({}, fp, {
                                    lo: +e.target.value,
                                  }),
                                );
                              },
                              style: { flex: 1, accentColor: th.ac },
                            }),
                            h(
                              "span",
                              {
                                style: {
                                  fontSize: 9,
                                  color: th.ac,
                                  fontFamily: M,
                                },
                              },
                              fp.lo || 20,
                            ),
                          ),
                        ),
                      (pid === "savgol" ||
                        pid === "median" ||
                        pid === "rms" ||
                        pid === "gauss") &&
                        h(
                          "div",
                          {
                            style: {
                              display: "flex",
                              alignItems: "center",
                              gap: 6,
                            },
                          },
                          h(
                            "span",
                            {
                              style: {
                                fontSize: 9,
                                color: th.t2,
                                width: 60,
                              },
                            },
                            "Window",
                          ),
                          h("input", {
                            type: "range",
                            min: 3,
                            max: 21,
                            step: 2,
                            value: fp.win || 7,
                            onChange: function (e) {
                              setFp(
                                Object.assign({}, fp, {
                                  win: +e.target.value,
                                }),
                              );
                            },
                            style: { flex: 1, accentColor: th.ac },
                          }),
                          h(
                            "span",
                            {
                              style: {
                                fontSize: 9,
                                color: th.ac,
                                fontFamily: M,
                              },
                            },
                            fp.win || 7,
                          ),
                        ),
                      pid === "thresh" &&
                        h(
                          "div",
                          {
                            style: {
                              display: "flex",
                              alignItems: "center",
                              gap: 6,
                            },
                          },
                          h(
                            "span",
                            {
                              style: {
                                fontSize: 9,
                                color: th.t2,
                                width: 60,
                              },
                            },
                            "Threshold",
                          ),
                          h("input", {
                            type: "range",
                            min: 1,
                            max: 80,
                            step: 1,
                            value: fp.th || 30,
                            onChange: function (e) {
                              setFp(
                                Object.assign({}, fp, {
                                  th: +e.target.value,
                                }),
                              );
                            },
                            style: { flex: 1, accentColor: th.ac },
                          }),
                          h(
                            "span",
                            {
                              style: {
                                fontSize: 9,
                                color: th.ac,
                                fontFamily: M,
                              },
                            },
                            fp.th || 30,
                          ),
                        ),
                      pid === "slew" &&
                        h(
                          "div",
                          {
                            style: {
                              display: "flex",
                              alignItems: "center",
                              gap: 6,
                            },
                          },
                          h(
                            "span",
                            {
                              style: {
                                fontSize: 9,
                                color: th.t2,
                                width: 60,
                              },
                            },
                            "Rate",
                          ),
                          h("input", {
                            type: "range",
                            min: 0.5,
                            max: 30,
                            step: 0.5,
                            value: fp.sr || 5,
                            onChange: function (e) {
                              setFp(
                                Object.assign({}, fp, {
                                  sr: +e.target.value,
                                }),
                              );
                            },
                            style: { flex: 1, accentColor: th.ac },
                          }),
                          h(
                            "span",
                            {
                              style: {
                                fontSize: 9,
                                color: th.ac,
                                fontFamily: M,
                              },
                            },
                            fp.sr || 5,
                          ),
                        ),
                      pid === "clip" &&
                        h(
                          "div",
                          {
                            style: {
                              display: "flex",
                              alignItems: "center",
                              gap: 6,
                            },
                          },
                          h(
                            "span",
                            {
                              style: {
                                fontSize: 9,
                                color: th.t2,
                                width: 60,
                              },
                            },
                            "Drive",
                          ),
                          h("input", {
                            type: "range",
                            min: 0.005,
                            max: 0.2,
                            step: 0.005,
                            value: fp.cd || 0.05,
                            onChange: function (e) {
                              setFp(
                                Object.assign({}, fp, {
                                  cd: +e.target.value,
                                }),
                              );
                            },
                            style: { flex: 1, accentColor: th.ac },
                          }),
                          h(
                            "span",
                            {
                              style: {
                                fontSize: 9,
                                color: th.ac,
                                fontFamily: M,
                              },
                            },
                            (fp.cd || 0.05).toFixed(3),
                          ),
                        ),
                      pid === "artifact" &&
                        h(
                          "div",
                          {
                            style: {
                              display: "flex",
                              alignItems: "center",
                              gap: 6,
                            },
                          },
                          h(
                            "span",
                            {
                              style: {
                                fontSize: 9,
                                color: th.t2,
                                width: 60,
                              },
                            },
                            "Reject >",
                          ),
                          h("input", {
                            type: "range",
                            min: 20,
                            max: 150,
                            step: 5,
                            value: fp.at || 80,
                            onChange: function (e) {
                              setFp(
                                Object.assign({}, fp, {
                                  at: +e.target.value,
                                }),
                              );
                            },
                            style: { flex: 1, accentColor: th.ac },
                          }),
                          h(
                            "span",
                            {
                              style: {
                                fontSize: 9,
                                color: th.ac,
                                fontFamily: M,
                              },
                            },
                            fp.at || 80,
                          ),
                        ),
                      pid === "deltafilt" &&
                        h(
                          "div",
                          { style: { fontSize: 9, color: th.t3 } },
                          "High-pass filter at ~4 Hz. Removes slow delta-band drift and low-frequency noise that dominates raw EEG. Useful when delta overwhelms other bands.",
                        ),
                      pid === "none" &&
                        h(
                          "div",
                          { style: { fontSize: 9, color: th.t3 } },
                          "Bypass \u2014 no processing",
                        ),
                    ),
                  ),
                ),
                // RIGHT: Live data display
                h(
                  "div",
                  {
                    style: {
                      display: "flex",
                      flexDirection: "column",
                      gap: 12,
                    },
                  },
                  h(
                    Card,
                    {
                      t: th,
                      title:
                        "Live Data \u2014 " +
                        BANDS[bi].n +
                        " (" +
                        ((
                          PROCS.find(function (p) {
                            return p.id === pid;
                          }) || {}
                        ).n || "Bypass") +
                        ")",
                    },
                    h(PowerTL, {
                      t: th,
                      time: time,
                      dev: dev,
                      bands: sBands,
                      pid: pid,
                      fp: fp,
                      chs: sChs,
                      autoScale: autoScales.timeline,
                      yAxisRange: yAxisRanges.timeline,
                    }),
                    h(ScaleControls, {
                      t: th,
                      viewId: "timeline",
                      autoScale: autoScales.timeline,
                      yAxisRange: yAxisRanges.timeline,
                      setAutoScales: setAutoScales,
                      setYAxisRanges: setYAxisRanges,
                    }),
                  ),
                ),
              ),

            displayMode === "single" &&
              view === "osc" &&
              h(
                Card,
                { t: th, title: "OSC Output" },
                h(
                  "div",
                  null,
                  // Send status + bridge status
                  h(
                    "div",
                    {
                      style: {
                        display: "flex",
                        alignItems: "center",
                        justifyContent: "space-between",
                        padding: "8px 10px",
                        borderRadius: 8,
                        background: oscSending ? th.gd + "10" : th.sg,
                        border:
                          "1px solid " + (oscSending ? th.gd + "40" : th.bd),
                        marginBottom: 10,
                      },
                    },
                    h(
                      "div",
                      null,
                      h(
                        "div",
                        {
                          style: {
                            fontSize: 9,
                            fontWeight: 600,
                            color: oscSending ? th.gd : th.tx,
                          },
                        },
                        oscSending ? "OSC Streaming Active" : "OSC Stopped",
                      ),
                      h(
                        "div",
                        {
                          style: {
                            display: "flex",
                            alignItems: "center",
                            gap: 6,
                            marginTop: 2,
                          },
                        },
                        h(
                          "span",
                          { style: { fontSize: 8, color: th.t3 } },
                          oscSending
                            ? "Sending " +
                                oscBands.length +
                                " bands " +
                                (oscFilt ? "(filtered)" : "(raw)") +
                                " to port " +
                                oscPort
                            : "Toggle 'OSC Sending' in the header to start",
                        ),
                        h(
                          "span",
                          {
                            style: {
                              fontSize: 7,
                              padding: "1px 6px",
                              borderRadius: 5,
                              fontWeight: 600,
                              background:
                                bridgeStatus === "server"
                                  ? th.gd + "20"
                                  : "#f59e0b20",
                              color:
                                bridgeStatus === "server" ? th.gd : "#f59e0b",
                            },
                          },
                          bridgeStatus === "server"
                            ? "\u25CF Backend Connected"
                            : "\u25CB Standalone",
                        ),
                      ),
                    ),
                    h(
                      "button",
                      {
                        onClick: function () {
                          setOscSending(!oscSending);
                        },
                        style: {
                          padding: "5px 14px",
                          borderRadius: 7,
                          border: "1px solid " + (oscSending ? th.rd : th.gd),
                          background: oscSending ? th.rd + "15" : th.gd + "15",
                          color: oscSending ? th.rd : th.gd,
                          fontSize: 9,
                          fontWeight: 600,
                        },
                      },
                      oscSending
                        ? "\u23F9 Stop Sending"
                        : "\u25B6 Start Sending",
                    ),
                  ),

                  // Filtered/Raw
                  h(
                    "div",
                    {
                      style: {
                        display: "flex",
                        alignItems: "center",
                        justifyContent: "space-between",
                        padding: "8px 10px",
                        borderRadius: 8,
                        background: oscFilt ? th.ac + "10" : th.sg,
                        border: "1px solid " + (oscFilt ? th.ac + "40" : th.bd),
                        marginBottom: 12,
                      },
                    },
                    h(
                      "div",
                      null,
                      h(
                        "div",
                        { style: { fontSize: 9, fontWeight: 700 } },
                        "Send " + (oscFilt ? "Filtered" : "Raw") + " Data",
                      ),
                      h(
                        "div",
                        { style: { fontSize: 9, color: th.t3 } },
                        oscFilt
                          ? "Using: " +
                              (
                                PROCS.find(function (p) {
                                  return p.id === pid;
                                }) || {}
                              ).n
                          : "Bypassing all processing",
                      ),
                    ),
                    h(
                      "button",
                      {
                        onClick: function () {
                          setOscFilt(!oscFilt);
                        },
                        style: {
                          width: 34,
                          height: 18,
                          borderRadius: 9,
                          border: "none",
                          background: oscFilt ? th.gd : th.bd,
                          position: "relative",
                        },
                      },
                      h("div", {
                        style: {
                          width: 14,
                          height: 14,
                          borderRadius: 7,
                          background: "#fff",
                          position: "absolute",
                          top: 2,
                          left: oscFilt ? 18 : 2,
                          transition: "left .2s",
                          boxShadow: "0 1px 3px rgba(0,0,0,.3)",
                        },
                      }),
                    ),
                  ),

                  // ── Target Routing ──
                  h(
                    "div",
                    { style: { marginBottom: 12 } },
                    h(
                      "div",
                      {
                        style: {
                          fontSize: 9,
                          fontWeight: 600,
                          color: th.t2,
                          textTransform: "uppercase",
                          letterSpacing: ".05em",
                          marginBottom: 6,
                        },
                      },
                      "OSC Targets \u2014 Route to Multiple Apps",
                    ),
                    h(
                      "div",
                      {
                        style: {
                          display: "flex",
                          flexDirection: "column",
                          gap: 4,
                        },
                      },
                      oscTargets.map(function (tgt, ti) {
                        return h(
                          "div",
                          {
                            key: ti,
                            style: {
                              display: "flex",
                              alignItems: "center",
                              gap: 8,
                              padding: "6px 10px",
                              borderRadius: 8,
                              background: tgt.enabled ? th.ac + "08" : th.sg,
                              border:
                                "1px solid " +
                                (tgt.enabled ? th.ac + "30" : th.bd),
                            },
                          },
                          // Enable toggle
                          h(
                            "button",
                            {
                              onClick: function () {
                                setOscTargets(function (p) {
                                  var n = p.slice();
                                  n[ti] = Object.assign({}, n[ti], {
                                    enabled: !n[ti].enabled,
                                  });
                                  return n;
                                });
                              },
                              style: {
                                width: 30,
                                height: 16,
                                borderRadius: 8,
                                border: "none",
                                background: tgt.enabled ? th.gd : th.bd,
                                position: "relative",
                                flexShrink: 0,
                              },
                            },
                            h("div", {
                              style: {
                                width: 12,
                                height: 12,
                                borderRadius: 5,
                                background: "#fff",
                                position: "absolute",
                                top: 2,
                                left: tgt.enabled ? 16 : 2,
                                transition: "left .2s",
                              },
                            }),
                          ),
                          // Name
                          h(
                            "span",
                            {
                              style: {
                                fontSize: 9,
                                fontWeight: 600,
                                color: tgt.enabled ? th.tx : th.t3,
                                minWidth: 100,
                              },
                            },
                            tgt.name,
                          ),
                          // Port input
                          h(
                            "span",
                            { style: { fontSize: 8, color: th.t3 } },
                            ":",
                          ),
                          h("input", {
                            value: tgt.port,
                            onChange: function (e) {
                              setOscTargets(function (p) {
                                var n = p.slice();
                                n[ti] = Object.assign({}, n[ti], {
                                  port: e.target.value,
                                });
                                return n;
                              });
                            },
                            style: {
                              width: 50,
                              padding: "2px 5px",
                              borderRadius: 5,
                              border: "1px solid " + th.bd,
                              background: th.sg,
                              color: th.tx,
                              fontSize: 9,
                              fontFamily: M,
                              textAlign: "center",
                            },
                          }),
                          // Mode selector
                          h(
                            "select",
                            {
                              value: tgt.mode,
                              onChange: function (e) {
                                setOscTargets(function (p) {
                                  var n = p.slice();
                                  n[ti] = Object.assign({}, n[ti], {
                                    mode: e.target.value,
                                  });
                                  return n;
                                });
                              },
                              style: {
                                padding: "2px 4px",
                                borderRadius: 5,
                                border: "1px solid " + th.bd,
                                background: th.sg,
                                color: th.tx,
                                fontSize: 8,
                                fontFamily: M,
                              },
                            },
                            h("option", { value: "A" }, "Mode A (Muse/Csound)"),
                            h("option", { value: "B" }, "Mode B (Scalar/Max)"),
                          ),
                          // Status
                          tgt.enabled &&
                            oscSending &&
                            h(
                              "span",
                              {
                                style: {
                                  fontSize: 7,
                                  color: th.gd,
                                  fontWeight: 600,
                                  fontFamily: M,
                                },
                              },
                              "\u25CF LIVE",
                            ),
                        );
                      }),
                    ),
                    h(
                      "div",
                      {
                        style: { fontSize: 8, color: th.t3, marginTop: 6 },
                      },
                      'Mode A = /muse/elements/{band}_absolute with "ffff" (4 floats per message, Csound-compatible)',
                      h("br"),
                      "Mode B = /eeg/{electrode}/{band} with single float (Max/MSP, TouchDesigner, Unity-friendly)",
                    ),
                  ),

                  // Connection settings
                  h(
                    "div",
                    {
                      style: {
                        display: "grid",
                        gridTemplateColumns: "1fr 100px",
                        gap: 8,
                        marginBottom: 12,
                        alignItems: "end",
                      },
                    },
                    h(
                      "div",
                      null,
                      h(
                        "div",
                        {
                          style: {
                            fontSize: 9,
                            color: th.t3,
                            fontWeight: 600,
                            textTransform: "uppercase",
                            letterSpacing: ".05em",
                            marginBottom: 3,
                          },
                        },
                        "Default Host",
                      ),
                      h(
                        "div",
                        {
                          style: {
                            padding: "5px 8px",
                            borderRadius: 5,
                            background: th.sg,
                            border: "1px solid " + th.bd,
                            fontSize: 9,
                            fontFamily: M,
                            color: th.tx,
                          },
                        },
                        "127.0.0.1",
                      ),
                    ),
                    h(
                      "div",
                      null,
                      h(
                        "div",
                        {
                          style: {
                            fontSize: 9,
                            color: th.t3,
                            fontWeight: 600,
                            textTransform: "uppercase",
                            letterSpacing: ".05em",
                            marginBottom: 3,
                          },
                        },
                        "Default Port",
                      ),
                      h("input", {
                        value: oscPort,
                        onChange: function (e) {
                          setOscPort(e.target.value);
                        },
                        style: {
                          padding: "5px 8px",
                          borderRadius: 5,
                          background: th.wr + "15",
                          border: "1px solid " + th.wr + "40",
                          fontSize: 9,
                          fontFamily: M,
                          color: th.wr,
                          fontWeight: 600,
                          width: "100%",
                          textAlign: "center",
                        },
                      }),
                    ),
                  ),

                  // Runtime status
                  h(
                    "div",
                    {
                      style: {
                        padding: "8px 10px",
                        borderRadius: 5,
                        background:
                          bridgeStatus === "server"
                            ? th.gd + "08"
                            : "#f59e0b10",
                        border:
                          "1px solid " +
                          (bridgeStatus === "server"
                            ? th.gd + "30"
                            : "#f59e0b30"),
                        marginBottom: 12,
                      },
                    },
                    bridgeStatus === "server"
                      ? h(
                          "div",
                          null,
                          h(
                            "div",
                            {
                              style: {
                                fontSize: 9,
                                fontWeight: 600,
                                color: th.gd,
                                marginBottom: 2,
                              },
                            },
                            "\u2713 Python Backend Connected \u2014 Real UDP OSC via python-osc",
                          ),
                          h(
                            "div",
                            { style: { fontSize: 8, color: th.t3 } },
                            "OSC packets sent by the backend to your configured targets.",
                          ),
                        )
                      : h(
                          "div",
                          null,
                          h(
                            "div",
                            {
                              style: {
                                fontSize: 9,
                                fontWeight: 600,
                                color: "#f59e0b",
                                marginBottom: 4,
                              },
                            },
                            "Standalone Mode \u2014 No OSC Output",
                          ),
                          h(
                            "div",
                            {
                              style: {
                                fontSize: 8,
                                color: th.t3,
                                lineHeight: 1.7,
                              },
                            },
                            "For real OSC to Csound/Max, use one of:",
                            h("br"),
                            h("br"),
                            h("b", null, "Option A: Electron app"),
                            " (recommended, no dependencies)",
                            h("br"),
                            h(
                              "span",
                              { style: { fontFamily: M, color: th.ac } },
                              "npm install && npm start",
                            ),
                            h("br"),
                            h("br"),
                            h("b", null, "Option B: Python server"),
                            " (uses a virtual environment to avoid PEP 668 conflicts)",
                            h("br"),
                            h(
                              "span",
                              { style: { fontFamily: M, color: th.ac } },
                              "python3 -m venv .venv && source .venv/bin/activate",
                            ),
                            h("br"),
                            h(
                              "span",
                              { style: { fontFamily: M, color: th.ac } },
                              "pip install fastapi uvicorn python-osc",
                            ),
                            h("br"),
                            h(
                              "span",
                              { style: { fontFamily: M, color: th.ac } },
                              "python neurovis-server.py",
                            ),
                            h("br"),
                            h(
                              "span",
                              {
                                style: {
                                  fontSize: 7,
                                  color: th.t3,
                                  fontStyle: "italic",
                                },
                              },
                              "On Windows: .venv\\Scripts\\activate instead of source .venv/bin/activate",
                            ),
                            h("br"),
                            h("br"),
                            "The OSC Monitor shows what ",
                            h("i", null, "would"),
                            " be sent.",
                          ),
                        ),
                  ),

                  // Stream rate
                  h(
                    "div",
                    { style: { marginBottom: 12 } },
                    h(
                      "div",
                      {
                        style: {
                          fontSize: 9,
                          fontWeight: 600,
                          color: th.t2,
                          textTransform: "uppercase",
                          letterSpacing: ".05em",
                          marginBottom: 4,
                        },
                      },
                      "Stream Rate & Smoothing",
                    ),
                    h(
                      "div",
                      {
                        style: {
                          display: "flex",
                          alignItems: "center",
                          gap: 6,
                          marginBottom: 6,
                        },
                      },
                      h(
                        "span",
                        { style: { fontSize: 9, color: th.t2, width: 80 } },
                        "Send Rate",
                      ),
                      h(
                        "select",
                        {
                          value: oscRate,
                          onChange: function (e) {
                            setOscRate(e.target.value);
                          },
                          style: {
                            padding: "3px 6px",
                            borderRadius: 5,
                            border: "1px solid " + th.bd,
                            background: th.sg,
                            color: th.tx,
                            fontSize: 9,
                            fontFamily: M,
                          },
                        },
                        h(
                          "option",
                          { value: "10" },
                          "10 Hz (Mind Monitor default)",
                        ),
                        h("option", { value: "20" }, "20 Hz"),
                        h("option", { value: "30" }, "30 Hz"),
                        h("option", { value: "60" }, "60 Hz (fast)"),
                      ),
                    ),
                    h(
                      "div",
                      {
                        style: {
                          display: "flex",
                          alignItems: "center",
                          gap: 6,
                        },
                      },
                      h(
                        "span",
                        { style: { fontSize: 9, color: th.t2, width: 80 } },
                        "OSC Smooth",
                      ),
                      h("input", {
                        type: "range",
                        min: 0.01,
                        max: 0.5,
                        step: 0.01,
                        value: oscSmooth,
                        onChange: function (e) {
                          setOscSmooth(+e.target.value);
                        },
                        style: { flex: 1, accentColor: th.ac },
                      }),
                      h(
                        "span",
                        {
                          style: {
                            fontSize: 9,
                            color: th.ac,
                            fontFamily: M,
                            minWidth: 30,
                          },
                        },
                        oscSmooth.toFixed(2),
                      ),
                    ),
                    h(
                      "div",
                      {
                        style: { fontSize: 8, color: th.t3, marginTop: 3 },
                      },
                      "Mind Monitor sends at 10 Hz. Lower smooth = less jitter, slower response.",
                    ),
                    h(
                      "div",
                      {
                        style: {
                          display: "flex",
                          alignItems: "center",
                          gap: 6,
                          marginTop: 6,
                        },
                      },
                      h(
                        "span",
                        { style: { fontSize: 9, color: th.t2, width: 80 } },
                        "OSC Scale",
                      ),
                      h("input", {
                        type: "range",
                        min: 0.1,
                        max: 5.0,
                        step: 0.1,
                        value: oscScale,
                        onChange: function (e) {
                          setOscScale(+e.target.value);
                        },
                        style: { flex: 1, accentColor: th.wr },
                      }),
                      h(
                        "span",
                        {
                          style: {
                            fontSize: 9,
                            color: th.wr,
                            fontFamily: M,
                            minWidth: 30,
                          },
                        },
                        oscScale.toFixed(1) + "x",
                      ),
                    ),
                    h(
                      "div",
                      {
                        style: { fontSize: 8, color: th.t3, marginTop: 2 },
                      },
                      "Scale multiplier for OSC output values. 1.0x = log10(\u00B5V\u00B2/Hz) matching Mind Monitor. Increase for Csound cpspch mapping.",
                    ),
                  ),

                  // Selective band streaming
                  h(
                    "div",
                    { style: { marginBottom: 12 } },
                    h(
                      "div",
                      {
                        style: {
                          fontSize: 9,
                          fontWeight: 600,
                          color: th.t2,
                          textTransform: "uppercase",
                          letterSpacing: ".05em",
                          marginBottom: 4,
                        },
                      },
                      "Select Streams to Send",
                    ),
                    h(
                      "div",
                      {
                        style: {
                          display: "flex",
                          flexWrap: "wrap",
                          gap: 3,
                        },
                      },
                      BANDS.map(function (b) {
                        var on = oscBands.indexOf(b.n) >= 0,
                          c = th === TH.dark ? b.d : b.c;
                        return h(Pill, {
                          key: b.n,
                          on: on,
                          fn: function () {
                            setOscBands(function (p) {
                              return on
                                ? p.filter(function (x) {
                                    return x !== b.n;
                                  })
                                : p.concat([b.n]);
                            });
                          },
                          c: c,
                          t: th,
                          label: b.n + " absolute",
                        });
                      }),
                    ),
                    h(
                      "div",
                      {
                        style: {
                          display: "flex",
                          flexWrap: "wrap",
                          gap: 3,
                          marginTop: 4,
                        },
                      },
                      BANDS.map(function (b) {
                        var key = b.n + "_rel";
                        var on = oscExtras.indexOf(key) >= 0;
                        var c = th === TH.dark ? b.d : b.c;
                        return h(Pill, {
                          key: key,
                          on: on,
                          fn: function () {
                            setOscExtras(function (p) {
                              return on
                                ? p.filter(function (x) {
                                    return x !== key;
                                  })
                                : p.concat([key]);
                            });
                          },
                          c: c,
                          t: th,
                          label: b.n + " relative",
                        });
                      }),
