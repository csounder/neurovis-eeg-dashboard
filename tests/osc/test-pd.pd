#N canvas 100 100 800 600 12;
#X text 20 20 NeuroVis EEG → Pure Data OSC Test;
#X text 20 50 SETUP: 1) Load this patch 2) Turn on audio (Pd menu → Media → Audio ON);
#X text 20 70 3) Start NeuroVis and enable OSC on port 7400;
#X text 20 90 4) Watch number boxes update with live EEG data;
#X obj 20 140 netreceive -u -b 7400;
#X obj 20 170 oscparse;
#X text 20 200 CH1 Alpha (absolute):;
#X obj 180 200 route /eeg/CH1/alpha/absolute;
#X obj 180 230 unpack f;
#X floatatom 180 260 8 0 0 0 - - - 0;
#X text 20 300 CH2 Beta (absolute):;
#X obj 180 300 route /eeg/CH2/beta/absolute;
#X obj 180 330 unpack f;
#X floatatom 180 360 8 0 0 0 - - - 0;
#X text 20 400 Alpha Average:;
#X obj 180 400 route /eeg/alpha/averages;
#X obj 180 430 unpack f;
#X floatatom 180 460 8 0 0 0 - - - 0;
#X text 420 140 Sonification: Alpha → Frequency (200-800 Hz);
#X obj 420 170 * 600;
#X obj 420 200 + 200;
#X obj 420 230 osc~;
#X obj 420 260 *~ 0.3;
#X obj 420 290 dac~;
#X text 20 520 INSTRUCTIONS:;
#X text 20 540 - Alpha power from CH1 controls the tone frequency;
#X text 20 560 - Number boxes show live values (0.0 to 1.0);
#X text 20 580 - Toggle DSP ON to hear the tone;
#X connect 4 0 5 0;
#X connect 5 0 7 0;
#X connect 5 0 11 0;
#X connect 5 0 15 0;
#X connect 7 0 8 0;
#X connect 8 0 9 0;
#X connect 8 0 19 0;
#X connect 11 0 12 0;
#X connect 12 0 13 0;
#X connect 15 0 16 0;
#X connect 16 0 17 0;
#X connect 19 0 20 0;
#X connect 20 0 21 0;
#X connect 21 0 22 0;
#X connect 22 0 23 0;
#X connect 22 0 23 1;
