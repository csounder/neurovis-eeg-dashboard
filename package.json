{
  "name": "neurovis-eeg",
  "version": "2.0.0",
  "description": "NeuroVis EEG — Unified Brain Activity Dashboard (Muse + OpenBCI)",
  "author": "Richard Boulanger",
  "license": "MIT",
  "main": "main.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server-enhanced.js",
    "electron": "electron .",
    "build-mac": "electron-builder --mac",
    "build-win": "electron-builder --win",
    "build-linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.neurovis.eeg",
    "productName": "NeuroVis",
    "mac": {
      "category": "public.app-category.healthcare-fitness",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "files": [
      "main.js",
      "preload.js",
      "neurovis.html",
      "server-enhanced.js",
      "dsp.js",
      "MuseBridge",
      "public/**"
    ]
  },
  "dependencies": {
    "brainflow": "^5.13.1",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "osc": "^2.4.5",
    "ws": "^8.13.0"
  },
  "devDependencies": {
    "browser-sync": "^3.0.4",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "nodemon": "^2.0.20",
    "playwright": "^1.59.1"
  }
}
