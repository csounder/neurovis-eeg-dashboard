#N canvas 0 0 1000 700 12;
#X obj 50 50 tgl 15 0 empty empty POWER 17 7 0 10 -262144 -1 -1 0 1;
#X obj 50 100 netreceive -u -b 7401;
#X obj 50 150 oscparse;
#X obj 50 200 route /muse/eeg;
#X floatatom 50 250 5 0 1 0 - - -;
#X floatatom 150 250 5 0 1 0 - - -;
#X floatatom 250 250 5 0 1 0 - - -;
#X floatatom 350 250 5 0 1 0 - - -;
#X comment 50 30 300 20 12 0 0 0 0 0 0 0 Muse EEG Synth - Pure Data;
#X comment 50 320 500 60 12 0 0 0 0 0 0 0 OSC INPUT ON PORT 7401:;
#X comment 50 30 600 20 12 0 0 0 0 0 0 0 Receives /muse/eeg [ch1 ch2 ch3 ch4] from Node.js;
#X obj 50 300 * 400;
#X obj 50 300 + 100;
#X obj 150 300 * 0.2;
#X obj 250 300 * 5000;
#X obj 250 300 + 500;
#X comment 50 380 500 60 12 0 0 0 0 0 0 0 MAPPING:;
#X comment 50 400 500 60 12 0 0 0 0 0 0 0 Ch1 (0-1) -> Frequency (100-500 Hz);
#X comment 50 420 500 60 12 0 0 0 0 0 0 0 Ch2 (0-1) -> Amplitude (0-0.2);
#X comment 50 440 500 60 12 0 0 0 0 0 0 0 Ch3 (0-1) -> Filter Cutoff (500-5000 Hz);
#X comment 50 460 500 60 12 0 0 0 0 0 0 0 Ch4 (0-1) -> Reserved;
#X obj 50 500 osc~ 200;
#X obj 50 550 *~ 0.2;
#X obj 50 600 moogladder~ 1000 0.5;
#X obj 50 650 dac~;
